@page
@model FYPilot.Web.Pages.Admin.MarketNeedsModel
@{
    ViewData["Title"]    = "Market Needs";
    ViewData["Subtitle"] = "Industry problem dataset used for AI project matching";
}

<div class="row g-4">
    <div class="col-lg-8">
        <div class="page-card p-4">
            <div class="d-flex align-items-center justify-content-between mb-3">
                <h6 class="fw-bold mb-0"><i class="bi bi-graph-up-arrow me-2 text-success"></i>Market Problems (@Model.Needs.Count)</h6>
            </div>
            <div class="table-responsive">
                <table class="table table-hover align-middle small">
                    <thead><tr><th>Sector</th><th>Problem</th><th>Demand</th><th>Solution</th></tr></thead>
                    <tbody>
                        @foreach (var n in Model.Needs.OrderByDescending(n => n.DemandScore))
                        {
                            <tr>
                                <td><span class="badge bg-primary-subtle text-primary text-capitalize">@n.Sector</span></td>
                                <td style="max-width:220px">
                                    <div class="fw-semibold">@n.Problem</div>
                                    <div class="text-muted-sm">@n.BusinessValue.Substring(0, Math.Min(n.BusinessValue.Length, 60))…</div>
                                </td>
                                <td>
                                    <div class="d-flex align-items-center gap-1">
                                        <div class="progress" style="height:4px;width:40px">
                                            <div class="progress-bar bg-success" style="width:@n.DemandScore%"></div>
                                        </div>
                                        <span class="fw-semibold @(n.DemandScore >= 80 ? "text-success" : n.DemandScore >= 60 ? "text-warning" : "text-danger")">@n.DemandScore</span>
                                    </div>
                                </td>
                                <td class="text-muted" style="max-width:180px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">@n.PossibleSolution</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="page-card p-4 mb-3">
            <h6 class="fw-bold mb-3">By Sector</h6>
            @foreach (var g in Model.Needs.GroupBy(n => n.Sector).OrderByDescending(g => g.Average(n => n.DemandScore)))
            {
                var avg = (int)g.Average(n => n.DemandScore);
                <div class="mb-2">
                    <div class="d-flex justify-content-between small mb-1">
                        <span class="text-capitalize">@g.Key (@g.Count())</span>
                        <span class="fw-semibold">@avg</span>
                    </div>
                    <div class="progress" style="height:6px">
                        <div class="progress-bar bg-primary" style="width:@avg%"></div>
                    </div>
                </div>
            }
        </div>

        <div class="page-card p-4">
            <h6 class="fw-bold mb-3">Add Market Need</h6>
            <form method="post">
                @Html.AntiForgeryToken()
                <div class="mb-2"><input asp-for="Input.Sector"          class="form-control form-control-sm" placeholder="Sector" /></div>
                <div class="mb-2"><input asp-for="Input.Problem"         class="form-control form-control-sm" placeholder="Problem" /></div>
                <div class="mb-2"><input asp-for="Input.PossibleSolution" class="form-control form-control-sm" placeholder="Possible Solution" /></div>
                <div class="mb-2"><input asp-for="Input.BusinessValue"   class="form-control form-control-sm" placeholder="Business Value" /></div>
                <div class="mb-2"><input asp-for="Input.DemandScore" type="number" min="0" max="100" class="form-control form-control-sm" placeholder="Demand 0-100" /></div>
                <button type="submit" class="btn btn-sm btn-primary w-100">Add Need</button>
            </form>
        </div>
    </div>
</div>
