            width: min(390px, calc(100vw - 2rem));
            display: grid;
            gap: .65rem;
            pointer-events: none;
        }

        .defense-toast {
            position: relative;
            display: grid;
            grid-template-columns: auto minmax(0, 1fr) auto;
            gap: .75rem;
            align-items: flex-start;
            overflow: hidden;
            padding: .9rem .95rem 1rem;
            border: 1px solid;
            border-radius: 18px;
            background: #fff;
            box-shadow: 0 20px 50px rgba(15, 23, 42, .16);
            opacity: 0;
            transform: translateY(-12px) scale(.98);
            transition: opacity .24s ease, transform .24s ease;
            pointer-events: auto;
        }

            .defense-toast.is-visible {
                opacity: 1;
                transform: translateY(0) scale(1);
            }

            .defense-toast.is-leaving {
                opacity: 0;
                transform: translateY(-8px) scale(.98);
            }

        .defense-toast--error {
            color: #7f1d1d;
            border-color: #fecaca;
            background: #fffafa;
        }

        .defense-toast--info {
            color: #304163;
            border-color: #cbd5e1;
            background: #fbfdff;
        }

        .defense-toast__icon {
            width: 36px;
            height: 36px;
            display: grid;
            place-items: center;
            border-radius: 12px;
            font-size: 1rem;
        }

        .defense-toast--error .defense-toast__icon {
            color: #991b1b;
            background: #fee2e2;
        }

        .defense-toast--info .defense-toast__icon {
            color: var(--defense-blue);
            background: #e8eef5;
        }

        .defense-toast__content {
            min-width: 0;
            padding-top: .05rem;
        }

            .defense-toast__content strong,
            .defense-toast__content span {
                display: block;
            }

            .defense-toast__content strong {
                font-size: .8rem;
                font-weight: 600;
                line-height: 1.35;
            }

            .defense-toast__content span {
                margin-top: .2rem;
                color: #52647f;
                font-size: .73rem;
                line-height: 1.5;
            }

        .defense-toast--error .defense-toast__content span {
            color: #7f1d1d;
        }

        .defense-toast__close {
            width: 30px;
            height: 30px;
            display: grid;
            place-items: center;
            margin: -.1rem -.15rem 0 0;
            padding: 0;
            border: 0;
            border-radius: 9px;
            color: #64748b;
            background: transparent;
            cursor: pointer;
            transition: background .15s ease, color .15s ease;
        }

            .defense-toast__close:hover {
                color: var(--defense-ink);
                background: rgba(148, 163, 184, .14);
            }

        .defense-toast__timer {
            position: absolute;
            right: 0;
            bottom: 0;
            left: 0;
            height: 3px;
            transform-origin: left;
            background: #94a3b8;
            animation: defense-toast-timer var(--toast-duration, 5200ms) linear forwards;
        }

        .defense-toast--error .defense-toast__timer {
            background: #dc2626;
        }

        .defense-toast--info .defense-toast__timer {
            background: var(--defense-blue);
        }

        .defense-area-grid.has-validation-error {
            padding: .65rem;
            border: 1px solid #f0b4b4;
            border-radius: 20px;
            background: #fffafa;
            animation: defense-validation-shake .28s ease;
        }

        @@keyframes defense-toast-timer {
            from {
                transform: scaleX(1);
            }

            to {
                transform: scaleX(0);
            }
        }

        @@keyframes defense-validation-shake {
            0%, 100% {
                transform: translateX(0);
            }

            35% {
                transform: translateX(-4px);
            }

            70% {
                transform: translateX(4px);
            }
        }


