@page
@using System
@using System.Linq
@using System.Collections.Generic
@model FYPilot.Web.Pages.Supervisor.MeetingsModel
@{
    ViewData["Title"] = "Meetings";
    ViewData["Subtitle"] = "Schedule, track, and prepare supervisor meetings.";

    var selected = Model.SelectedMeeting;
    var today = DateTime.Today;

    // ---------- Week navigation via ?week= query string (no PageModel changes needed) ----------
    int weekOffset = 0;
    int.TryParse(Request.Query["week"].ToString(), out weekOffset);

    var todayDow = (int)today.DayOfWeek; // Sunday = 0
    var mondayThisWeek = today.AddDays(todayDow == 0 ? -6 : -(todayDow - 1));
    var startOfWeek = mondayThisWeek.AddDays(7 * weekOffset);
    var endOfWeek = startOfWeek.AddDays(6);
    var weekDays = Enumerable.Range(0, 7).Select(i => startOfWeek.AddDays(i)).ToList();

    string BuildNavLink(int offset)
    {
        var qs = $"week={offset}";
        if (selected != null)
        {
            qs += $"&meetingId={selected.Id}";
        }
        return "/Supervisor/Meetings?" + qs;
    }

    // Union of upcoming + recent so a meeting scheduled further ahead still shows on the calendar
    var allMeetings = Model.UpcomingMeetings
        .Concat(Model.RecentMeetings)
        .GroupBy(m => m.Id)
        .Select(g => g.First())
        .ToList();

    var weekMeetings = allMeetings
        .Where(m =>
        {
            var d = m.ScheduledAt.ToLocalTime().Date;
            return d >= startOfWeek && d <= endOfWeek;
        })
        .ToList();
    // Fixed visible working hours: 9 AM until 7 PM.
    // This keeps the weekly scheduler consistent even when there are only morning meetings.
    int minHour = 9;
    int maxHour = 19;
    var hourSlots = Enumerable.Range(minHour, maxHour - minHour + 1).ToList();
}

<section class="meet-page">

    <header class="meet-hero">
        <div class="meet-hero-left">
            <div class="meet-hero-icon">
                <i class="bi bi-calendar-check"></i>
            </div>

            <div class="meet-hero-copy">
                <h1>Stay aligned. Make progress together.</h1>
                <p>Plan productive meetings, track action items, and keep your FYP journey on track.</p>
            </div>
        </div>

        <button type="button" class="meet-hero-action" id="openSchedulePanel">
            <i class="bi bi-plus-lg"></i>
            Schedule Meeting
        </button>
    </header>

    <section class="meet-layout">

        <main class="meet-main-column">

            <article class="meet-card">
                <div class="meet-card-head">
                    <div class="meet-card-title">
                        <i class="bi bi-calendar3"></i>
                        <h2>Upcoming Meetings</h2>
                    </div>

                    <a href="?week=0" class="meet-view-link">
                        View Calendar <i class="bi bi-chevron-right"></i>
                    </a>
                </div>

                @if (!Model.UpcomingMeetings.Any())
                {
                    <div class="meet-empty-state compact">
                        <i class="bi bi-calendar2-plus"></i>
                        <h3>No upcoming meetings</h3>
                        <p>Schedule your first real meeting from the form below.</p>
                    </div>
                }
                else
                {
                    <div class="meet-upcoming-list">
                        @foreach (var meeting in Model.UpcomingMeetings.Take(4))
                        {
                            var localStart = meeting.ScheduledAt.ToLocalTime();
                            var localEnd = meeting.ScheduledAt.AddMinutes(meeting.DurationMinutes).ToLocalTime();
                            var active = selected?.Id == meeting.Id;
                            var isToday = localStart.Date == today;

                            <a href="/Supervisor/Meetings?meetingId=@meeting.Id"
                               class="meet-upcoming-row @(active ? "active" : "")"
                               data-meeting-start="@meeting.ScheduledAt.ToString("O")"
                               data-meeting-end="@meeting.ScheduledAt.AddMinutes(meeting.DurationMinutes).ToString("O")">

                                @if (isToday)
                                {
                                    <span class="meet-today-badge">TODAY</span>
                                }
                                else
                                {
                                    <span class="meet-today-badge spacer"></span>
                                }

                                <div class="meet-upcoming-title">
                                    <h3>@meeting.Title</h3>
                                    <p>@ShortText(meeting.Agenda, 72)</p>
                                </div>

                                <div class="meet-upcoming-cell">
                                    <i class="bi bi-calendar3"></i>
                                    <div>
                                        <span>@localStart.ToString("MMM d, yyyy")</span>
                                        <small>@localStart.ToString("dddd")</small>
                                    </div>
                                </div>

                                <div class="meet-upcoming-cell">
                                    <i class="bi bi-clock"></i>
                                    <div>
                                        <span>@localStart.ToString("hh:mm tt")</span>
                                        <small>@meeting.DurationMinutes min</small>
                                    </div>
                                </div>

                                <div class="meet-upcoming-cell">
                                    <i class="bi bi-person"></i>
                                    <div>
                                        <span>@(meeting.Student?.FullName ?? "No student")</span>
                                        <small>Student</small>
                                    </div>
                                </div>

                                <div class="meet-upcoming-cell">
                                    <i class="@ModeIcon(meeting.MeetingMode)"></i>
                                    <div>
                                        <span>@ModeLabel(meeting.MeetingMode)</span>
                                        <small class="js-meeting-countdown">Calculating...</small>
                                    </div>
                                </div>

                                <span class="@(isToday ? "meet-status-today" : "meet-status") js-meeting-status">
                                    @(isToday ? "Today" : "Upcoming")
                                </span>
                            </a>
                        }
                    </div>
                }
            </article>

            <article class="meet-card">
                <div class="meet-card-head">
                    <div class="meet-card-title">
                        <i class="bi bi-calendar3"></i>
                        <h2>Weekly Schedule</h2>
                    </div>

                    <div class="meet-week-nav">
                        <span class="meet-week-range">@weekDays.First().ToString("MMM d") &ndash; @weekDays.Last().ToString("MMM d, yyyy")</span>
                        <a href="@BuildNavLink(weekOffset - 1)" class="meet-nav-btn" title="Previous week">
                            <i class="bi bi-chevron-left"></i>
                        </a>
                        <a href="@BuildNavLink(weekOffset + 1)" class="meet-nav-btn" title="Next week">
                            <i class="bi bi-chevron-right"></i>
                        </a>
                    </div>
                </div>

                <div class="meet-week-wrap">
                    <div class="meet-week-grid" id="meetWeeklyGrid">
                        <div class="meet-week-corner"></div>

                        @foreach (var day in weekDays)
                        {
                            <div class="meet-week-day">
                                <span>@day.ToString("ddd")</span>
                                @if (day.Date == today)
                                {
                                    <strong class="today-circle">@day.Day</strong>
                                }
                                else
                                {
                                    <strong>@day.Day</strong>
                                }
                            </div>
                        }

                        @foreach (var hour in hourSlots)
                        {
                            <div class="meet-hour-label">@DateTime.Today.AddHours(hour).ToString("h tt")</div>

                            @foreach (var day in weekDays)
                            {
                                var meetingsAtSlot = weekMeetings
                                    .Where(m =>
                                    {
                                        var local = m.ScheduledAt.ToLocalTime();
                                        return local.Date == day.Date && local.Hour == hour;
                                    })
                                    .OrderBy(m => m.ScheduledAt)
                                    .ToList();

                                <div class="meet-week-cell" data-day="@day.ToString("yyyy-MM-dd")" data-hour="@hour">
                                    @foreach (var meeting in meetingsAtSlot)
                                    {
                                        var localStart = meeting.ScheduledAt.ToLocalTime();

                                        <a href="/Supervisor/Meetings?meetingId=@meeting.Id"
                                           class="meet-week-event @(meeting.Status)"
                                           data-meeting-start="@meeting.ScheduledAt.ToString("O")"
                                           data-meeting-end="@meeting.ScheduledAt.AddMinutes(meeting.DurationMinutes).ToString("O")">
                                            <span>@localStart.ToString("h:mm tt") <i class="@ModeIcon(meeting.MeetingMode)"></i></span>
                                            <strong>@meeting.Title</strong>
                                        </a>
                                    }
                                </div>
                            }
                        }
                    </div>
                </div>
            </article>

        </main>

        <aside class="meet-details-card">
            @if (selected == null)
            {
                <div class="meet-empty-state tall">
                    <i class="bi bi-calendar-week"></i>
                    <h3>Select a meeting</h3>
                    <p>Meeting details will appear here after you select or schedule a meeting.</p>
                </div>
            }
            else
            {
                var selectedStart = selected.ScheduledAt.ToLocalTime();
                var selectedEnd = selected.ScheduledAt.AddMinutes(selected.DurationMinutes).ToLocalTime();
                var isSelectedToday = selectedStart.Date == today;

                <div class="meet-details-head">
                    <h2>Meeting Details</h2>
                    @if (isSelectedToday)
                    {
                        <span class="meet-today-pill">TODAY</span>
                    }
                    else
                    {
                        <span class="@StatusClass(selected.Status)">@DisplayStatus(selected)</span>
                    }
                </div>

                <h3 class="meet-details-title">@selected.Title</h3>

                <div class="meet-detail-meta">
                    <div>
                        <i class="bi bi-calendar3"></i>
                        <span>@selectedStart.ToString("MMM d, yyyy") @(isSelectedToday ? "(Today)" : "")</span>
                    </div>

                    <div>
                        <i class="bi bi-clock"></i>
                        <span>@selectedStart.ToString("hh:mm tt") &ndash; @selectedEnd.ToString("hh:mm tt")</span>
                    </div>

                    <div>
                        <i class="@ModeIcon(selected.MeetingMode)"></i>
                        <span>@ModeLabel(selected.MeetingMode) Meeting</span>
                    </div>
                </div>

                <div class="meet-with-box">
                    <div class="meet-with-avatar">@Initials(selected.Student?.FullName)</div>
                    <div>
                        <span>With</span>
                        <h3>@(selected.Student?.FullName ?? "No student selected")</h3>
                        <p>@(selected.Student?.Email ?? "No email available")</p>
                    </div>
                </div>

                <div class="meet-detail-section">
                    <h3>Agenda</h3>

                    @if (SplitLines(selected.Agenda).Any())
                    {
                        <ul>
                            @foreach (var item in SplitLines(selected.Agenda))
                            {
                                <li>@item</li>
                            }
                        </ul>
                    }
                    else
                    {
                        <p class="meet-muted">No agenda added.</p>
                    }
                </div>

                <div class="meet-detail-section">
                    <h3>Notes to prepare</h3>

                    @if (SplitLines(selected.NotesToPrepare).Any())
                    {
                        <ul>
                            @foreach (var item in SplitLines(selected.NotesToPrepare))
                            {
                                <li>@item</li>
                            }
                        </ul>
                    }
                    else
                    {
                        <p class="meet-muted">No preparation notes added.</p>
                    }
                </div>

                <div class="meet-join-card">
                    <div class="meet-join-icon">
                        <i class="bi bi-camera-video"></i>
                    </div>

                    <div class="meet-join-copy">
                        <span>Meeting Access</span>
                        <h3>@(selected.LocationOrLink != null && selected.LocationOrLink.StartsWith("http", StringComparison.OrdinalIgnoreCase) ? "Online meeting is ready" : "Meeting location")</h3>
                        <p>@(string.IsNullOrWhiteSpace(selected.LocationOrLink) ? "No online link or room location was added yet." : selected.LocationOrLink)</p>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(selected.LocationOrLink) && selected.LocationOrLink.StartsWith("http", StringComparison.OrdinalIgnoreCase))
                    {
                        <a href="@selected.LocationOrLink" target="_blank" rel="noopener" class="meet-join-btn">
                            <i class="bi bi-box-arrow-up-right"></i>
                            Join Meet
                        </a>
                    }
                    else
                    {
                        <span class="meet-join-disabled">No link</span>
                    }
                </div>

                <div class="meet-detail-actions">
                    @if (selected.Status == "scheduled")
                    {
                        <form method="post" asp-page-handler="Complete">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="meetingId" value="@selected.Id" />
                            <button type="submit" class="meet-soft-btn">
                                <i class="bi bi-check2 me-1"></i>
                                Mark Completed
                            </button>
                        </form>

                        <form method="post" asp-page-handler="Cancel">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="meetingId" value="@selected.Id" />
                            <button type="submit" class="meet-danger-btn">
                                <i class="bi bi-x-lg me-1"></i>
                                Cancel
                            </button>
                        </form>
                    }
                </div>
            }
        </aside>
    </section>

    <section class="meet-bottom-grid">
        <article class="meet-card meet-recent-card">
            <div class="meet-card-head">
                <div class="meet-card-title">
                    <i class="bi bi-chat-square-text"></i>
                    <h2>Recent Meetings</h2>
                </div>

                <span class="meet-view-link inactive">View All</span>
            </div>

            @if (!Model.RecentMeetings.Any())
            {
                <div class="meet-compact-empty">
                    No recent meetings yet.
                </div>
            }
            else
            {
                <div class="meet-recent-table">
                    <div class="meet-recent-header">
                        <span>Meeting</span>
                        <span>Date</span>
                        <span>Time</span>
                        <span>With</span>
                        <span>Mode</span>
                        <span>Duration</span>
                        <span>Outcome</span>
                    </div>

                    @foreach (var meeting in Model.RecentMeetings.Take(5))
                    {
                        var localStart = meeting.ScheduledAt.ToLocalTime();

                        <a href="/Supervisor/Meetings?meetingId=@meeting.Id" class="meet-recent-row">
                            <div class="meet-recent-title">
                                <span class="meet-recent-check @StatusDotClass(meeting.Status)">
                                    <i class="bi bi-check-circle-fill"></i>
                                </span>
                                <div>
                                    <h3>@meeting.Title</h3>
                                    <p>@ShortText(meeting.Agenda, 48)</p>
                                </div>
                            </div>

                            <span>@localStart.ToString("MMM d, yyyy")<small>@localStart.ToString("dddd")</small></span>
                            <span>@localStart.ToString("hh:mm tt")</span>

                            <span class="meet-recent-with">
                                <b class="meet-with-avatar-sm">@Initials(meeting.Student?.FullName)</b>
                                @(meeting.Student?.FullName ?? "No student")
                            </span>

                            <span><i class="@ModeIcon(meeting.MeetingMode)"></i> @ModeLabel(meeting.MeetingMode)</span>
                            <span>@meeting.DurationMinutes min</span>
                            <span><b class="@StatusClass(meeting.Status)">@DisplayStatus(meeting)</b></span>
                        </a>
                    }
                </div>
            }
        </article>
    </section>

    <div class="meet-schedule-overlay" id="scheduleOverlay"></div>

    <aside class="meet-schedule-panel" id="schedulePanel" aria-hidden="true">
        <div class="meet-panel-head">
            <div>
                <span>Schedule</span>
                <h2>Create Meeting</h2>
            </div>

            <button type="button" id="closeSchedulePanel" aria-label="Close schedule form">
                <i class="bi bi-x-lg"></i>
            </button>
        </div>

        <form method="post" asp-page-handler="Schedule" class="meet-form">
            @Html.AntiForgeryToken()

            <div class="meet-field">
                <label asp-for="Input.Title">Meeting title</label>
                <input asp-for="Input.Title" class="form-control" placeholder="Example: FYP progress meeting" />
            </div>

            <div class="meet-form-grid">
                <div class="meet-field">
                    <label asp-for="Input.StudentId">Student</label>
                    <select asp-for="Input.StudentId" class="form-select">
                        <option value="">No student selected</option>
                        @foreach (var student in Model.Students)
                        {
                            <option value="@student.Id">@student.FullName - @student.Email</option>
                        }
                    </select>
                </div>

                <div class="meet-field">
                    <label asp-for="Input.ScheduledAt">Date and time</label>
                    <input asp-for="Input.ScheduledAt" class="form-control" type="datetime-local" />
                </div>
            </div>

            <div class="meet-form-grid three">
                <div class="meet-field">
                    <label asp-for="Input.DurationMinutes">Duration</label>
                    <select asp-for="Input.DurationMinutes" class="form-select">
                        <option value="30">30 min</option>
                        <option value="45">45 min</option>
                        <option value="60">60 min</option>
                        <option value="90">90 min</option>
                        <option value="120">120 min</option>
                    </select>
                </div>

                <div class="meet-field">
                    <label asp-for="Input.MeetingMode">Mode</label>
                    <select asp-for="Input.MeetingMode" class="form-select">
                        <option value="online">Online</option>
                        <option value="in_person">In-person</option>
                        <option value="hybrid">Hybrid</option>
                    </select>
                </div>

                <div class="meet-field">
                    <label asp-for="Input.LocationOrLink">Location or link</label>
                    <input asp-for="Input.LocationOrLink" class="form-control" placeholder="Meet link, Zoom, office..." />
                </div>
            </div>

            <div class="meet-form-grid">
                <div class="meet-field">
                    <label asp-for="Input.Agenda">Agenda</label>
                    <textarea asp-for="Input.Agenda" class="form-control" rows="4" placeholder="One agenda item per line..."></textarea>
                </div>

                <div class="meet-field">
                    <label asp-for="Input.NotesToPrepare">Notes to prepare</label>
                    <textarea asp-for="Input.NotesToPrepare" class="form-control" rows="4" placeholder="What should be prepared before the meeting?"></textarea>
                </div>
            </div>

            <div class="meet-form-actions">
                <button type="submit" class="btn meet-primary-btn">
                    <i class="bi bi-calendar-plus me-1"></i>
                    Save Meeting
                </button>
            </div>
        </form>
    </aside>

</section>

@section Head {
    <style>
        :root {
            --meet-navy: #28385E;
            --meet-blue: #304163;
            --meet-steel: #516C8D;
            --meet-border: #E8ECF2;
            --meet-text: #111827;
            --meet-muted: #64748B;
            --meet-tint: #EEF2F6;
        }

        .meet-page {
            max-width: 1500px;
            margin: 0 auto;
            color: var(--meet-text);
            padding-bottom: 1.5rem;
        }

        .meet-alert {
            border: 0;
            border-radius: 18px;
            box-shadow: 0 14px 34px rgba(15,23,42,0.08);
        }

        /* ---------- Hero (matches reference: icon + copy left, button + illustration right) ---------- */
        .meet-hero {
            position: relative;
            min-height: 150px;
            margin-bottom: 1rem;
            border-radius: 24px;
            padding: 1.5rem 1.75rem;
            color: #ffffff;
            background: radial-gradient(circle at 92% 20%, rgba(255,255,255,0.10), transparent 32%), linear-gradient(120deg, #0B1F4D 0%, var(--meet-navy) 55%, var(--meet-blue) 100%);
            box-shadow: 0 18px 42px rgba(40,56,94,0.16);
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 1.5rem;
            overflow: hidden;
        }

        .meet-hero-left {
            display: flex;
            align-items: center;
            gap: 1.1rem;
            z-index: 1;
        }

        .meet-hero-icon {
            width: 56px;
            height: 56px;
            min-width: 56px;
            border-radius: 18px;
            background: rgba(255,255,255,0.14);
            border: 1px solid rgba(255,255,255,0.18);
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: 1.5rem;
        }

        .meet-hero-copy h1 {
            margin: 0;
            color: #ffffff;
            font-size: clamp(1.25rem, 2.2vw, 1.6rem);
            font-weight: 700;
            letter-spacing: -0.03em;
        }

        .meet-hero-copy p {
            margin: 0.3rem 0 0;
            max-width: 480px;
            color: rgba(255,255,255,0.78);
            line-height: 1.5;
            font-size: 0.88rem;
        }

        .meet-hero-action {
            z-index: 1;
            border: 0;
            color: var(--meet-blue);
            background: #ffffff;
            border-radius: 13px;
            padding: 0.7rem 1.1rem;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            font-size: 0.85rem;
            font-weight: 600;
            white-space: nowrap;
            box-shadow: 0 14px 30px rgba(0,0,0,0.14);
        }

            .meet-hero-action:hover {
                color: var(--meet-blue);
                background: #F8FAFC;
            }

        .meet-hero-art {
            position: absolute;
            right: 1.75rem;
            bottom: 0;
            width: 140px;
            height: 100px;
            display: none;
        }

        @@media (min-width: 1100px) {
            .meet-hero-art {
                display: block;
            }
        }

        .meet-hero-screen {
            position: absolute;
            right: 0;
            bottom: 0.5rem;
            width: 110px;
            height: 70px;
            border-radius: 10px;
            background: rgba(255,255,255,0.08);
            border: 1px solid rgba(255,255,255,0.16);
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 6px;
        }

        .meet-hero-screen-dot {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background: rgba(255,255,255,0.35);
        }

        .meet-hero-bubble {
            position: absolute;
            right: 8px;
            top: 0;
            width: 34px;
            height: 34px;
            border-radius: 10px;
            background: rgba(255,255,255,0.9);
            color: var(--meet-blue);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 0.9rem;
            box-shadow: 0 8px 18px rgba(0,0,0,0.2);
        }

        /* ---------- Layout ---------- */
        .meet-layout {
            display: grid;
            grid-template-columns: minmax(0, 1.65fr) minmax(360px, 0.9fr);
            gap: 1rem;
            align-items: stretch;
            margin-bottom: 1rem;
        }

        .meet-bottom-grid {
            display: grid;
            gap: 1rem;
        }

        .meet-main-column {
            display: grid;
            gap: 1rem;
            min-width: 0;
        }

        .meet-card,
        .meet-details-card {
            background: #ffffff;
            border: 1px solid var(--meet-border);
            border-radius: 20px;
            box-shadow: 0 10px 28px rgba(15,23,42,0.05);
            overflow: hidden;
        }

        .meet-details-card {
            position: sticky;
            top: 100px;
            height: 100%;
            padding-bottom: 0.5rem;
        }

        .meet-card-head {
            min-height: 56px;
            padding: 0.85rem 1.1rem;
            border-bottom: 1px solid var(--meet-border);
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 1rem;
        }

        .meet-card-title {
            display: flex;
            align-items: center;
            gap: 0.55rem;
        }

            .meet-card-title i {
                color: var(--meet-blue);
                font-size: 1rem;
            }

            .meet-card-title h2 {
                margin: 0;
                color: var(--meet-text);
                font-size: 1.02rem;
                font-weight: 700;
                letter-spacing: -0.02em;
            }

        .meet-view-link {
            color: var(--meet-blue);
            font-size: 0.82rem;
            font-weight: 600;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 0.2rem;
        }

            .meet-view-link:hover {
                color: var(--meet-navy);
            }

        /* ---------- Upcoming meetings: list rows exactly like reference ---------- */
        .meet-upcoming-list {
            display: flex;
            flex-direction: column;
        }

        .meet-upcoming-row {
            color: inherit;
            text-decoration: none;
            padding: 0.85rem 1.1rem;
            border-bottom: 1px solid var(--meet-border);
            display: grid;
            grid-template-columns: 62px minmax(160px, 1.3fr) minmax(120px, 0.9fr) minmax(100px, 0.75fr) minmax(140px, 0.95fr) minmax(90px, 0.75fr) auto;
            gap: 1.1rem;
