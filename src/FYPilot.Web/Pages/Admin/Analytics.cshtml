@page
@model FYPilot.Web.Pages.Admin.AnalyticsModel
@{
    ViewData["Title"]    = "Analytics";
    ViewData["Subtitle"] = "Platform usage statistics and performance metrics";
}

<!-- KPI cards -->
<div class="row g-3 mb-4">
    @foreach (var kpi in Model.KPIs)
    {
        <div class="col-6 col-xl-3">
            <div class="stat-card">
                <div class="d-flex align-items-center justify-content-between mb-2">
                    <div class="stat-icon" style="background:@kpi.BgColor"><i class="bi bi-@kpi.Icon" style="color:@kpi.Color"></i></div>
                    <span class="badge @(kpi.Change >= 0 ? "bg-success-subtle text-success" : "bg-danger-subtle text-danger")">
                        @(kpi.Change >= 0 ? "+" : "")@kpi.Change%
                    </span>
                </div>
                <div class="stat-value">@kpi.Value</div>
                <div class="stat-label">@kpi.Label</div>
            </div>
        </div>
    }
</div>

<div class="row g-4">
    <!-- Domain distribution -->
    <div class="col-lg-6">
        <div class="page-card p-4">
            <h6 class="fw-bold mb-3"><i class="bi bi-pie-chart me-2 text-primary"></i>Ideas by Domain</h6>
            @foreach (var (domain, count, pct) in Model.DomainDist)
            {
                <div class="mb-2">
                    <div class="d-flex justify-content-between small mb-1">
                        <span>@domain</span>
                        <span class="text-muted">@count (@pct%)</span>
                    </div>
                    <div class="progress" style="height:8px">
                        <div class="progress-bar" style="width:@pct%;background:#3b82f6"></div>
                    </div>
                </div>
            }
        </div>
    </div>

    <!-- Difficulty dist -->
    <div class="col-lg-6">
        <div class="page-card p-4">
            <h6 class="fw-bold mb-3"><i class="bi bi-bar-chart-steps me-2 text-warning"></i>Difficulty Distribution</h6>
            @foreach (var (level, count, color) in Model.DifficultyDist)
            {
                <div class="mb-3 p-3 rounded-2" style="background:@(color)25;border:1px solid @(color)60">
                    <div class="d-flex justify-content-between align-items-center">
                        <span class="fw-semibold text-capitalize small">@level</span>
                        <span class="fw-bold" style="color:@color;font-size:1.5rem">@count</span>
                    </div>
                    <div class="text-muted-sm">ideas at this difficulty level</div>
                </div>
            }
        </div>
    </div>

    <!-- Top metrics -->
    <div class="col-12">
        <div class="page-card p-4">
            <h6 class="fw-bold mb-3"><i class="bi bi-trophy me-2 text-warning"></i>Top Performing Ideas</h6>
            <div class="table-responsive">
                <table class="table table-hover align-middle small">
                    <thead><tr><th>Title</th><th>Student</th><th>Domain</th><th>Innovation</th><th>Feasibility</th><th>Market</th><th>Avg Score</th></tr></thead>
                    <tbody>
                        @foreach (var idea in Model.TopIdeas)
                        {
                            <tr>
                                <td class="fw-semibold" style="max-width:200px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">@idea.Title</td>
                                <td class="text-muted">@idea.StudentName</td>
                                <td><span class="badge bg-primary-subtle text-primary">@idea.Domain</span></td>
                                <td>@idea.InnovationScore%</td>
                                <td>@idea.FeasibilityScore%</td>
                                <td>@idea.MarketDemandScore%</td>
                                <td><span class="badge bg-success">@((idea.InnovationScore + idea.FeasibilityScore + idea.MarketDemandScore) / 3)%</span></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
