@page
@using System
@using System.Linq
@model FYPilot.Web.Pages.Student.ProjectDetailsModel
@{
    ViewData["Title"] = "Project Details";
    ViewData["Subtitle"] = "Selected project idea details from the database";
}

<div class="pd-page">

    @if (!string.IsNullOrWhiteSpace(Model.SuccessMessage))
    {
        <div class="alert alert-success pd-alert">
            <i class="bi bi-check-circle me-2"></i>
            @Model.SuccessMessage
        </div>
    }

    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="alert alert-danger pd-alert">
            <i class="bi bi-exclamation-triangle me-2"></i>
            @Model.ErrorMessage
        </div>
    }

    @if (Model.Idea == null)
    {
        <section class="pd-empty">
            <div class="pd-empty-icon">
                <i class="bi bi-folder2-open"></i>
            </div>

            <h1>No Project Idea Selected</h1>

            <p>
                Select one generated idea to view its real project details from the database.
            </p>

            <div class="pd-empty-actions">
                <a href="/Student/IdeaComparison" class="btn pd-primary-btn">
                    <i class="bi bi-check2-circle me-1"></i>
                    Choose an Idea
                </a>

                <a href="/Student/IdeaGenerator" class="btn pd-light-btn">
                    <i class="bi bi-stars me-1"></i>
                    Generate Ideas
                </a>
            </div>
        </section>
    }
    else
    {
        var idea = Model.Idea;

        var technologies = SplitItems(idea.RequiredTechnologies);
        var requiredSkills = SplitItems(idea.RequiredSkills);

        var studentSkillKeys = Model.StudentSkillNames
            .Select(NormalizeSkill)
            .ToHashSet(StringComparer.OrdinalIgnoreCase);

        var missingSkills = SplitItems(idea.MissingSkills)
            .Where(skill => !studentSkillKeys.Contains(NormalizeSkill(skill)))
            .ToList();

        var hasDomain = HasText(idea.Domain);
        var hasDifficulty = HasText(idea.DifficultyLevel);
        var hasDuration = idea.ExpectedDurationWeeks > 0;
        var hasSector = HasText(idea.LebanesesSector);
        var hasProblem = HasText(idea.ProblemStatement);
        var hasUsers = HasText(idea.TargetUsers);
        var hasUsefulness = HasText(idea.WhyUseful);
        var hasLebaneseRelevance = HasText(idea.LebaneseMarketRelevance);
        var hasDataset = HasUsefulDataset(idea.DatasetNeeded);
        var hasSupervisorCategory = HasText(idea.SupervisorCategory);

        var innovation = ClampScore(idea.InnovationScore);
        var feasibility = ClampScore(idea.FeasibilityScore);
        var market = ClampScore(idea.MarketDemandScore);

        var hasInnovation = idea.InnovationScore > 0;
        var hasFeasibility = idea.FeasibilityScore > 0;
        var hasMarket = idea.MarketDemandScore > 0;
        var hasAnyScore = hasInnovation || hasFeasibility || hasMarket;

        var scoreCount = 0;
        var scoreTotal = 0;

        if (hasInnovation)
        {
            scoreCount++;
            scoreTotal += innovation;
        }

        if (hasFeasibility)
        {
            scoreCount++;
            scoreTotal += feasibility;
        }

        if (hasMarket)
        {
            scoreCount++;
            scoreTotal += market;
        }

        var overall = scoreCount > 0 ? ClampScore(scoreTotal / scoreCount) : 0;

        var hasOverview = hasProblem || hasUsers || hasUsefulness || hasLebaneseRelevance;
        var hasTechnicalScope = technologies.Any() || requiredSkills.Any() || missingSkills.Any() || hasDataset;
        var hasMeta = hasDomain || hasDifficulty || hasDuration || hasSector || hasSupervisorCategory;

        <section class="pd-hero">
            <div class="pd-hero-main">
                <div class="pd-eyebrow">
                    <span>
                        <i class="bi bi-folder-check"></i>
                        Project Details
                    </span>

                    @if (idea.IsSelected)
                    {
                        <span class="pd-selected-badge">
                            <i class="bi bi-check-circle-fill"></i>
                            Selected Idea
                        </span>
                    }
                    else
                    {
                        <span class="pd-draft-badge">
                            <i class="bi bi-circle"></i>
                            Draft Idea
                        </span>
                    }
                </div>

                <h1>@idea.Title</h1>

                @if (hasMeta)
                {
                    <div class="pd-meta">
                        @if (hasDomain)
                        {
                            <span><i class="bi bi-grid"></i>@idea.Domain</span>
                        }

                        @if (hasDifficulty)
                        {
                            <span class="text-capitalize"><i class="bi bi-speedometer2"></i>@idea.DifficultyLevel</span>
                        }

                        @if (hasDuration)
                        {
                            <span><i class="bi bi-calendar-week"></i>@idea.ExpectedDurationWeeks weeks</span>
                        }

                        @if (hasSector)
                        {
                            <span><i class="bi bi-geo-alt"></i>@idea.LebanesesSector</span>
                        }

                        @if (hasSupervisorCategory)
                        {
                            <span><i class="bi bi-person-workspace"></i>@idea.SupervisorCategory</span>
                        }
                    </div>
                }
            </div>

            @if (hasAnyScore)
            {
                <aside class="pd-overall-card">
                    <span>Overall Project Fit</span>
                    <strong>@overall%</strong>
                    <div class="pd-score-bar">
                        <b style="width:@overall%"></b>
                    </div>
                    <small>@ScoreLabel(overall)</small>
                </aside>
            }
        </section>

        <section class="pd-layout">

            <main class="pd-main">

                @if (hasOverview)
                {
                    <section class="pd-card">
                        <div class="pd-card-head">
                            <div>
                                <span>Overview</span>
                                <h2>Project Idea Summary</h2>
                            </div>
                        </div>

                        <div class="pd-overview-grid">
                            @if (hasProblem)
                            {
                                <article class="pd-info-block wide">
                                    <div class="pd-info-icon"><i class="bi bi-bullseye"></i></div>
                                    <div>
                                        <h3>Problem Statement</h3>
                                        <p>@idea.ProblemStatement</p>
                                    </div>
                                </article>
                            }

                            @if (hasUsers)
                            {
                                <article class="pd-info-block">
                                    <div class="pd-info-icon"><i class="bi bi-people"></i></div>
                                    <div>
                                        <h3>Target Users</h3>
                                        <p>@idea.TargetUsers</p>
                                    </div>
                                </article>
                            }

                            @if (hasUsefulness)
                            {
                                <article class="pd-info-block">
                                    <div class="pd-info-icon"><i class="bi bi-lightbulb"></i></div>
                                    <div>
                                        <h3>Usefulness</h3>
                                        <p>@idea.WhyUseful</p>
                                    </div>
                                </article>
                            }

                            @if (hasLebaneseRelevance)
                            {
                                <article class="pd-info-block wide">
                                    <div class="pd-info-icon"><i class="bi bi-shop"></i></div>
                                    <div>
                                        <h3>Lebanese Market Relevance</h3>
                                        <p>@idea.LebaneseMarketRelevance</p>
                                    </div>
                                </article>
                            }
                        </div>
                    </section>
                }

                @if (hasTechnicalScope)
                {
                    <section class="pd-card">
                        <div class="pd-card-head">
                            <div>
                                <span>Technical Scope</span>
                                <h2>Implementation Requirements</h2>
                            </div>
                        </div>

                        <div class="pd-tech-grid">
                            @if (technologies.Any())
                            {
                                <article>
                                    <h3><i class="bi bi-code-slash"></i> Required Technologies</h3>

                                    <div class="pd-chip-cloud">
                                        @foreach (var tech in technologies)
                                        {
                                            <span>@tech</span>
                                        }
                                    </div>
                                </article>
                            }

                            @if (requiredSkills.Any())
                            {
                                <article>
                                    <h3><i class="bi bi-person-check"></i> Required Skills</h3>

                                    <div class="pd-list">
                                        @foreach (var skill in requiredSkills)
                                        {
                                            <div><i class="bi bi-check2"></i><span>@skill</span></div>
                                        }
                                    </div>
                                </article>
                            }

                            @if (missingSkills.Any())
                            {
                                <article>
                                    <h3><i class="bi bi-exclamation-circle"></i> Missing Skills</h3>

                                    <div class="pd-chip-cloud warning">
                                        @foreach (var skill in missingSkills)
                                        {
                                            <span>@skill</span>
                                        }
                                    </div>
                                </article>
                            }

                            @if (hasDataset)
                            {
                                <article>
                                    <h3><i class="bi bi-database"></i> Dataset Requirement</h3>
                                    <p class="pd-soft-text">@idea.DatasetNeeded</p>
                                </article>
                            }
                        </div>
                    </section>
                }
            </main>

            <aside class="pd-sidebar">

                <section class="pd-side-card pd-actions-card">
                    <div class="pd-side-head">
                        <span>Actions</span>
                        <h2>Continue From This Idea</h2>
                    </div>

                    @if (!idea.IsSelected)
                    {
                        <form method="post" asp-page-handler="Select" class="pd-select-form">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="ideaId" value="@idea.Id" />

                            <button type="submit" class="btn pd-primary-btn w-100">
                                <i class="bi bi-check2-circle me-1"></i>
                                Select This Idea
                            </button>
                        </form>
                    }

                    <div class="pd-action-list">
                        <a href="/Student/IdeaComparison">
                            <i class="bi bi-columns-gap"></i>
                            <span>Compare Ideas</span>
                        </a>

                        @if (idea.IsSelected)
                        {
                            <a href="/Student/ProjectDNA?ideaId=@idea.Id">
                                <i class="bi bi-fingerprint"></i>
                                <span>Project DNA</span>
                            </a>

                            <a href="/Student/Roadmap?ideaId=@idea.Id">
                                <i class="bi bi-map"></i>
                                <span>Roadmap</span>
                            </a>

                            <a href="/Student/MentorChat?ideaId=@idea.Id">
                                <i class="bi bi-chat-dots"></i>
                                <span>Mentor Chat</span>
                            </a>

                            <a href="/Student/Feedback">
                                <i class="bi bi-chat-square-text"></i>
                                <span>Supervisor Feedback</span>
                            </a>
                        }
                    </div>
                </section>

                @if (hasAnyScore)
                {
                    <section class="pd-side-card">
                        <div class="pd-side-head">
                            <span>Scores</span>
                            <h2>Evaluation Snapshot</h2>
                        </div>

                        <div class="pd-score-list">
                            @if (hasInnovation)
                            {
                                <div>
                                    <label>Innovation</label>
                                    <strong>@innovation%</strong>
                                    <span><b style="width:@innovation%"></b></span>
                                </div>
                            }

                            @if (hasFeasibility)
                            {
                                <div>
                                    <label>Feasibility</label>
                                    <strong>@feasibility%</strong>
                                    <span><b style="width:@feasibility%"></b></span>
                                </div>
                            }

                            @if (hasMarket)
                            {
                                <div>
                                    <label>Market Demand</label>
                                    <strong>@market%</strong>
                                    <span><b style="width:@market%"></b></span>
                                </div>
                            }
                        </div>
                    </section>
                }
            </aside>
        </section>
    }
</div>

@section Head {
