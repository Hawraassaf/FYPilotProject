@page
@model FYPilot.Web.Pages.Admin.AdminAccountsModel
@{
    ViewData["Title"] = "Manage Administrators";
    ViewData["Subtitle"] = "Create and review privileged administrator accounts.";
}

<section class="admin-accounts-page">
    @if (!string.IsNullOrWhiteSpace(Model.SuccessMessage))
    {
        <div class="alert alert-success admin-alert" role="alert">
            <i class="bi bi-check-circle-fill"></i>
            <span>@Model.SuccessMessage</span>
        </div>
    }

    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="alert alert-danger admin-alert" role="alert">
            <i class="bi bi-exclamation-triangle-fill"></i>
            <span>@Model.ErrorMessage</span>
        </div>
    }

    <header class="admin-accounts-hero">
        <div>
            <span class="admin-eyebrow">Main administrator control</span>
            <h1>Administrator Accounts</h1>
            <p>
                Create secure administrator accounts without changing PostgreSQL manually.
                Every administrator receives a separate identity and the same operational admin role.
            </p>
        </div>

        <div class="admin-hero-stats">
            <div>
                <span>Total administrators</span>
                <strong>@Model.Admins.Count</strong>
            </div>
            <div>
                <span>Next account</span>
                <strong class="next-email">@Model.NextAdminEmail</strong>
            </div>
        </div>
    </header>

    <div class="admin-accounts-grid">
        <article class="admin-create-card">
            <div class="card-heading">
                <div class="heading-icon">
                    <i class="bi bi-person-plus-fill"></i>
                </div>
                <div>
                    <span>Create account</span>
                    <h2>New Administrator</h2>
                </div>
            </div>

            <form method="post"
                  asp-page-handler="Create"
                  id="createAdminForm"
                  class="admin-create-form">
                @Html.AntiForgeryToken()

                <div asp-validation-summary="ModelOnly"
                     class="text-danger validation-summary"></div>

                <div class="form-field">
                    <label>Generated email</label>
                    <div class="readonly-email">
                        <i class="bi bi-envelope"></i>
                        <input value="@Model.NextAdminEmail"
                               readonly
                               aria-label="Generated administrator email" />
                    </div>
                    <small>The system generates the next available admin number automatically.</small>
                </div>

                <div class="form-field">
                    <label asp-for="Input.FullName">Display name</label>
                    <input asp-for="Input.FullName"
                           class="form-control"
                           autocomplete="name" />
                    <span asp-validation-for="Input.FullName"
                          class="text-danger"></span>
                </div>

                <div class="form-field">
                    <label asp-for="Input.Password">Temporary password</label>
                    <div class="password-wrap">
                        <input asp-for="Input.Password"
                               class="form-control"
                               autocomplete="new-password" />
                        <button type="button"
                                class="password-toggle"
                                data-target="Input_Password"
                                aria-label="Show or hide password">
                            <i class="bi bi-eye"></i>
                        </button>
                    </div>
                    <span asp-validation-for="Input.Password"
                          class="text-danger"></span>
                    <small>At least 8 characters with uppercase, lowercase, and a number.</small>
                </div>

                <div class="form-field">
                    <label asp-for="Input.ConfirmPassword">Confirm password</label>
                    <div class="password-wrap">
                        <input asp-for="Input.ConfirmPassword"
                               class="form-control"
                               autocomplete="new-password" />
                        <button type="button"
                                class="password-toggle"
                                data-target="Input_ConfirmPassword"
                                aria-label="Show or hide password confirmation">
                            <i class="bi bi-eye"></i>
                        </button>
                    </div>
                    <span asp-validation-for="Input.ConfirmPassword"
                          class="text-danger"></span>
                </div>

                <div class="security-note">
                    <i class="bi bi-shield-lock-fill"></i>
                    <p>
                        The password is hashed before storage. It cannot be displayed later,
                        so share it securely with the new administrator.
                    </p>
                </div>

                <button type="submit"
                        class="create-admin-button"
                        id="createAdminButton">
                    <i class="bi bi-person-plus"></i>
                    <span>Create Administrator</span>
                </button>
            </form>
        </article>

        <article class="admin-directory-card">
            <div class="directory-heading">
                <div>
                    <span class="admin-eyebrow">Account directory</span>
                    <h2>Current Administrators</h2>
                </div>

                <label class="admin-search">
                    <i class="bi bi-search"></i>
                    <input type="search"
                           id="adminSearch"
                           placeholder="Search name or email..."
                           autocomplete="off" />
                </label>
            </div>

            <div class="admin-list" id="adminList">
                @foreach (var admin in Model.Admins)
                {
                    var searchText = $"{admin.FullName} {admin.Email}".ToLowerInvariant();

                    <div class="admin-row" data-search="@searchText">
                        <div class="admin-avatar">
                            @Initials(admin.FullName)
                        </div>

                        <div class="admin-identity">
                            <div class="admin-name-line">
                                <strong>@admin.FullName</strong>

                                @if (admin.IsMainAdmin)
                                {
                                    <span class="main-admin-badge">
                                        <i class="bi bi-star-fill"></i>
                                        Main Admin
                                    </span>
                                }
                                else
                                {
                                    <span class="regular-admin-badge">Administrator</span>
                                }
                            </div>

                            <span>@admin.Email</span>
                            <small>
                                Created @admin.CreatedAt.ToLocalTime().ToString("MMM d, yyyy • hh:mm tt")
                            </small>
                        </div>

                        <div class="admin-status">
                            <i class="bi bi-check-circle-fill"></i>
                            Active
                        </div>
                    </div>
                }

                <div class="admin-empty" id="adminSearchEmpty">
                    <i class="bi bi-search"></i>
                    <p>No administrator matches your search.</p>
                </div>
            </div>

            <footer class="directory-footer">
                <i class="bi bi-info-circle"></i>
                <span>
                    The list stays inside a fixed-height scroll area, even when many accounts are created.
                </span>
            </footer>
        </article>
    </div>
</section>

@section Head {
    <style>
        :root {
            --admin-navy: #28385E;
            --admin-deep: #071D49;
            --admin-steel: #516C8D;
            --admin-border: #E5EAF1;
            --admin-muted: #64748B;
            --admin-soft: #F4F6F9;
            --admin-green: #047857;
        }

        .admin-accounts-page {
            max-width: 1450px;
            margin: 0 auto;
            padding-bottom: 1.5rem;
            color: #111827;
        }

        .admin-alert {
            display: flex;
            align-items: center;
            gap: .6rem;
            border: 0;
            border-radius: 16px;
            box-shadow: 0 12px 28px rgba(15, 23, 42, .08);
        }

        .admin-accounts-hero {
            display: grid;
            grid-template-columns: minmax(0, 1fr) minmax(330px, 430px);
            gap: 1.25rem;
            align-items: center;
            padding: 1.5rem;
            margin-bottom: 1rem;
            border-radius: 26px;
            color: #fff;
            background: radial-gradient(circle at 88% 18%, rgba(255,255,255,.14), transparent 24%), linear-gradient(135deg, var(--admin-deep), var(--admin-navy) 58%, var(--admin-steel));
            box-shadow: 0 22px 48px rgba(40, 56, 94, .16);
        }

        .admin-eyebrow {
            display: block;
            margin-bottom: .25rem;
            color: var(--admin-steel);
            font-size: .68rem;
            font-weight: 750;
            letter-spacing: .11em;
            text-transform: uppercase;
        }

        .admin-accounts-hero .admin-eyebrow {
            color: rgba(255,255,255,.7);
        }

        .admin-accounts-hero h1 {
            margin: 0;
            font-size: clamp(1.65rem, 3vw, 2.45rem);
            font-weight: 700;
            letter-spacing: -.04em;
        }

        .admin-accounts-hero p {
            max-width: 780px;
            margin: .55rem 0 0;
            color: rgba(255,255,255,.76);
            line-height: 1.65;
            font-size: .9rem;
        }

        .admin-hero-stats {
            display: grid;
            grid-template-columns: .75fr 1.25fr;
            gap: .7rem;
        }

            .admin-hero-stats > div {
                min-height: 88px;
                display: grid;
                align-content: center;
                padding: .85rem;
                border-radius: 18px;
                border: 1px solid rgba(255,255,255,.16);
                background: rgba(255,255,255,.11);
            }

            .admin-hero-stats span {
                color: rgba(255,255,255,.72);
                font-size: .7rem;
            }

            .admin-hero-stats strong {
                margin-top: .22rem;
                color: #fff;
                font-size: 1.45rem;
            }

            .admin-hero-stats .next-email {
                font-size: .94rem;
                overflow-wrap: anywhere;
            }

        .admin-accounts-grid {
            display: grid;
            grid-template-columns: minmax(330px, .72fr) minmax(0, 1.28fr);
            gap: 1rem;
            align-items: stretch;
        }

        .admin-create-card,
        .admin-directory-card {
            background: #fff;
            border: 1px solid var(--admin-border);
            border-radius: 24px;
            box-shadow: 0 14px 34px rgba(15,23,42,.05);
            overflow: hidden;
        }

        .card-heading,
        .directory-heading {
            min-height: 76px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 1rem;
            padding: 1rem 1.15rem;
            border-bottom: 1px solid var(--admin-border);
        }

        .card-heading {
            justify-content: flex-start;
        }

        .heading-icon {
            width: 44px;
            height: 44px;
            border-radius: 15px;
            display: grid;
            place-items: center;
            color: #fff;
            background: var(--admin-navy);
        }

        .card-heading span {
            display: block;
            color: var(--admin-muted);
            font-size: .68rem;
            text-transform: uppercase;
            letter-spacing: .08em;
            font-weight: 700;
        }

        .card-heading h2,
        .directory-heading h2 {
            margin: .1rem 0 0;
            font-size: 1.05rem;
            font-weight: 750;
        }

        .admin-create-form {
            padding: 1.1rem 1.15rem 1.2rem;
            display: grid;
            gap: .9rem;
        }

        .validation-summary:empty {
            display: none;
        }

        .form-field label {
            display: block;
            margin-bottom: .32rem;
            color: #334155;
            font-size: .76rem;
            font-weight: 700;
        }

        .form-field small {
            display: block;
            margin-top: .28rem;
            color: var(--admin-muted);
            font-size: .68rem;
            line-height: 1.45;
        }

        .form-field .form-control,
        .readonly-email input {
            min-height: 44px;
            border-radius: 12px;
            border-color: #DCE3ED;
            font-size: .84rem;
        }

            .form-field .form-control:focus {
                border-color: var(--admin-steel);
                box-shadow: 0 0 0 .2rem rgba(81,108,141,.14);
            }

        .readonly-email {
            display: grid;
            grid-template-columns: auto minmax(0, 1fr);
            align-items: center;
            gap: .55rem;
            min-height: 44px;
            padding: 0 .75rem;
            border: 1px solid #DCE3ED;
            border-radius: 12px;
            background: var(--admin-soft);
        }

            .readonly-email i {
                color: var(--admin-steel);
            }

            .readonly-email input {
                width: 100%;
                min-height: 42px;
                padding: 0;
                border: 0;
                outline: 0;
                color: var(--admin-navy);
                background: transparent;
                font-weight: 700;
            }

        .password-wrap {
            position: relative;
        }

            .password-wrap .form-control {
                padding-right: 2.8rem;
            }

        .password-toggle {
            position: absolute;
            right: .45rem;
            top: 50%;
            width: 34px;
            height: 34px;
            transform: translateY(-50%);
            border: 0;
            border-radius: 9px;
            color: var(--admin-steel);
            background: transparent;
        }

        .security-note {
            display: grid;
            grid-template-columns: auto minmax(0, 1fr);
            gap: .6rem;
            padding: .75rem;
            border: 1px solid #DCE5F2;
            border-radius: 14px;
            background: #F7F9FC;
        }

            .security-note i {
                color: var(--admin-navy);
            }

            .security-note p {
                margin: 0;
                color: var(--admin-muted);
                font-size: .72rem;
                line-height: 1.55;
            }

        .create-admin-button {
            min-height: 45px;
            border: 0;
            border-radius: 13px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: .5rem;
            color: #fff;
            background: var(--admin-navy);
            font-size: .82rem;
            font-weight: 750;
            transition: .15s ease;
        }

            .create-admin-button:hover:not(:disabled) {
                background: #344A76;
                transform: translateY(-1px);
            }

            .create-admin-button:disabled {
                opacity: .7;
                cursor: wait;
            }

        .admin-search {
            width: min(300px, 100%);
            min-height: 40px;
            display: grid;
            grid-template-columns: auto minmax(0, 1fr);
            align-items: center;
            gap: .45rem;
            padding: 0 .7rem;
            border: 1px solid #DCE3ED;
            border-radius: 12px;
            background: #F8FAFC;
        }

            .admin-search i {
                color: var(--admin-muted);
            }

            .admin-search input {
                width: 100%;
                border: 0;
                outline: 0;
                background: transparent;
                font-size: .78rem;
            }

        .admin-list {
            height: 455px;
            overflow-y: auto;
            overscroll-behavior: contain;
            scrollbar-width: thin;
        }

        .admin-row {
            display: grid;
            grid-template-columns: auto minmax(0, 1fr) auto;
            gap: .75rem;
            align-items: center;
            padding: .9rem 1.1rem;
            border-bottom: 1px solid #EDF1F5;
        }

            .admin-row:last-of-type {
                border-bottom: 0;
            }

        .admin-avatar {
            width: 42px;
            height: 42px;
            border-radius: 14px;
            display: grid;
            place-items: center;
            color: #fff;
            background: linear-gradient(135deg, var(--admin-navy), var(--admin-steel));
            font-size: .74rem;
            font-weight: 800;
        }

        .admin-identity {
            min-width: 0;
        }

        .admin-name-line {
            display: flex;
            align-items: center;
            gap: .45rem;
            flex-wrap: wrap;
        }

            .admin-name-line strong {
                font-size: .87rem;
            }

        .admin-identity > span {
            display: block;
            margin-top: .1rem;
            color: #475569;
            font-size: .76rem;
            overflow-wrap: anywhere;
        }

        .admin-identity small {
            display: block;
            margin-top: .12rem;
            color: #94A3B8;
            font-size: .67rem;
        }

        .main-admin-badge,
        .regular-admin-badge {
            display: inline-flex;
            align-items: center;
            gap: .25rem;
            padding: .24rem .45rem;
            border-radius: 999px;
            font-size: .61rem;
            font-weight: 800;
        }

        .main-admin-badge {
            color: #854D0E;
            background: #FEF3C7;
        }

        .regular-admin-badge {
            color: var(--admin-navy);
            background: #E9EEF6;
        }

        .admin-status {
            display: inline-flex;
            align-items: center;
            gap: .3rem;
            color: var(--admin-green);
            font-size: .7rem;
            font-weight: 750;
            white-space: nowrap;
        }

        .admin-empty {
            min-height: 220px;
            display: none;
            place-items: center;
            align-content: center;
            text-align: center;
            color: var(--admin-muted);
        }

            .admin-empty i {
                font-size: 1.4rem;
            }

            .admin-empty p {
                margin: .45rem 0 0;
                font-size: .8rem;
            }

        .directory-footer {
            min-height: 54px;
            display: flex;
            align-items: center;
            gap: .5rem;
            padding: .75rem 1rem;
            border-top: 1px solid var(--admin-border);
            color: var(--admin-muted);
            background: #FAFBFC;
            font-size: .7rem;
        }

        @@media (max-width: 1050px) {
            .admin-accounts-hero,
            .admin-accounts-grid {
                grid-template-columns: 1fr;
            }

            .admin-list {
                height: 390px;
            }
        }

        @@media (max-width: 650px) {
            .admin-accounts-hero {
                padding: 1.1rem;
            }

            .admin-hero-stats {
                grid-template-columns: 1fr;
            }

            .directory-heading {
                align-items: flex-start;
                flex-direction: column;
            }

            .admin-search {
                width: 100%;
            }

            .admin-row {
                grid-template-columns: auto minmax(0, 1fr);
            }

            .admin-status {
                grid-column: 2;
            }
        }
    </style>
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        document.querySelectorAll(".password-toggle").forEach(function (button) {
            button.addEventListener("click", function () {
                const input = document.getElementById(button.dataset.target);
                const icon = button.querySelector("i");

                if (!input) return;

                const show = input.type === "password";
                input.type = show ? "text" : "password";

                if (icon) {
                    icon.className = show ? "bi bi-eye-slash" : "bi bi-eye";
                }
            });
        });

        const searchInput = document.getElementById("adminSearch");
        const rows = Array.from(document.querySelectorAll(".admin-row"));
        const emptyState = document.getElementById("adminSearchEmpty");

        searchInput?.addEventListener("input", function () {
            const value = searchInput.value.trim().toLowerCase();
            let visibleCount = 0;

            rows.forEach(function (row) {
                const matches = !value || (row.dataset.search || "").includes(value);
                row.style.display = matches ? "grid" : "none";

                if (matches) visibleCount++;
            });

            if (emptyState) {
                emptyState.style.display = visibleCount === 0 ? "grid" : "none";
            }
        });

        const form = document.getElementById("createAdminForm");
        const submitButton = document.getElementById("createAdminButton");

        form?.addEventListener("submit", function () {
            if (!form.checkValidity() || !submitButton) return;

            submitButton.disabled = true;
            submitButton.innerHTML =
                '<span class="spinner-border spinner-border-sm"></span>' +
                '<span>Creating...</span>';
        });
    </script>
}

@functions {
    private static string Initials(string? fullName)
    {
        if (string.IsNullOrWhiteSpace(fullName))
        {
            return "AD";
        }

        var parts = fullName
            .Split(' ', StringSplitOptions.RemoveEmptyEntries)
            .Take(2)
            .ToList();

        return parts.Count == 0
            ? "AD"
            : string.Join("", parts.Select(p => p[0])).ToUpperInvariant();
    }
}
