@page
@model FYPilot.Web.Pages.Student.ProjectDetailsModel
@{
    ViewData["Title"]    = "My Project";
    ViewData["Subtitle"] = "Full details of your selected project idea";
}

@if (Model.Idea == null)
{
    <div class="page-card p-5 text-center">
        <i class="bi bi-folder2-open display-3 text-muted"></i>
        <h5 class="mt-3">No Project Selected</h5>
        <p class="text-muted">Generate and select a project idea to view its details here.</p>
        <a href="/Student/IdeaGenerator" class="btn btn-primary"><i class="bi bi-stars me-2"></i>Generate Ideas</a>
    </div>
}
else
{
    var idea = Model.Idea;
    <div class="row g-4">
        <div class="col-lg-8">
            <div class="page-card p-4 mb-3">
                <div class="d-flex align-items-start justify-content-between mb-3">
                    <div>
                        <h5 class="fw-bold mb-1">@idea.Title</h5>
                        <div class="d-flex flex-wrap gap-1">
                            <span class="badge bg-primary-subtle text-primary">@idea.Domain</span>
                            <span class="badge bg-warning-subtle text-warning text-capitalize">@idea.DifficultyLevel</span>
                            <span class="badge bg-success-subtle text-success"><i class="bi bi-check-circle me-1"></i>Selected Project</span>
                        </div>
                    </div>
                    <div class="text-end">
                        <div class="score-ring text-success" style="width:64px;height:64px;font-size:1rem">@idea.FeasibilityScore%</div>
                        <div class="small text-muted mt-1">Feasibility</div>
                    </div>
                </div>
                <h6 class="small fw-bold text-muted mb-1">Problem Statement</h6>
                <p class="text-muted small">@idea.ProblemStatement</p>
                <h6 class="small fw-bold text-muted mb-1">Why It's Useful</h6>
                <p class="text-muted small">@idea.WhyUseful</p>
                @if (!string.IsNullOrEmpty(idea.LebaneseMarketRelevance))
                {
                    <h6 class="small fw-bold text-muted mb-1">Market Relevance</h6>
                    <p class="text-muted small">@idea.LebaneseMarketRelevance</p>
                }
            </div>

            <div class="page-card p-4">
                <h6 class="fw-bold mb-3">Project Details</h6>
                <div class="row g-3">
                    @foreach (var (label, val) in new[] {
                        ("Target Users",       idea.TargetUsers),
                        ("Required Skills",    idea.RequiredSkills),
                        ("Technologies",       idea.RequiredTechnologies),
                        ("Missing Skills",     string.IsNullOrEmpty(idea.MissingSkills) ? "None" : idea.MissingSkills),
                        ("Dataset Needed",     string.IsNullOrEmpty(idea.DatasetNeeded) ? "None" : idea.DatasetNeeded),
                        ("Final Deliverables", idea.FinalDeliverables),
                    })
                    {
                        <div class="col-sm-6">
                            <div class="small fw-semibold text-muted mb-1">@label</div>
                            <div class="small">@val</div>
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="page-card p-4 mb-3">
                <h6 class="fw-bold mb-3">Scores</h6>
                @foreach (var (label, val, color) in new[] {
                    ("Innovation",   idea.InnovationScore,   "#3b82f6"),
                    ("Feasibility",  idea.FeasibilityScore,  "#10b981"),
                    ("Market",       idea.MarketDemandScore, "#f59e0b"),
                })
                {
                    <div class="mb-2">
                        <div class="d-flex justify-content-between small mb-1">
                            <span>@label</span><span class="fw-semibold" style="color:@color">@val%</span>
                        </div>
                        <div class="progress" style="height:6px">
                            <div class="progress-bar" style="width:@val%;background:@color"></div>
                        </div>
                    </div>
                }
                <div class="mt-3 pt-3 border-top small text-muted">
                    <i class="bi bi-clock me-1"></i>Est. @idea.ExpectedDurationWeeks weeks
                </div>
            </div>

            <div class="page-card p-4">
                <h6 class="fw-bold mb-3">Quick Actions</h6>
                <div class="d-grid gap-2">
                    <a href="/Student/ProjectDNA?ideaId=@idea.Id"      class="btn btn-outline-primary btn-sm"><i class="bi bi-diagram-3 me-1"></i>DNA Analysis</a>
                    <a href="/Student/Roadmap?ideaId=@idea.Id"         class="btn btn-outline-success btn-sm"><i class="bi bi-map me-1"></i>View Roadmap</a>
                    <a href="/Student/ScopeOptimizer?ideaId=@idea.Id"  class="btn btn-outline-warning btn-sm"><i class="bi bi-funnel me-1"></i>Scope Optimizer</a>
                    <a href="/Student/DefenseSimulator?ideaId=@idea.Id" class="btn btn-outline-danger btn-sm"><i class="bi bi-shield-check me-1"></i>Defense Prep</a>
                    <a href="/Student/MentorChat?ideaId=@idea.Id"      class="btn btn-outline-secondary btn-sm"><i class="bi bi-chat-dots me-1"></i>Mentor Chat</a>
                </div>
            </div>
        </div>
    </div>
}
