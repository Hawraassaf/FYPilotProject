@page
@model FYPilot.Web.Pages.Student.DocumentationGeneratorModel
@{
    ViewData["Title"] = "Smart Project Specification Generator";
}

@section Head {
    <style>
        .spec-hero {
            background: linear-gradient(135deg, #0f172a, #1e3a8a);
            border-radius: 24px;
            color: white;
            padding: 28px;
            box-shadow: 0 20px 45px rgba(15, 23, 42, 0.18);
        }

        .spec-hero-badge {
            background: rgba(255, 255, 255, 0.15);
            border: 1px solid rgba(255, 255, 255, 0.25);
            color: white;
            border-radius: 999px;
            padding: 6px 14px;
            font-size: 0.8rem;
        }

        .glass-card {
            border: 0;
            border-radius: 22px;
            box-shadow: 0 12px 35px rgba(15, 23, 42, 0.08);
            overflow: hidden;
        }

        .section-card {
            border: 1px solid #e5e7eb;
            border-radius: 18px;
            background: #ffffff;
            margin-bottom: 18px;
            overflow: hidden;
        }

        .section-title {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 16px 18px;
            background: #f8fafc;
            border-bottom: 1px solid #e5e7eb;
            font-weight: 700;
        }

        .section-icon {
            width: 34px;
            height: 34px;
            border-radius: 10px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            background: #dbeafe;
            color: #1d4ed8;
        }

        .requirement-item {
            padding: 14px 16px;
            border-bottom: 1px solid #eef2f7;
            line-height: 1.65;
        }

            .requirement-item:last-child {
                border-bottom: 0;
            }

        .report-toolbar {
            position: sticky;
            top: 0;
            z-index: 5;
            background: white;
            border-bottom: 1px solid #e5e7eb;
            padding: 14px 18px;
        }

        .mini-stat {
            border-radius: 18px;
            background: #f8fafc;
            border: 1px solid #e5e7eb;
            padding: 16px;
            height: 100%;
        }

            .mini-stat .number {
                font-size: 1.35rem;
                font-weight: 800;
                color: #0f172a;
            }

            .mini-stat .label {
                color: #64748b;
                font-size: 0.85rem;
            }

        .code-block {
            white-space: pre-wrap;
            background: #0f172a;
            color: #e2e8f0;
            border-radius: 18px;
            padding: 18px;
            font-size: 0.9rem;
            line-height: 1.7;
        }

        .empty-state {
            min-height: 520px;
            border-radius: 22px;
            background: linear-gradient(180deg, #ffffff, #f8fafc);
            border: 1px dashed #cbd5e1;
        }

        @@media print {
            body * {
                visibility: hidden;
            }

            #se-report, #se-report * {
                visibility: visible;
            }

            #se-report {
                position: absolute;
                left: 0;
                top: 0;
                width: 100%;
                background: white;
                padding: 30px;
            }

            .no-print {
                display: none !important;
            }

            .card, .section-card {
                border: none !important;
                box-shadow: none !important;
            }

            .code-block {
                background: white !important;
                color: black !important;
                border: 1px solid #ddd;
            }
        }
    </style>
}

<div class="container-fluid py-4">

    <div class="spec-hero mb-4">
        <div class="d-flex flex-column flex-lg-row justify-content-between gap-3">
            <div>
                <div class="mb-3">
                    <span class="spec-hero-badge">
                        <i class="bi bi-file-earmark-text me-1"></i>
                        Software Engineering Intelligence Module
                    </span>
                </div>

                <h1 class="fw-bold mb-2">Smart Project Specification Generator</h1>

                <p class="mb-0 opacity-75" style="max-width: 900px;">
                    Generate a complete software engineering package for your selected FYP idea:
                    requirements, use cases, edge cases, database design, UI structure, diagrams,
                    and AI technical report when the project contains an AI component.
                </p>
            </div>

            <div class="text-lg-end">
                <div class="small opacity-75">Output</div>
                <div class="fw-bold fs-5">SE Report Package</div>
            </div>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.Message))
    {
        <div class="alert alert-success shadow-sm border-0 rounded-4 no-print">
            <i class="bi bi-check-circle me-2"></i>
            @Model.Message
        </div>
    }

    <div class="row g-4">

        <!-- LEFT PANEL -->
        <div class="col-xl-4">

            <div class="card glass-card mb-4 no-print">
                <div class="card-header bg-white border-0 p-4 pb-0">
                    <h4 class="fw-bold mb-1">Project Information</h4>
                    <p class="text-muted mb-0">
                        Select a saved idea or customize the project details before generating the report.
                    </p>
                </div>

                <div class="card-body p-4">
                    <form method="post">

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Use Saved Project Idea</label>
                            <select asp-for="SelectedProjectIdeaId"
                                    asp-items="Model.ProjectIdeaOptions"
                                    class="form-select form-select-lg"
                                    onchange="if(this.value) window.location='?projectIdeaId=' + this.value;">
                            </select>
                            <div class="form-text">
                                Select a saved idea to generate documentation based on the real project you chose.
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Project Title</label>
                            <input asp-for="Request.ProjectTitle"
                                   class="form-control form-control-lg"
                                   placeholder="Example: AI Clinic Appointment and Triage System" />
                            <span asp-validation-for="Request.ProjectTitle" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Project Description</label>
                            <textarea asp-for="Request.ProjectDescription"
                                      class="form-control"
                                      rows="7"
                                      placeholder="Describe what the project does, who uses it, and what problem it solves."></textarea>
                            <span asp-validation-for="Request.ProjectDescription" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Domain</label>
                            <input asp-for="Request.Domain"
                                   class="form-control"
                                   placeholder="Healthcare, Education, FinTech..." />
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Technology Stack</label>
                            <input asp-for="Request.TechStack"
                                   class="form-control"
                                   placeholder="ASP.NET Core, PostgreSQL, Python AI..." />
                        </div>

                        <div class="form-check mb-4">
                            <input asp-for="Request.ContainsAi" class="form-check-input" />
                            <label class="form-check-label">
                                This project contains an AI/Data Science component
                            </label>
                        </div>

                        <button type="submit" class="btn btn-primary btn-lg w-100 rounded-4">
                            <i class="bi bi-magic me-2"></i>
                            Generate Full SE Package
                        </button>
                    </form>
                </div>
            </div>

            <div class="card glass-card no-print">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-3">Generated Sections</h5>

                    <div class="d-grid gap-2 small">
                        <div><i class="bi bi-check2-circle text-success me-2"></i>Functional Requirements</div>
                        <div><i class="bi bi-check2-circle text-success me-2"></i>Non-Functional Requirements</div>
                        <div><i class="bi bi-check2-circle text-success me-2"></i>Use Cases</div>
                        <div><i class="bi bi-check2-circle text-success me-2"></i>Edge Cases</div>
                        <div><i class="bi bi-check2-circle text-success me-2"></i>Database Design</div>
                        <div><i class="bi bi-check2-circle text-success me-2"></i>UI / Front Design</div>
                        <div><i class="bi bi-check2-circle text-success me-2"></i>Diagram Descriptions</div>
                        <div><i class="bi bi-check2-circle text-success me-2"></i>AI Technical Report</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- RIGHT PANEL -->
        <div class="col-xl-8">
            @if (Model.GeneratedDocumentation == null)
            {
                <div class="empty-state d-flex flex-column justify-content-center align-items-center text-center p-5">
                    <div class="display-3 mb-3">📄</div>
                    <h2 class="fw-bold">No documentation generated yet</h2>
                    <p class="text-muted mb-0" style="max-width: 520px;">
                        Fill the project information, or select a saved idea, then click
                        <strong>Generate Full SE Package</strong> to create a structured software engineering report.
                    </p>
                </div>
            }
            else
            {
                <div id="se-report" class="card glass-card mb-4">

                    <div class="report-toolbar d-flex flex-column flex-lg-row justify-content-between gap-3">
                        <div>
                            <div class="text-muted small">Generated Documentation Package</div>
                            <h3 class="fw-bold mb-0">@Model.GeneratedDocumentation.Title</h3>
                        </div>

                        <div class="d-flex gap-2 align-items-center no-print">
                            <span class="badge rounded-pill bg-success">
                                @Model.GeneratedDocumentation.SupervisorStatus
                            </span>

                            <button type="button"
                                    class="btn btn-outline-dark btn-sm rounded-pill"
                                    onclick="window.print()">
                                <i class="bi bi-download me-1"></i>
                                Download PDF
                            </button>
                        </div>
                    </div>

                    <div class="card-body p-4">

                        <div class="row g-3 mb-4">
                            <div class="col-md-3">
                                <div class="mini-stat">
                                    <div class="number">@Model.GeneratedDocumentation.FunctionalRequirements.Count</div>
                                    <div class="label">Functional Requirements</div>
                                </div>
                            </div>

                            <div class="col-md-3">
                                <div class="mini-stat">
                                    <div class="number">@Model.GeneratedDocumentation.UseCases.Count</div>
                                    <div class="label">Use Cases</div>
                                </div>
                            </div>

                            <div class="col-md-3">
                                <div class="mini-stat">
                                    <div class="number">@Model.GeneratedDocumentation.EdgeCases.Count</div>
                                    <div class="label">Edge Cases</div>
                                </div>
                            </div>

                            <div class="col-md-3">
                                <div class="mini-stat">
                                    <div class="number">8</div>
                                    <div class="label">Report Sections</div>
                                </div>
                            </div>
                        </div>

                        <div class="section-card">
                            <div class="section-title">
                                <span class="section-icon"><i class="bi bi-list-check"></i></span>
                                1. Functional Requirements
                            </div>
                            @foreach (var item in Model.GeneratedDocumentation.FunctionalRequirements)
                            {
                                <div class="requirement-item">@item</div>
                            }
                        </div>

                        <div class="section-card">
                            <div class="section-title">
                                <span class="section-icon"><i class="bi bi-shield-check"></i></span>
                                2. Non-Functional Requirements
                            </div>
                            @foreach (var item in Model.GeneratedDocumentation.NonFunctionalRequirements)
                            {
                                <div class="requirement-item">@item</div>
                            }
                        </div>

                        <div class="section-card">
                            <div class="section-title">
                                <span class="section-icon"><i class="bi bi-person-gear"></i></span>
                                3. Use Cases
                            </div>
                            @foreach (var item in Model.GeneratedDocumentation.UseCases)
                            {
                                <div class="requirement-item">@item</div>
                            }
                        </div>

                        <div class="section-card">
                            <div class="section-title">
                                <span class="section-icon"><i class="bi bi-exclamation-triangle"></i></span>
                                4. Edge Cases
                            </div>
                            @foreach (var item in Model.GeneratedDocumentation.EdgeCases)
                            {
                                <div class="requirement-item">@item</div>
                            }
                        </div>

                        <div class="section-card">
                            <div class="section-title">
                                <span class="section-icon"><i class="bi bi-database"></i></span>
                                5. Database Design
                            </div>
                            @foreach (var item in Model.GeneratedDocumentation.DatabaseDesign)
                            {
                                <div class="requirement-item">@item</div>
                            }
                        </div>

                        <div class="section-card">
                            <div class="section-title">
                                <span class="section-icon"><i class="bi bi-window-sidebar"></i></span>
                                6. UI / Front Design
                            </div>
                            @foreach (var item in Model.GeneratedDocumentation.UiDesign)
                            {
                                <div class="requirement-item">@item</div>
                            }
                        </div>

                        <div class="section-card">
                            <div class="section-title">
                                <span class="section-icon"><i class="bi bi-diagram-3"></i></span>
                                7. Diagram Descriptions
                            </div>
                            <div class="p-3">
                                <div class="code-block">@Model.GeneratedDocumentation.DiagramDescriptions</div>
                            </div>
                        </div>

                        <div class="section-card mb-0">
                            <div class="section-title">
                                <span class="section-icon"><i class="bi bi-cpu"></i></span>
                                8. AI Technical Report
                            </div>
                            <div class="p-3">
                                <div class="code-block">@Model.GeneratedDocumentation.AiTechnicalReport</div>
                            </div>
                        </div>

                    </div>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}