@page
@model FYPilot.Web.Pages.Student.IdeaComparisonModel
@using FYPilot.Domain.Entities
@{
    ViewData["Title"] = "Idea Comparison";
    ViewData["Subtitle"] = "Compare ideas clearly and choose the one that fits you best";

    var ideas = Model.Ideas;

    var metricDefinitions = new[]
    {
        new { Key = "feasibility", Label = "Feasibility", Icon = "bar-chart-line", Description = "How achievable the idea is with your time and resources." },
        new { Key = "innovation", Label = "Innovation", Icon = "lightbulb", Description = "How original and creative the idea feels." },
        new { Key = "market", Label = "Market Value", Icon = "shop", Description = "How useful the idea is for real users or the Lebanese market." },
        new { Key = "time", Label = "Time Fit", Icon = "clock", Description = "How realistic the duration is for a semester project." },
        new { Key = "difficulty", Label = "Difficulty Fit", Icon = "speedometer2", Description = "How suitable the challenge level is for a student FYP." }
    };

    var comparisonData = ideas.Select(idea => new
    {
        id = idea.Id,
        title = idea.Title,
        domain = idea.Domain,
        selected = idea.IsSelected,
        scores = new Dictionary<string, int>
        {
            ["feasibility"] = ClampScore(idea.FeasibilityScore),
            ["innovation"] = ClampScore(idea.InnovationScore),
            ["market"] = ClampScore(idea.MarketDemandScore),
            ["time"] = TimeFitScore(idea.ExpectedDurationWeeks),
            ["difficulty"] = DifficultyFitScore(idea.DifficultyLevel)
        }
    }).ToList();
}

@if (!ideas.Any())
{
    <section class="ic2-empty-page">
        <div class="ic2-empty-card">
            <div class="ic2-empty-icon">
                <i class="bi bi-columns-gap"></i>
            </div>

            <h2>No ideas to compare yet</h2>

            <p>
                Generate at least two project ideas first, then come back here to compare them clearly.
            </p>

            <a href="/Student/IdeaGenerator" class="btn ic2-primary-btn">
                <i class="bi bi-stars me-2"></i>
                Generate Ideas
            </a>
        </div>
    </section>
}
else
{
    <section class="ic2-page">
        <div class="ic2-hero">
            <div>
                <div class="ic2-kicker">Idea Comparison</div>
                <h1>Choose based on what matters to you</h1>
                <p>
                    Select one or more comparison metrics. FYPilot will show which idea performs better for your priorities.
                </p>
            </div>

            <div class="ic2-hero-badge">
                <i class="bi bi-check2-circle"></i>
                <span>@ideas.Count idea(s) ready</span>
            </div>
        </div>

        <div class="ic2-layout">

            <aside class="ic2-left-card">
                <div class="ic2-left-head">
                    <div>
                        <div class="ic2-kicker">Your Ideas</div>
                        <h2>Ideas list</h2>
                    </div>

                    <a href="/Student/IdeaGenerator" class="ic2-mini-link">
                        Add ideas
                    </a>
                </div>

                <div class="ic2-idea-list">
                    @for (var i = 0; i < ideas.Count; i++)
                    {
                        var idea = ideas[i];
                        var avg = AverageScore(idea);
                        var isSelected = idea.IsSelected;

                        <div class="ic2-idea-card @(i == 0 ? "active" : "")"
                             data-focus-idea="@idea.Id"
                             role="button"
                             tabindex="0">

                            <div class="ic2-idea-number">
                                @(i + 1)
                            </div>

                            <div class="ic2-idea-info">
                                <h3>@idea.Title</h3>

                                <div class="ic2-idea-meta">
                                    <span>@idea.Domain</span>
                                    <span class="text-capitalize">@idea.DifficultyLevel</span>
                                </div>

                                <p>@Clip(idea.ProblemStatement, 92)</p>

                                <form method="post" asp-page-handler="Select" class="ic2-inline-select-form">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="ideaId" value="@idea.Id" />

                                    <button type="submit" class="btn btn-sm ic2-select-small-btn">
                                        Select Idea
                                    </button>
                                </form>
                            </div>

                            <div class="ic2-idea-score">
                                <strong>@avg%</strong>
                                <span>overall</span>
                            </div>

                            @if (isSelected)
                            {
                                <div class="ic2-selected-dot" title="Currently selected">
                                    <i class="bi bi-check"></i>
                                </div>
                            }
                        </div>
                    }
                </div>

                <div class="ic2-left-tip">
                    <i class="bi bi-info-circle"></i>
                    <span>
                        Start with Feasibility and Time Fit if you want the safest choice.
                    </span>
                </div>
            </aside>

            <main class="ic2-main-card">
                <div class="ic2-main-head">
                    <div>
                        <div class="ic2-kicker">Compare By</div>
                        <h2>Select your priorities</h2>
                    </div>

                    <div class="d-flex align-items-center gap-2 flex-wrap">
                        <form method="post" asp-page-handler="Compare" class="m-0">
                            @Html.AntiForgeryToken()

                            <button type="submit" class="btn ic2-primary-btn">
                                <i class="bi bi-columns-gap me-1"></i>
                                Compare My Ideas
                            </button>
                        </form>

                        <button type="button" class="btn ic2-clear-btn" id="ic2ResetMetrics">
                            Reset
                        </button>
                    </div>
                </div>

                <div class="ic2-metric-tabs" id="ic2MetricTabs">
                    @foreach (var metric in metricDefinitions)
                    {
                        var active = metric.Key is "feasibility" or "time";

                        <button type="button"
                                class="ic2-metric-tab @(active ? "active" : "")"
                                data-metric="@metric.Key">
                            <i class="bi bi-@metric.Icon"></i>
                            <span>@metric.Label</span>
                            <b class="ic2-check"><i class="bi bi-check"></i></b>
                        </button>
                    }
                </div>

                <div class="ic2-selected-summary" id="ic2SelectedSummary">
                    Showing comparison for: <strong>Feasibility</strong> and <strong>Time Fit</strong>
                </div>

                <div class="ic2-results-area">
                    @foreach (var metric in metricDefinitions)
                    {
                        var isVisible = metric.Key is "feasibility" or "time";

                        <section class="ic2-metric-panel @(isVisible ? "" : "d-none")"
                                 data-metric-panel="@metric.Key">
                            <div class="ic2-panel-title">
                                <div>
                                    <h3>@metric.Label</h3>
                                    <p>@metric.Description</p>
                                </div>
                            </div>

                            <div class="ic2-bars">
                                @{
                                    var bestScore = ideas.Max(i => ScoreForMetric(i, metric.Key));
                                }

                                @foreach (var idea in ideas.OrderByDescending(i => ScoreForMetric(i, metric.Key)))
                                {
                                    var score = ScoreForMetric(idea, metric.Key);
                                    var isBest = score == bestScore;

                                    <div class="ic2-bar-row @(isBest ? "best" : "")" data-idea-row="@idea.Id">
                                        <div class="ic2-bar-title">
                                            <span>@idea.Title</span>

                                            @if (isBest)
                                            {
                                                <small>Best for @metric.Label</small>
                                            }
                                        </div>

                                        <div class="ic2-bar-track">
                                            <div style="width:@score%"></div>
                                        </div>

                                        <div class="ic2-bar-score">
                                            @score%
                                        </div>
                                    </div>
                                }
                            </div>
                        </section>
                    }
                </div>

                <div class="ic2-recommendation-card">
                    <div class="ic2-recommendation-icon">
                        <i class="bi bi-award"></i>
                    </div>

                    <div>
                        <div class="ic2-kicker">Recommended Based On Your Selected Metrics</div>
                        <h3 id="ic2RecommendedTitle">Best matching idea</h3>
                        <p id="ic2RecommendedText">
                            The recommendation updates when you choose comparison metrics.
                        </p>
                    </div>

                    <form method="post" asp-page-handler="Select" class="ic2-recommendation-action">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="ideaId" id="ic2RecommendedIdeaId" value="@ideas.First().Id" />

                        <button type="submit" class="btn ic2-primary-btn">
                            <i class="bi bi-check2-circle me-1"></i>
                            Select This Idea
                        </button>
                    </form>
                </div>
            </main>
        </div>
    </section>
}

@section Scripts {
    <script>
        const comparisonIdeas = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(comparisonData));
        const metricLabels = {
            feasibility: "Feasibility",
            innovation: "Innovation",
            market: "Market Value",
            time: "Time Fit",
            difficulty: "Difficulty Fit"
        };

        const metricTabs = document.querySelectorAll("[data-metric]");
        const metricPanels = document.querySelectorAll("[data-metric-panel]");
        const selectedSummary = document.getElementById("ic2SelectedSummary");
        const recommendedTitle = document.getElementById("ic2RecommendedTitle");
        const recommendedText = document.getElementById("ic2RecommendedText");
        const recommendedIdeaId = document.getElementById("ic2RecommendedIdeaId");
        const resetButton = document.getElementById("ic2ResetMetrics");

        function getSelectedMetrics() {
            return Array.from(metricTabs)
                .filter(tab => tab.classList.contains("active"))
                .map(tab => tab.dataset.metric);
        }

        function scoreIdea(idea, selectedMetrics) {
            if (selectedMetrics.length === 0) {
                return 0;
            }

            const total = selectedMetrics.reduce((sum, metric) => {
                return sum + (idea.scores[metric] || 0);
            }, 0);

            return Math.round(total / selectedMetrics.length);
        }

        function updateComparison() {
            let selectedMetrics = getSelectedMetrics();

            if (selectedMetrics.length === 0) {
                const feasibilityTab = document.querySelector('[data-metric="feasibility"]');

                if (feasibilityTab) {
                    feasibilityTab.classList.add("active");
                }

                selectedMetrics = ["feasibility"];
            }

            metricPanels.forEach(panel => {
                const metric = panel.dataset.metricPanel;
                panel.classList.toggle("d-none", !selectedMetrics.includes(metric));
            });

            const selectedLabels = selectedMetrics.map(metric => metricLabels[metric]);

            selectedSummary.innerHTML =
                "Showing comparison for: " +
                selectedLabels.map(label => `<strong>${label}</strong>`).join(", ");

            const ranked = comparisonIdeas
                .map(idea => ({
                    ...idea,
                    finalScore: scoreIdea(idea, selectedMetrics)
                }))
                .sort((a, b) => b.finalScore - a.finalScore);

            const best = ranked[0];

            if (best) {
                recommendedTitle.textContent = best.title;
                recommendedText.textContent =
                    `${best.title} has the strongest average fit across your selected metric(s): ${best.finalScore}%.`;

                recommendedIdeaId.value = best.id;
            }
        }

        metricTabs.forEach(tab => {
            tab.addEventListener("click", function () {
                this.classList.toggle("active");
                updateComparison();
            });
        });

        document.querySelectorAll("[data-focus-idea]").forEach(card => {
            card.addEventListener("click", function (event) {
                if (event.target.closest("form")) {
                    return;
                }

                document.querySelectorAll("[data-focus-idea]").forEach(item => item.classList.remove("active"));
                this.classList.add("active");

                const ideaId = this.dataset.focusIdea;

                document.querySelectorAll("[data-idea-row]").forEach(row => {
                    row.classList.toggle("focused", row.dataset.ideaRow === ideaId);
                });
            });

            card.addEventListener("keydown", function (event) {
                if (event.key === "Enter" || event.key === " ") {
                    event.preventDefault();
                    this.click();
                }
            });
        });

        resetButton?.addEventListener("click", function () {
            metricTabs.forEach(tab => tab.classList.remove("active"));

            document.querySelector('[data-metric="feasibility"]')?.classList.add("active");
            document.querySelector('[data-metric="time"]')?.classList.add("active");

            updateComparison();
        });

        updateComparison();
    </script>
}

@functions {
    private static string Clip(string? value, int max)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return "No description available.";
        }

        return value.Length <= max ? value : value[..max] + "...";
    }

    private static int ClampScore(int value)
    {
        return Math.Clamp(value, 0, 100);
    }

    private static int AverageScore(ProjectIdea idea)
    {
        return (ClampScore(idea.InnovationScore) + ClampScore(idea.FeasibilityScore) + ClampScore(idea.MarketDemandScore)) / 3;
    }

    private static int TimeFitScore(int weeks)
    {
        if (weeks <= 0)
        {
            return 70;
        }

        if (weeks <= 10)
        {
            return 95;
        }

        if (weeks <= 14)
        {
            return 88;
        }

        if (weeks <= 18)
        {
            return 74;
        }

        if (weeks <= 24)
        {
            return 58;
        }

        return 42;
    }

    private static int DifficultyFitScore(string? difficulty)
    {
        var value = (difficulty ?? "").Trim().ToLowerInvariant();

        return value switch
        {
            "beginner" => 82,
            "easy" => 82,
            "intermediate" => 92,
            "medium" => 92,
            "advanced" => 68,
            "hard" => 58,
            _ => 75
        };
    }

    private static int ScoreForMetric(ProjectIdea idea, string metric)
    {
        return metric switch
        {
            "feasibility" => ClampScore(idea.FeasibilityScore),
            "innovation" => ClampScore(idea.InnovationScore),
            "market" => ClampScore(idea.MarketDemandScore),
            "time" => TimeFitScore(idea.ExpectedDurationWeeks),
            "difficulty" => DifficultyFitScore(idea.DifficultyLevel),
            _ => AverageScore(idea)
        };
    }
}
