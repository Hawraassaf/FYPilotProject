            max-width: 250px;
        }

        .er-empty {
            min-height: 520px;
            display: grid;
            place-items: center;
            align-content: center;
            text-align: center;
            gap: 0.6rem;
            padding: 2rem;
        }

            .er-empty.compact {
                min-height: 280px;
                box-shadow: none;
                border: 0;
            }

            .er-empty i {
                width: 74px;
                height: 74px;
                border-radius: 26px;
                color: var(--er-steel);
                background: #EEF2F6;
                display: grid;
                place-items: center;
                font-size: 1.9rem;
            }

            .er-empty h2 {
                margin: 0;
                color: var(--er-text);
                font-size: 1.3rem;
                font-weight: 620;
            }

            .er-empty p {
                margin: 0;
                color: var(--er-muted);
                max-width: 540px;
                line-height: 1.6;
            }

            .er-empty a {
                color: #ffffff;
                background: var(--er-blue);
                border-radius: 14px;
                padding: 0.64rem 0.9rem;
                text-decoration: none;
                font-size: 0.82rem;
                font-weight: 600;
            }

        @@media (max-width: 1280px) {
            .er-hero,
            .er-toolbar-card,
            .er-filter-form {
                grid-template-columns: 1fr;
            }

            .er-workflow-card {
                max-width: 100%;
            }
        }

        @@media (max-width: 767px) {
            .er-flow {
                grid-template-columns: 1fr;
            }

                .er-flow b {
                    display: none;
                }

            .er-table-head {
                align-items: flex-start;
                flex-direction: column;
            }
        }
    </style>
}

@functions {
    private static string NormalizeStatus(string? status)
    {
        return string.IsNullOrWhiteSpace(status)
            ? "pending"
            : status.Trim().ToLowerInvariant();
    }

    private static (string Label, string ClassName) StatusMeta(string? status)
    {
        return NormalizeStatus(status) switch
        {
            "approved" => ("Approved", "er-pill approved"),
            "needs_revision" => ("Needs Revision", "er-pill revision"),
            "rejected" => ("Rejected", "er-pill rejected"),
            _ => ("Pending", "er-pill pending")
        };
    }

    private static string SimilarityClass(int value)
    {
        return value >= 70
            ? "er-pill high"
            : value >= 50
                ? "er-pill medium"
                : "er-pill safe";
    }

    private static (string Label, string ClassName) FeedbackMeta(FYPilot.Web.Pages.Supervisor.EvaluationsModel.EvalRow item)
    {
        var hasComment = !string.IsNullOrWhiteSpace(item.Comment);
        var hasSuggestions = !string.IsNullOrWhiteSpace(item.ImprovementSuggestions);

        if (hasComment && hasSuggestions)
        {
            return ("Complete", "er-pill complete");
        }

        if (hasComment || hasSuggestions)
        {
            return ("Partial", "er-pill partial");
        }

        return ("Missing", "er-pill missing");
    }

    private static string FeedbackPreview(FYPilot.Web.Pages.Supervisor.EvaluationsModel.EvalRow item)
    {
        if (!string.IsNullOrWhiteSpace(item.Comment))
        {
            return item.Comment;
        }

        if (!string.IsNullOrWhiteSpace(item.ImprovementSuggestions))
        {
            return item.ImprovementSuggestions;
        }

        return "No written feedback added.";
    }

    private static string ShortText(string? value, int maxLength)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return "";
        }

        value = value.Trim().Replace("\r", " ").Replace("\n", " ");

        return value.Length <= maxLength ? value : value[..maxLength] + "...";
    }

    private static string Initials(string? name)
    {
        if (string.IsNullOrWhiteSpace(name))
        {
            return "ST";
        }

        var parts = name
            .Split(' ', StringSplitOptions.RemoveEmptyEntries)
            .Take(2)
            .ToList();

        return parts.Count == 0
            ? "ST"
            : string.Join("", parts.Select(part => part[0])).ToUpperInvariant();
    }
}
