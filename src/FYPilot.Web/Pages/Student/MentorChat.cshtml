@page
@model FYPilot.Web.Pages.Student.MentorChatModel
@{
    ViewData["Title"] = "Mentor Chat";
    ViewData["Subtitle"] = "AI-powered academic guidance for your FYP";

    var selectedIdeaTitle =
        Model.SelectedIdea?.Title ?? "No project selected";

    var selectedDomain =
        Model.SelectedIdea?.Domain ?? "Choose an idea first";

    var currentChatTitle =
        Model.CurrentChat?.Title ?? "New chat";
}

<style>
    .fyc-page {
        --fyc-navy: #17233f;
        --fyc-navy-soft: #263555;
        --fyc-border: #e4e8f0;
        --fyc-muted: #69758b;
        --fyc-bg: #f7f8fb;
        --fyc-panel: #ffffff;
        --fyc-lilac: #f0efff;
        --fyc-danger: #b8425a;
        min-height: calc(100vh - 120px);
    }

    .fyc-alert {
        border-radius: 14px;
        border: 1px solid #efd9a8;
        background: #fff9eb;
        color: #75571c;
        margin-bottom: 16px;
    }

    .fyc-top {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 24px;
        margin-bottom: 18px;
    }

    .fyc-brand,
    .fyc-project {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .fyc-logo {
        width: 46px;
        height: 46px;
        border-radius: 15px;
        display: grid;
        place-items: center;
        color: #fff;
        background: var(--fyc-navy);
        box-shadow: 0 10px 28px rgba(23, 35, 63, .18);
        flex: 0 0 auto;
    }

    .fyc-brand h1 {
        margin: 0;
        color: var(--fyc-navy);
        font-size: 1.5rem;
        font-weight: 720;
        letter-spacing: -.03em;
    }

    .fyc-brand p {
        margin: 3px 0 0;
        color: var(--fyc-muted);
        font-size: .9rem;
    }

    .fyc-project {
        min-width: 280px;
        max-width: 430px;
        padding: 11px 14px;
        border: 1px solid var(--fyc-border);
        border-radius: 15px;
        background: #fff;
    }

        .fyc-project > i {
            color: var(--fyc-navy-soft);
        }

        .fyc-project span,
        .fyc-project small {
            display: block;
            color: var(--fyc-muted);
            font-size: .72rem;
        }

        .fyc-project strong {
            display: block;
            color: var(--fyc-navy);
            font-size: .86rem;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

    .fyc-workspace {
        display: grid;
        grid-template-columns: 270px minmax(0, 1fr);
        min-height: 670px;
        height: calc(100vh - 225px);
        border: 1px solid var(--fyc-border);
        border-radius: 22px;
        overflow: hidden;
        background: var(--fyc-panel);
        box-shadow: 0 18px 50px rgba(24, 35, 63, .07);
    }

    .fyc-history {
        display: flex;
        min-width: 0;
        flex-direction: column;
        border-right: 1px solid var(--fyc-border);
        background: #fafbfe;
    }

    .fyc-history-top {
        padding: 16px;
        border-bottom: 1px solid var(--fyc-border);
    }

    .fyc-new-chat {
        width: 100%;
        min-height: 42px;
        border: 1px solid var(--fyc-navy);
        border-radius: 12px;
        background: var(--fyc-navy);
        color: #fff;
        font-weight: 650;
        transition: .18s ease;
    }

        .fyc-new-chat:hover {
            background: var(--fyc-navy-soft);
            transform: translateY(-1px);
        }

    .fyc-history-label {
        padding: 18px 16px 8px;
        color: var(--fyc-muted);
        font-size: .72rem;
        font-weight: 700;
        letter-spacing: .08em;
        text-transform: uppercase;
    }

    .fyc-session-list {
        flex: 1;
        min-height: 0;
        overflow-y: auto;
        padding: 0 9px 14px;
    }

    .fyc-session {
        position: relative;
        display: flex;
        align-items: center;
        gap: 4px;
        margin-bottom: 4px;
        border-radius: 11px;
    }

        .fyc-session.is-active {
            background: #eceffa;
        }

    .fyc-session-link {
        display: flex;
        min-width: 0;
        flex: 1;
        align-items: center;
        gap: 10px;
        padding: 10px 8px 10px 11px;
        color: #344057;
        text-decoration: none;
        border-radius: 11px;
    }

        .fyc-session-link:hover {
            color: var(--fyc-navy);
            background: #f0f2f8;
        }

        .fyc-session-link i {
            flex: 0 0 auto;
            color: #7a8599;
        }

    .fyc-session-copy {
        min-width: 0;
    }

        .fyc-session-copy strong {
            display: block;
            overflow: hidden;
            color: inherit;
            font-size: .83rem;
            font-weight: 600;
            text-overflow: ellipsis;
            white-space: nowrap;
        }

        .fyc-session-copy small {
            display: block;
            margin-top: 2px;
            color: #8a93a5;
            font-size: .68rem;
        }

    .fyc-delete-chat {
        width: 30px;
        height: 30px;
        margin-right: 5px;
        border: 0;
        border-radius: 9px;
        background: transparent;
        color: #8a93a5;
        opacity: 0;
        transition: .15s ease;
    }

    .fyc-session:hover .fyc-delete-chat,
    .fyc-session.is-active .fyc-delete-chat {
        opacity: 1;
    }

    .fyc-delete-chat:hover {
        color: var(--fyc-danger);
        background: #fff0f3;
    }

    .fyc-empty-history {
        padding: 16px;
        color: var(--fyc-muted);
        font-size: .82rem;
        line-height: 1.55;
    }

    .fyc-chat-shell {
        display: flex;
        min-width: 0;
        min-height: 0;
        flex-direction: column;
        background: #fff;
    }

    .fyc-chat-head {
        display: flex;
        min-height: 64px;
        align-items: center;
        justify-content: space-between;
        gap: 14px;
        padding: 12px 20px;
        border-bottom: 1px solid var(--fyc-border);
    }

        .fyc-chat-head strong {
            display: block;
            color: var(--fyc-navy);
            font-size: .95rem;
        }

        .fyc-chat-head span {
            color: var(--fyc-muted);
            font-size: .75rem;
        }

    .fyc-chat-state {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 6px 9px;
        border-radius: 999px;
        color: #59647a;
        background: #f2f4f8;
        font-size: .7rem;
        font-weight: 650;
    }

    .fyc-messages {
        flex: 1;
        min-height: 0;
        overflow-y: auto;
        scroll-behavior: smooth;
        background: radial-gradient(circle at 90% 5%, rgba(104, 94, 178, .055), transparent 30%), #fff;
    }

    .fyc-thread {
        width: min(850px, calc(100% - 42px));
        margin: 0 auto;
        padding: 32px 0;
    }

    .fyc-welcome {
        max-width: 680px;
        margin: 58px auto 0;
        text-align: center;
    }

    .fyc-welcome-icon {
        width: 56px;
        height: 56px;
        display: grid;
        place-items: center;
        margin: 0 auto 16px;
        border-radius: 18px;
        color: var(--fyc-navy);
        background: var(--fyc-lilac);
        font-size: 1.3rem;
    }

    .fyc-welcome h2 {
        margin: 0;
        color: var(--fyc-navy);
        font-size: 1.55rem;
        font-weight: 720;
        letter-spacing: -.03em;
    }

    .fyc-welcome > p {
        max-width: 560px;
        margin: 10px auto 22px;
        color: var(--fyc-muted);
        line-height: 1.7;
    }

    .fyc-starters {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 10px;
    }

        .fyc-starters button {
            display: flex;
            min-height: 54px;
            align-items: center;
            gap: 10px;
            padding: 12px 14px;
            border: 1px solid var(--fyc-border);
            border-radius: 13px;
            background: #fff;
            color: #3d4960;
            text-align: left;
            font-size: .82rem;
            transition: .17s ease;
        }

            .fyc-starters button:hover {
                border-color: #b9c1d2;
                background: #fafbfe;
                transform: translateY(-1px);
            }

    .fyc-msg {
        display: flex;
        align-items: flex-start;
        gap: 11px;
        margin-bottom: 22px;
    }

        .fyc-msg.is-user {
            flex-direction: row-reverse;
        }

    .fyc-avatar {
        width: 32px;
        height: 32px;
        display: grid;
        place-items: center;
        flex: 0 0 auto;
        border-radius: 10px;
        font-size: .8rem;
    }

        .fyc-avatar.is-ai {
            color: #fff;
            background: var(--fyc-navy);
        }

        .fyc-avatar.is-user {
            color: var(--fyc-navy);
            background: #e9ecf4;
        }

    .fyc-bubble {
        max-width: min(760px, 82%);
        padding: 13px 15px 9px;
        border: 1px solid var(--fyc-border);
        border-radius: 16px;
        background: #fff;
        box-shadow: 0 7px 20px rgba(23, 35, 63, .04);
    }

    .fyc-msg.is-user .fyc-bubble {
        border-color: var(--fyc-navy);
        background: var(--fyc-navy);
        color: #fff;
    }

    .fyc-meta {
        display: flex;
        align-items: center;
        gap: 8px;
        margin-bottom: 7px;
    }

        .fyc-meta strong {
            color: var(--fyc-navy);
            font-size: .76rem;
        }

        .fyc-meta span {
            color: var(--fyc-muted);
            font-size: .66rem;
        }

    .fyc-text {
        white-space: pre-wrap;
        overflow-wrap: anywhere;
        line-height: 1.65;
        font-size: .88rem;
    }

    .fyc-bubble time {
        display: block;
        margin-top: 7px;
        color: #919bad;
        font-size: .62rem;
        text-align: right;
    }

    .fyc-msg.is-user .fyc-bubble time {
        color: rgba(255, 255, 255, .68);
    }

    .fyc-composer {
        padding: 15px 20px 14px;
        border-top: 1px solid var(--fyc-border);
        background: rgba(255, 255, 255, .97);
    }

    .fyc-composer-inner {
        width: min(850px, 100%);
        margin: 0 auto;
    }

    .fyc-composer-box {
        display: flex;
        align-items: flex-end;
        gap: 10px;
        padding: 8px 8px 8px 14px;
        border: 1px solid #cfd5e1;
        border-radius: 16px;
        background: #fff;
        box-shadow: 0 8px 25px rgba(23, 35, 63, .06);
    }

    .fyc-input {
        min-height: 40px;
        max-height: 150px;
        padding: 9px 0;
        resize: none;
        border: 0 !important;
        outline: 0 !important;
        box-shadow: none !important;
        font-size: .9rem;
    }

    .fyc-send {
        width: 40px;
        height: 40px;
        display: grid;
        place-items: center;
        flex: 0 0 auto;
        border-radius: 12px;
        background: var(--fyc-navy);
        color: #fff;
    }

        .fyc-send:hover {
            background: var(--fyc-navy-soft);
            color: #fff;
        }

        .fyc-send:disabled {
            opacity: .58;
        }

    .fyc-note {
        margin-top: 7px;
        color: #8791a3;
        font-size: .67rem;
        text-align: center;
    }

    .fyc-thinking {
        display: flex;
        gap: 5px;
        padding: 4px 1px 6px;
    }

        .fyc-thinking span {
            width: 7px;
            height: 7px;
            border-radius: 50%;
            background: #8993a7;
            animation: fycPulse 1.2s infinite ease-in-out;
        }

            .fyc-thinking span:nth-child(2) {
                animation-delay: .16s;
            }

            .fyc-thinking span:nth-child(3) {
                animation-delay: .32s;
            }

    @@keyframes fycPulse {
        0%, 70%, 100% {
            opacity: .35;
            transform: translateY(0);
        }

        35% {
            opacity: 1;
            transform: translateY(-3px);
        }
    }

    @@media (max-width: 980px) {
        .fyc-workspace {
            grid-template-columns: 220px minmax(0, 1fr);
        }

        .fyc-project {
            min-width: 0;
        }
    }

    @@media (max-width: 760px) {
        .fyc-top {
            align-items: stretch;
            flex-direction: column;
        }

        .fyc-workspace {
            height: auto;
            min-height: 720px;
            grid-template-columns: 1fr;
        }

        .fyc-history {
            max-height: 220px;
            border-right: 0;
            border-bottom: 1px solid var(--fyc-border);
        }

        .fyc-session-list {
            max-height: 150px;
        }

        .fyc-chat-shell {
            min-height: 610px;
        }

        .fyc-starters {
            grid-template-columns: 1fr;
        }

        .fyc-thread {
            width: calc(100% - 24px);
        }
    }
</style>

<section class="fyc-page">

    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="alert fyc-alert" role="alert">
            <i class="bi bi-exclamation-triangle me-2"></i>
            @Model.ErrorMessage
        </div>
    }

    <header class="fyc-top">
        <div class="fyc-brand">
            <div class="fyc-logo">
                <i class="bi bi-stars"></i>
            </div>

            <div class="min-w-0">
                <h1>FYPilot Mentor</h1>
                <p>Project-aware academic guidance with saved conversations</p>
            </div>
        </div>

        <div class="fyc-project">
            <i class="bi bi-lightbulb"></i>

            <div class="min-w-0">
                <span>Project context</span>
                <strong title="@selectedIdeaTitle">
                    @selectedIdeaTitle
                </strong>
                <small>@selectedDomain</small>
            </div>
        </div>
    </header>

    <div class="fyc-workspace">

        <aside class="fyc-history">
            <div class="fyc-history-top">
                <form method="post" asp-page-handler="NewChat">
                    @Html.AntiForgeryToken()
                    <input type="hidden"
                           name="ideaId"
                           value="@Model.SelectedIdeaId" />

                    <button type="submit" class="fyc-new-chat">
                        <i class="bi bi-plus-lg me-2"></i>
                        New chat
                    </button>
                </form>
            </div>

            <div class="fyc-history-label">
                Conversations
            </div>

            <div class="fyc-session-list">
                @if (!Model.ChatSessions.Any())
                {
                    <div class="fyc-empty-history">
                        Your saved conversations will appear here.
                    </div>
                }
                else
                {
                    @foreach (var chat in Model.ChatSessions)
                    {
                        var isActive =
                            Model.CurrentChatId == chat.Id;

                        <div class="fyc-session @(isActive ? "is-active" : "")">
                            <a class="fyc-session-link"
                               asp-page="./MentorChat"
                               asp-route-ideaId="@Model.SelectedIdeaId"
                               asp-route-chatId="@chat.Id"
                               title="@chat.Title">

                                <i class="bi bi-chat-left-text"></i>

                                <span class="fyc-session-copy">
                                    <strong>@chat.Title</strong>
                                    <small>
                                        @chat.UpdatedAt.ToLocalTime().ToString("MMM d, HH:mm")
                                    </small>
                                </span>
                            </a>

                            <form method="post"
                                  asp-page-handler="DeleteChat"
                                  onsubmit="return confirm('Delete this conversation?');">

                                @Html.AntiForgeryToken()

                                <input type="hidden"
                                       name="ideaId"
                                       value="@Model.SelectedIdeaId" />

                                <input type="hidden"
                                       name="chatId"
                                       value="@chat.Id" />

                                <button type="submit"
                                        class="fyc-delete-chat"
                                        aria-label="Delete @chat.Title"
                                        title="Delete conversation">
                                    <i class="bi bi-trash3"></i>
                                </button>
                            </form>
                        </div>
                    }
                }
            </div>
        </aside>

        <main class="fyc-chat-shell">
            <header class="fyc-chat-head">
                <div class="min-w-0">
                    <strong title="@currentChatTitle">
                        @currentChatTitle
                    </strong>
                    <span>
                        Conversation saved automatically
                    </span>
                </div>

                <div class="fyc-chat-state">
                    <i class="bi bi-database-check"></i>
                    Project context active
                </div>
            </header>

            <div id="fycMessages" class="fyc-messages">
                <div class="fyc-thread" id="fycThread">

                    @if (!Model.Messages.Any())
                    {
                        <section class="fyc-welcome">
                            <div class="fyc-welcome-icon">
                                <i class="bi bi-chat-dots"></i>
                            </div>

                            <h2>How can I help with your project?</h2>

                            <p>
                                Ask about your next steps, risks, code, roadmap,
                                methodology, testing, documentation, or defense.
                                Follow-up questions stay inside this conversation.
                            </p>

                            <div class="fyc-starters">
                                <button type="button"
                                        data-prompt="What should I work on next?">
                                    <i class="bi bi-rocket-takeoff"></i>
                                    What should I work on next?
                                </button>

                                <button type="button"
                                        data-prompt="What are the main risks in my project?">
                                    <i class="bi bi-shield-exclamation"></i>
                                    What are the main risks?
                                </button>

                                <button type="button"
                                        data-prompt="Help me plan the implementation of my project.">
                                    <i class="bi bi-tools"></i>
                                    Help me plan implementation
                                </button>

                                <button type="button"
                                        data-prompt="How should I defend this idea in front of professors?">
                                    <i class="bi bi-mortarboard"></i>
                                    How do I defend this idea?
                                </button>
                            </div>
                        </section>
                    }

                    @foreach (var msg in Model.Messages)
                    {
                        var isUser = msg.Role == "user";

                        var isServiceNotice =
                            msg.Role == "assistant" &&
                            msg.Content.Contains(
                                "could not respond",
                                StringComparison.OrdinalIgnoreCase);

                        <div class="fyc-msg @(isUser ? "is-user" : "is-ai") @(isServiceNotice ? "is-service" : "")">
                            <div class="fyc-avatar @(isUser ? "is-user" : "is-ai")">
                                <i class="bi @(isUser ? "bi-person" : "bi-stars")"></i>
                            </div>

                            <article class="fyc-bubble">
                                @if (!isUser)
                                {
                                    <div class="fyc-meta">
                                        <strong>FYPilot Mentor</strong>
                                        <span>
                                            @(isServiceNotice
                                                ? "Service notice"
                                                : "AI guidance")
                                        </span>
                                    </div>
                                }

                                <div class="fyc-text">@msg.Content</div>

                                <time>
                                    @msg.CreatedAt.ToLocalTime().ToString("HH:mm")
                                </time>
                            </article>
                        </div>
                    }
                </div>
            </div>

            <form method="post"
                  asp-page-handler="Send"
                  id="fycForm"
                  class="fyc-composer">

                @Html.AntiForgeryToken()

                <input type="hidden"
                       name="ideaId"
                       value="@Model.SelectedIdeaId" />

                <input type="hidden"
                       name="chatId"
                       value="@Model.CurrentChatId" />

                <div class="fyc-composer-inner">
                    <div class="fyc-composer-box">
                        <textarea asp-for="MessageText"
                                  id="mentorMessage"
                                  class="form-control fyc-input"
                                  rows="1"
                                  placeholder="Message FYPilot Mentor..."
                                  required
                                  autofocus></textarea>

                        <button type="submit"
                                class="btn fyc-send"
                                aria-label="Send message">
                            <i class="bi bi-arrow-up"></i>
                        </button>
                    </div>

                    <div class="fyc-note">
                        Enter sends · Shift + Enter creates a new line ·
                        The active conversation is saved in PostgreSQL
                    </div>
                </div>
            </form>
        </main>
    </div>
</section>

@section Scripts {
    <script>
        const fycMessages =
            document.getElementById("fycMessages");

        const fycThread =
            document.getElementById("fycThread");

        const fycInput =
            document.getElementById("mentorMessage");

        const fycForm =
            document.getElementById("fycForm");

        function scrollMentorToBottom() {
            if (fycMessages) {
                fycMessages.scrollTop =
                    fycMessages.scrollHeight;
            }
        }

        function resizeMentorInput() {
            if (!fycInput) {
                return;
            }

            fycInput.style.height = "auto";
            fycInput.style.height =
                Math.min(fycInput.scrollHeight, 150) + "px";
        }

        function getCurrentTime() {
            const now = new Date();

            return now.toLocaleTimeString([], {
                hour: "2-digit",
                minute: "2-digit"
            });
        }

        scrollMentorToBottom();
        resizeMentorInput();

        if (fycInput) {
            fycInput.addEventListener(
                "input",
                resizeMentorInput);

            fycInput.addEventListener(
                "keydown",
                function (event) {
                    if (
                        event.key === "Enter" &&
                        !event.shiftKey
                    ) {
                        event.preventDefault();

                        if (fycForm) {
                            fycForm.requestSubmit();
                        }
                    }
                });
        }

        document
            .querySelectorAll("[data-prompt]")
            .forEach(button => {
                button.addEventListener(
                    "click",
                    function () {
                        if (!fycInput) {
                            return;
                        }

                        fycInput.value =
                            this.dataset.prompt;

                        resizeMentorInput();
                        fycInput.focus();
                    });
            });

        if (fycForm && fycThread && fycInput) {
            fycForm.addEventListener(
                "submit",
                function (event) {
                    event.preventDefault();

                    const value =
                        fycInput.value.trim();

                    if (!value) {
                        return;
                    }

                    const sendButton =
                        fycForm.querySelector(
                            "button[type='submit']");

                    if (sendButton) {
                        sendButton.disabled = true;
                    }

                    const userRow =
                        document.createElement("div");

                    userRow.className =
                        "fyc-msg is-user";

                    userRow.innerHTML = `
                        <div class="fyc-avatar is-user">
                            <i class="bi bi-person"></i>
                        </div>

                        <article class="fyc-bubble">
                            <div class="fyc-text"></div>
                            <time>${getCurrentTime()}</time>
                        </article>
                    `;

                    userRow
                        .querySelector(".fyc-text")
                        .textContent = value;

                    fycThread.appendChild(userRow);

                    const thinkingRow =
                        document.createElement("div");

                    thinkingRow.className =
                        "fyc-msg is-ai is-thinking";

                    thinkingRow.innerHTML = `
                        <div class="fyc-avatar is-ai">
                            <i class="bi bi-stars"></i>
                        </div>

                        <article class="fyc-bubble">
                            <div class="fyc-meta">
                                <strong>FYPilot Mentor</strong>
                                <span>Thinking</span>
                            </div>

                            <div class="fyc-thinking">
                                <span></span>
                                <span></span>
                                <span></span>
                            </div>
                        </article>
                    `;

                    fycThread.appendChild(thinkingRow);

                    fycInput.value = "";
                    fycInput.style.height = "auto";

                    scrollMentorToBottom();

                    const oldHiddenMessage =
                        fycForm.querySelector(
                            "input[data-temp-message='true']");

                    if (oldHiddenMessage) {
                        oldHiddenMessage.remove();
                    }

                    const hiddenMessage =
                        document.createElement("input");

                    hiddenMessage.type = "hidden";
                    hiddenMessage.name = "MessageText";
                    hiddenMessage.value = value;
                    hiddenMessage.setAttribute(
                        "data-temp-message",
                        "true");

                    fycForm.appendChild(hiddenMessage);

                    // Prevent the textarea and hidden field from
                    // posting duplicate MessageText values.
                    fycInput.removeAttribute("name");

                    setTimeout(function () {
                        HTMLFormElement
                            .prototype
                            .submit
                            .call(fycForm);
                    }, 350);
                });
        }
    </script>
}
