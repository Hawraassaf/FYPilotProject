}
@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        setTimeout(function () {
            document.querySelectorAll(".idea2-alert").forEach(function (message) {
                message.style.transition = "opacity 0.35s ease, transform 0.35s ease";
                message.style.opacity = "0";
                message.style.transform = "translateY(-6px)";

                setTimeout(function () {
                    message.remove();
                }, 350);
            });
        }, 2500);

        // Market Insight — loading state on submit. Regional research can
        // take a few seconds, so the clicked button is disabled and shows a
        // spinner to prevent duplicate submissions, without freezing the
        // rest of the page.
        document.querySelectorAll("[data-marketfp-analyze-form]").forEach(function (form) {
            form.addEventListener("submit", function () {
                const button = form.querySelector("[data-marketfp-submit-btn]");
                if (!button || button.disabled) {
                    return;
                }

                button.disabled = true;
                button.setAttribute("aria-busy", "true");

                const label = button.querySelector("[data-marketfp-btn-label]");
                if (label) {
                    label.textContent = "Analyzing regional signals…";
                }

                const icon = button.querySelector("i");
                if (icon) {
                    icon.className = "spinner-border spinner-border-sm";
                }
            });
        });

        // Bootstrap tooltip for the "Market Opportunity" info icon.
        document.querySelectorAll('[data-bs-toggle="tooltip"]').forEach(function (el) {
            if (window.bootstrap && window.bootstrap.Tooltip) {
                new window.bootstrap.Tooltip(el);
            }
        });
    </script>
}
