@section Scripts {
    <script>
        const openSchedulePanel = document.getElementById("openSchedulePanel");
        const closeSchedulePanel = document.getElementById("closeSchedulePanel");
        const schedulePanel = document.getElementById("schedulePanel");
        const scheduleOverlay = document.getElementById("scheduleOverlay");

        function openSchedule() {
            schedulePanel?.classList.add("show");
            scheduleOverlay?.classList.add("show");
            schedulePanel?.setAttribute("aria-hidden", "false");
        }

        function closeSchedule() {
            schedulePanel?.classList.remove("show");
            scheduleOverlay?.classList.remove("show");
            schedulePanel?.setAttribute("aria-hidden", "true");
        }

        openSchedulePanel?.addEventListener("click", openSchedule);
        closeSchedulePanel?.addEventListener("click", closeSchedule);
        scheduleOverlay?.addEventListener("click", closeSchedule);

        document.addEventListener("keydown", function (event) {
            if (event.key === "Escape") {
                closeSchedule();
            }
        });

        function highlightCurrentWeekCell() {
            const now = new Date();
            const localDate = new Date(now.getTime() - now.getTimezoneOffset() * 60000);
            const day = localDate.toISOString().slice(0, 10);
            const hour = now.getHours();

            document.querySelectorAll(".meet-week-cell.current-hour").forEach(cell => {
                cell.classList.remove("current-hour");
            });

            const target = document.querySelector(`.meet-week-cell[data-day="${day}"][data-hour="${hour}"]`);

            if (target) {
                target.classList.add("current-hour");
            }
        }

        function updateMeetingStatuses() {
            const now = new Date();

            document.querySelectorAll("[data-meeting-start][data-meeting-end]").forEach(item => {
                const start = new Date(item.dataset.meetingStart);
                const end = new Date(item.dataset.meetingEnd);

                if (item.classList.contains("meet-week-event")) {
                    item.classList.toggle("live", now >= start && now <= end);
                    return;
                }

                const status = item.querySelector(".js-meeting-status");
                const countdown = item.querySelector(".js-meeting-countdown");

                if (!status) {
                    return;
                }

                status.className = "meet-status js-meeting-status";

                if (now >= start && now <= end) {
                    status.textContent = "Live";
                    status.classList.add("meet-status-live");

                    if (countdown) {
                        const minutesLeft = Math.max(1, Math.round((end - now) / 60000));
                        countdown.textContent = `Ends in ${minutesLeft} min`;
                    }

                    return;
                }

                if (now > end) {
                    status.textContent = "Ended";
                    status.classList.add("meet-status-ended");

                    if (countdown) {
                        countdown.textContent = "Time passed";
                    }

                    return;
                }

                const minutesToStart = Math.round((start - now) / 60000);

                if (minutesToStart <= 60) {
                    status.textContent = "Soon";

                    if (countdown) {
                        countdown.textContent = `Starts in ${Math.max(1, minutesToStart)} min`;
                    }

                    return;
                }

                const badgeText = item.querySelector(".meet-today-badge")?.textContent?.trim();
                status.textContent = badgeText === "TODAY" ? "Today" : "Upcoming";

                if (countdown) {
                    const hours = Math.floor(minutesToStart / 60);
                    const days = Math.floor(hours / 24);

                    countdown.textContent = days > 0
                        ? `Starts in ${days} day${days === 1 ? "" : "s"}`
                        : `Starts in ${hours} hour${hours === 1 ? "" : "s"}`;
                }
            });
        }

        highlightCurrentWeekCell();
        updateMeetingStatuses();

        setInterval(highlightCurrentWeekCell, 60000);
        setInterval(updateMeetingStatuses, 30000);
    </script>
}

@functions {
    private static string ModeLabel(string? mode)
    {
        return mode switch
        {
            "in_person" => "In-person",
            "hybrid" => "Hybrid",
            _ => "Online"
        };
    }

    private static string ModeIcon(string? mode)
    {
        return mode switch
        {
            "in_person" => "bi bi-geo-alt",
            "hybrid" => "bi bi-intersect",
            _ => "bi bi-camera-video"
        };
    }

    private static string DisplayStatus(FYPilot.Domain.Entities.Meeting meeting)
    {
        if (meeting.Status == "cancelled")
        {
            return "Cancelled";
        }

        if (meeting.Status == "completed")
        {
            return "Completed";
        }

        var now = DateTime.UtcNow;
        var end = meeting.ScheduledAt.AddMinutes(meeting.DurationMinutes);

        if (end < now)
        {
            return "Ended";
        }

        return "Scheduled";
    }

    private static string StatusClass(string? status)
    {
        return status switch
        {
            "completed" => "meet-status-completed",
            "cancelled" => "meet-status-cancelled",
            _ => "meet-status"
        };
    }

    private static string StatusDotClass(string? status)
    {
        return status switch
        {
            "cancelled" => "cancelled",
            _ => "completed"
        };
    }

    private static List<string> SplitLines(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return [];
        }

        return value
            .Split(new[] { '\n', '\r' }, StringSplitOptions.RemoveEmptyEntries)
            .Select(x => x.Trim())
            .Where(x => x.Length > 0)
            .ToList();
    }

    private static string Initials(string? name)
    {
        if (string.IsNullOrWhiteSpace(name))
        {
            return "ST";
        }

        var parts = name
            .Split(' ', StringSplitOptions.RemoveEmptyEntries)
            .Take(2)
            .ToList();

        return parts.Count == 0
            ? "ST"
            : string.Join("", parts.Select(p => p[0])).ToUpperInvariant();
    }

    private static string ShortText(string? value, int length)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return "No notes added yet.";
        }

        value = value.Trim().Replace("\r", " ").Replace("\n", " ");

        return value.Length <= length ? value : value[..length] + "...";
    }
}