@page
@model FYPilot.Web.Pages.Student.IdeaGeneratorModel
@{
    ViewData["Title"] = "AI Idea Generator";
    ViewData["Subtitle"] = "Discover validated FYP ideas tailored to your profile";
}

<div class="idea2-page">

    @if (!string.IsNullOrWhiteSpace(Model.SuccessMessage))
    {
        <div class="alert alert-success idea2-alert">
            <i class="bi bi-check-circle me-2"></i>
            @Model.SuccessMessage
        </div>
    }

    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="alert alert-danger idea2-alert">
            <i class="bi bi-exclamation-triangle me-2"></i>
            @Model.ErrorMessage
        </div>
    }

    <div class="idea2-layout">

        <section class="idea2-settings-card">
            <div class="idea2-settings-header">
                <div class="idea2-settings-icon">
                    <i class="bi bi-stars"></i>
                </div>

                <div>
                    <div class="idea2-kicker">Generation Settings</div>
                    <h2>Build your idea brief</h2>
                    <p>
                        Keep the settings simple. FYPilot will combine these inputs with your assessed skills.
                    </p>
                </div>
            </div>

            @if (!Model.HasAssessedSkills)
            {
                <div class="idea2-warning">
                    <div>
                        <strong>Skill Assessment Required</strong>
                        <span>Complete your skill assessment first so ideas match your real level.</span>
                    </div>

                    <a href="/Student/SkillAssessment" class="btn idea2-outline-btn">
                        Go to Skill Assessment
                    </a>
                </div>
            }

            <form method="post" class="idea2-settings-form">
                @Html.AntiForgeryToken()

                <div class="idea2-form-scroll">

                    <div class="idea2-field">
                        <label>Preferred Domain</label>
                        <select asp-for="Input.PreferredDomain" class="form-select idea2-control">
                            <option value="General Software System">General Software System</option>
                            <option value="Web Development">Web Development</option>
                            <option value="AI/Data Science">AI/Data Science</option>
                            <option value="Mobile Development">Mobile Development</option>
                            <option value="Cybersecurity">Cybersecurity</option>
                            <option value="Healthcare Technology">Healthcare Technology</option>
                            <option value="FinTech">FinTech</option>
                            <option value="Education Technology">Education Technology</option>
                            <option value="IoT / Embedded">IoT / Embedded</option>
                        </select>
                        <span asp-validation-for="Input.PreferredDomain" class="text-danger small"></span>
                    </div>

                    <div class="idea2-two-cols">
                        <div class="idea2-field">
                            <label>Experience</label>
                            <select asp-for="Input.ExperienceLevel" class="form-select idea2-control">
                                <option value="beginner">Beginner</option>
                                <option value="intermediate">Intermediate</option>
                                <option value="advanced">Advanced</option>
                            </select>
                            <span asp-validation-for="Input.ExperienceLevel" class="text-danger small"></span>
                        </div>

                        <div class="idea2-field">
                            <label>Difficulty</label>
                            <select asp-for="Input.TargetDifficulty" class="form-select idea2-control">
                                <option value="beginner">Beginner</option>
                                <option value="intermediate">Intermediate</option>
                                <option value="advanced">Advanced</option>
                            </select>
                            <span asp-validation-for="Input.TargetDifficulty" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="idea2-two-cols">
                        <div class="idea2-field">
                            <label>Hours / Week</label>
                            <input asp-for="Input.AvailableHours" type="number" min="1" max="60" class="form-control idea2-control" />
                            <span asp-validation-for="Input.AvailableHours" class="text-danger small"></span>
                        </div>

                        <div class="idea2-field">
                            <label>Team Size</label>
                            <select asp-for="Input.TeamSize" class="form-select idea2-control">
                                <option value="1">Solo</option>
                                <option value="2">2 members</option>
                                <option value="3">3 members</option>                         
                            </select>
                            <span asp-validation-for="Input.TeamSize" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="idea2-skills-panel">
                        <div class="d-flex align-items-center justify-content-between gap-2 mb-2">
                            <label class="mb-0">Assessed Skills Used</label>

                            <a href="/Student/SkillAssessment">
                                Update
                            </a>
                        </div>

                        @if (Model.AssessedSkills.Any())
                        {
                            <div class="idea2-skill-cloud">
                                @foreach (var skill in Model.AssessedSkills)
                                {
                                    <span>
                                        @skill.SkillName
                                        <b>@skill.Rating/5</b>
                                    </span>
                                }
                            </div>
                        }
                        else
                        {
                            <div class="idea2-empty-skills">
                                No assessed skills found.
                            </div>
                        }
                    </div>
                </div>

                <div class="idea2-generate-footer">
                    <button type="submit" class="btn idea2-primary-btn w-100" @(Model.HasAssessedSkills ? "" : "disabled")>
                        <i class="bi bi-magic me-2"></i>
                        Generate Ideas
                    </button>

                    <div class="idea2-small-note">
                        Ideas are saved automatically after generation.
                    </div>
                </div>
            </form>
        </section>

        <section class="idea2-results-card">
            @if (Model.GeneratedIdeas.Any())
            {
                <div class="idea2-results-header">
                    <div>
                        <div class="idea2-kicker">Generated Ideas</div>
                        <h2>Choose an idea to expand</h2>
                        <p>Click the arrow card to open details. Opening another idea closes the current one.</p>
                    </div>

                    <div class="idea2-toolbar">
                        <form method="post" asp-page-handler="Shuffle">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn idea2-outline-btn">
                                <i class="bi bi-shuffle me-1"></i>
                                Shuffle
                            </button>
                        </form>

                        <form method="post" asp-page-handler="Regenerate">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn idea2-soft-btn">
                                <i class="bi bi-arrow-clockwise me-1"></i>
                                Regenerate
                            </button>
                        </form>

                        <a href="/Student/IdeaComparison" class="btn idea2-outline-btn">
                            <i class="bi bi-bar-chart-line me-1"></i>
                            Compare
                        </a>
                    </div>
                </div>

                <div class="idea2-accordion" id="ideaAccordion">
                    @for (var i = 0; i < Model.GeneratedIdeas.Count; i++)
                    {
                        var idea = Model.GeneratedIdeas[i];

                        var requiresDataset =
                            !string.IsNullOrWhiteSpace(idea.DatasetNeeded) &&
                            !idea.DatasetNeeded.Equals("None", StringComparison.OrdinalIgnoreCase);

                        var collapseId = $"idea-details-{idea.Id}";
                        var headingId = $"idea-heading-{idea.Id}";
                        var isOpen = Model.OpenIdeaId.HasValue
                            ? idea.Id == Model.OpenIdeaId.Value
                            : i == 0;

                        Model.LatestMarketInsights.TryGetValue(idea.Id, out var marketInsight);
                        var hasReadyInsight = marketInsight is { OverallOpportunityScore: not null };
                        var feasibilityStatus = idea.FeasibilityScore >= 80
                            ? "Strong"
                            : idea.FeasibilityScore >= 60
                                ? "Moderate"
                                : "Developing";

                        <article class="idea2-idea-item">
                            <button class="idea2-idea-summary @(isOpen ? "" : "collapsed")"
                                    type="button"
                                    id="@headingId"
                                    data-bs-toggle="collapse"
                                    data-bs-target="#@collapseId"
                                    aria-expanded="@(isOpen ? "true" : "false")"
                                    aria-controls="@collapseId">

                                <div class="idea2-idea-number">
                                    0@(i + 1)
                                </div>

                                <div class="idea2-idea-title-area">
                                    <div class="idea2-idea-tags">
                                        <span>@idea.Domain</span>
                                        <span class="text-capitalize">@idea.DifficultyLevel</span>
                                        <span>@idea.ExpectedDurationWeeks weeks</span>

                                        @if (idea.IsSelected)
                                        {
                                            <span class="selected">Selected</span>
                                        }
                                    </div>

                                    <h3>@idea.Title</h3>

                                    <p>
                                        @(string.IsNullOrWhiteSpace(idea.ProblemStatement)
                                            ? "Open this idea to review its full details."
                                            : idea.ProblemStatement)
                                    </p>
                                </div>

                                <div class="idea2-score-mini-group marketfp-header-score-group">
                                    <div class="marketfp-mini-score is-feasibility"
                                         title="Feasibility estimate generated with this project idea.">
                                        <em>Feasibility</em>
                                        <strong>@idea.FeasibilityScore%</strong>
                                        <span>@feasibilityStatus</span>
                                    </div>

                                    @if (hasReadyInsight)
                                    {
                                        <div class="marketfp-mini-score is-evidence"
                                             title="Evidence-based regional opportunity score. It is not market share or expected revenue.">
                                            <em>Market Opportunity</em>
                                            <strong>@(marketInsight!.OverallOpportunityScore)%</strong>
                                            <span>Evidence-backed</span>
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="marketfp-mini-score is-preliminary"
                                             title="Preliminary estimate generated with the idea. Open the idea to run regional evidence analysis.">
                                            <em>Market</em>
                                            <strong>@idea.MarketDemandScore%</strong>
                                            <span>Preliminary</span>
                                        </div>
                                    }
                                </div>

                                <div class="idea2-arrow">
                                    <i class="bi bi-chevron-down"></i>
                                </div>
                            </button>

                            <div id="@collapseId"
                                 class="collapse @(isOpen ? "show" : "")"
                                 aria-labelledby="@headingId"
                                 data-bs-parent="#ideaAccordion">

                                <div class="idea2-details">

                                    <div class="idea2-detail-grid">
                                        <div class="idea2-detail-block wide">
                                            <label>Problem Statement</label>
                                            <p>@idea.ProblemStatement</p>
                                        </div>

                                        <div class="idea2-detail-block">
                                            <label>Target Users</label>
                                            <p>@idea.TargetUsers</p>
                                        </div>

                                        <div class="idea2-detail-block">
                                            <label>Why Useful</label>
                                            <p>@idea.WhyUseful</p>
                                        </div>

                                        <div class="idea2-detail-block">
                                            <label>Required Skills</label>
                                            <p>@idea.RequiredSkills</p>
                                        </div>

                                        <div class="idea2-detail-block">
                                            <label>Missing Skills</label>
                                            <p>@(string.IsNullOrWhiteSpace(idea.MissingSkills) ? "None" : idea.MissingSkills)</p>
                                        </div>

                                        <div class="idea2-detail-block wide">
                                            <label>Technologies</label>
                                            <p>@idea.RequiredTechnologies</p>
                                        </div>

                                        <div class="idea2-detail-block wide">
                                            <label>Lebanese Market Relevance</label>
                                            <p>@idea.LebaneseMarketRelevance</p>
                                        </div>

                                        <div class="idea2-detail-block">
                                            <label>Dataset Requirement</label>
                                            <p>@(requiresDataset ? idea.DatasetNeeded : "No dataset is required for this idea.")</p>
                                        </div>

                                        <div class="idea2-detail-block">
                                            <label>Final Deliverables</label>
                                            <p>@idea.FinalDeliverables</p>
                                        </div>
                                    </div>

                                    <div class="idea2-score-row">
                                        <div>
                                            <span>Innovation</span>
                                            <strong>@idea.InnovationScore%</strong>
                                            <div class="idea2-progress">
                                                <div style="width:@(idea.InnovationScore)%"></div>
                                            </div>
                                        </div>

                                        <div class="marketfp-preliminary-score-card">
                                            <span class="marketfp-preliminary-label">
                                                Preliminary Market Fit
                                                <i class="bi bi-info-circle"
                                                   tabindex="0"
                                                   data-bs-toggle="tooltip"
                                                   data-bs-placement="top"
                                                   title="This initial score is generated with the project idea. Market Insight performs a separate evidence-based analysis across Lebanon, MENA and the global market."></i>
                                            </span>
                                            <strong>@idea.MarketDemandScore%</strong>
                                            <div class="idea2-progress">
                                                <div style="width:@(idea.MarketDemandScore)%"></div>
                                            </div>
                                            <small class="marketfp-score-help">AI estimate before regional evidence</small>
                                        </div>

                                        <div>
                                            <span>Feasibility</span>
                                            <strong>@idea.FeasibilityScore%</strong>
                                            <div class="idea2-progress">
                                                <div style="width:@(idea.FeasibilityScore)%"></div>
                                            </div>
                                        </div>
                                    </div>

                                    <section class="marketfp-section">
                                        <div class="marketfp-head">
                                            <div class="marketfp-title-wrap">
                                                <span class="marketfp-icon-tile" aria-hidden="true">
                                                    <i class="bi bi-globe2"></i>
                                                </span>

                                                <div>
                                                    <h4>Market Insight</h4>
                                                    <p>Where this idea has the strongest evidence-based opportunity.</p>
                                                </div>
                                            </div>

                                            <span class="marketfp-status-badge @(hasReadyInsight ? "is-ready" : "is-pending")">
                                                <i class="bi @(hasReadyInsight ? "bi-patch-check" : "bi-hourglass-split")"></i>
                                                @(hasReadyInsight ? "Evidence-backed" : "Not analyzed")
                                            </span>
                                        </div>

                                        @{
                                            var showInlineError =
                                                Model.OpenIdeaId == idea.Id &&
                                                !string.IsNullOrWhiteSpace(Model.ErrorMessage) &&
                                                !hasReadyInsight;
                                        }

                                        @if (showInlineError)
                                        {
                                            <div class="marketfp-alert">
                                                <i class="bi bi-exclamation-triangle-fill mt-1"></i>
                                                <span>@Model.ErrorMessage</span>
                                            </div>
                                        }

                                        @if (!hasReadyInsight)
                                        {
                                            <div class="marketfp-empty">
                                                <div class="marketfp-empty-copy">
                                                    <span class="marketfp-empty-icon" aria-hidden="true">
                                                        <i class="bi bi-compass"></i>
                                                    </span>

                                                    <div>
                                                        <h5>Discover the idea’s strongest market</h5>

                                                        <p>
                                                            Compare verified opportunity signals across Lebanon,
                                                            MENA and the global market.
                                                        </p>

                                                        <div class="marketfp-region-pills" aria-label="Regions included in the analysis">
                                                            <span><i class="bi bi-geo-alt"></i> Lebanon</span>
                                                            <span><i class="bi bi-bounding-box-circles"></i> MENA</span>
                                                            <span><i class="bi bi-globe"></i> Global</span>
                                                        </div>
                                                    </div>
                                                </div>

                                                <div class="marketfp-empty-action">
                                                    <form method="post"
                                                          asp-page-handler="AnalyzeMarket"
                                                          data-marketfp-analyze-form>
                                                        @Html.AntiForgeryToken()
                                                        <input type="hidden" name="ideaId" value="@idea.Id" />

                                                        <button type="submit"
                                                                class="marketfp-btn"
                                                                data-marketfp-submit-btn
                                                                aria-busy="false">
                                                            <i class="bi bi-radar"></i>
                                                            <span data-marketfp-btn-label>Analyze Regional Demand</span>
                                                        </button>
                                                    </form>

                                                    <small>One research request analyzes all three regions.</small>
                                                </div>
                                            </div>

                                            <div class="marketfp-note">
                                                <i class="bi bi-info-circle" aria-hidden="true"></i>
                                                <span>
                                                    Regional percentages are normalized evidence-based opportunity
                                                    scores. They are not market share, revenue estimates or
                                                    probability of commercial success.
                                                </span>
                                            </div>
                                        }
                                        else
                                        {
                                            var snapshot = marketInsight!;
                                            var whyDemanded = IdeaGeneratorModel.ParseStringList(snapshot.WhyDemandedJson);
                                            var expansionPath = IdeaGeneratorModel.ParseStringList(snapshot.ExpansionPathJson);
                                            var limitations = IdeaGeneratorModel.ParseStringList(snapshot.LimitationsJson);
                                            var sources = IdeaGeneratorModel.ParseSources(snapshot.SourcesJson);
                                            var verifiedCount = sources.Count(s => s.IsVerified);
                                            var orderedRegions = snapshot.Regions
                                                .OrderBy(r => r.RegionKey == "lebanon" ? 0 : r.RegionKey == "mena" ? 1 : 2)
                                                .ToList();

                                            <div class="marketfp-panel">

                                                @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage) && Model.OpenIdeaId == idea.Id)
                                                {
                                                    <div class="marketfp-alert">
                                                        <i class="bi bi-exclamation-triangle-fill mt-1"></i>
                                                        <span>@Model.ErrorMessage</span>
                                                    </div>
                                                }

                                                <div class="marketfp-overall-grid">
                                                    <div class="marketfp-overall-card is-primary">
                                                        <div class="marketfp-label">
                                                            Market Opportunity
                                                            <i class="bi bi-info-circle marketfp-info-icon"
                                                               tabindex="0"
                                                               data-bs-toggle="tooltip"
                                                               data-bs-placement="top"
                                                               title="This is a normalized evidence-based regional opportunity score. It is not market share, revenue, or probability of commercial success."></i>
                                                        </div>
                                                        <strong>@(snapshot.OverallOpportunityScore)%</strong>
                                                        <span class="marketfp-tone">@snapshot.OverallDemandLevel opportunity</span>
                                                    </div>

                                                    <div class="marketfp-overall-card">
                                                        <div class="marketfp-label">Evidence confidence</div>
                                                        <strong>@(snapshot.OverallConfidenceScore)%</strong>
                                                        <span class="marketfp-tone">
                                                            @(snapshot.OverallConfidenceScore >= 80 ? "High" : snapshot.OverallConfidenceScore >= 55 ? "Medium" : "Low") confidence
                                                        </span>
                                                    </div>

                                                    <div class="marketfp-overall-card">
                                                        <div class="marketfp-label">Best launch market</div>
                                                        <strong class="marketfp-summary-text">@snapshot.BestLaunchMarket</strong>
                                                        <span class="marketfp-tone">Strongest starting point</span>
                                                    </div>

                                                    <div class="marketfp-overall-card">
                                                        <div class="marketfp-label">Expansion path</div>
                                                        <div class="marketfp-summary-path">
                                                            @for (var pathIndex = 0; pathIndex < expansionPath.Count; pathIndex++)
                                                            {
                                                                <span>@expansionPath[pathIndex]</span>

                                                                @if (pathIndex < expansionPath.Count - 1)
                                                                {
                                                                    <i class="bi bi-arrow-right"></i>
                                                                }
                                                            }
                                                        </div>
                                                        <span class="marketfp-tone">Recommended sequence</span>
                                                    </div>
                                                </div>

                                                <div class="marketfp-subhead">
                                                    <div>
                                                        <h5>Regional Demand Footprint</h5>
                                                        <p>Evidence-based opportunity by geography.</p>
                                                    </div>
                                                </div>

                                                <div class="marketfp-regions-grid">
                                                    @foreach (var region in orderedRegions)
                                                    {
                                                        var isBest = string.Equals(region.RegionName, snapshot.BestLaunchMarket, StringComparison.OrdinalIgnoreCase);
                                                        var levelClass = "level-" + region.DemandLevel.ToLowerInvariant().Replace(" ", "-");

                                                        <article class="marketfp-region-card @(isBest ? "is-best" : "")">
                                                            <div class="marketfp-region-head">
                                                                <h5>@region.RegionName</h5>

                                                                @if (isBest)
                                                                {
                                                                    <span class="marketfp-best-badge">
                                                                        <i class="bi bi-star-fill"></i>
                                                                        Best start
                                                                    </span>
                                                                }
                                                            </div>

                                                            <div class="marketfp-region-score">
                                                                @(region.OpportunityScore.HasValue ? $"{region.OpportunityScore}%" : "—")
                                                            </div>

                                                            <div class="marketfp-region-demand @levelClass">
                                                                <i class="bi bi-circle-fill"></i>
                                                                @region.DemandLevel opportunity
                                                            </div>

                                                            <div class="marketfp-region-meta">
                                                                <span>Confidence: @(region.ConfidenceScore)%</span>
                                                                <span class="text-capitalize">Competition: @region.CompetitionPressure</span>
                                                            </div>

                                                            <p>@region.EvidenceSummary</p>
                                                        </article>
                                                    }
                                                </div>

                                                @if (!string.IsNullOrWhiteSpace(snapshot.BestLaunchReason))
                                                {
                                                    <div class="marketfp-launch-rationale">
                                                        <span class="marketfp-rationale-icon" aria-hidden="true">
                                                            <i class="bi bi-geo-alt"></i>
                                                        </span>

                                                        <div>
                                                            <label>Why start in @snapshot.BestLaunchMarket?</label>
                                                            <p>@snapshot.BestLaunchReason</p>
                                                        </div>
                                                    </div>
                                                }

                                                @if (whyDemanded.Any())
                                                {
                                                    <div class="marketfp-insight-block">
                                                        <div class="marketfp-subhead">
                                                            <div>
                                                                <h5>Why this idea is demanded</h5>
                                                                <p>The strongest evidence signals behind the opportunity.</p>
                                                            </div>
                                                        </div>

                                                        <div class="marketfp-why-list">
                                                            @{
                                                                var demandIcons = new[]
                                                                {
                                                                    "bi-lightning-charge",
                                                                    "bi-people",
                                                                    "bi-graph-up-arrow"
                                                                };
                                                            }

                                                            @for (var reasonIndex = 0; reasonIndex < whyDemanded.Count; reasonIndex++)
                                                            {
                                                                <div class="marketfp-why-item">
                                                                    <span aria-hidden="true">
                                                                        <i class="bi @demandIcons[Math.Min(reasonIndex, demandIcons.Length - 1)]"></i>
                                                                    </span>
                                                                    <p>@whyDemanded[reasonIndex]</p>
                                                                </div>
                                                            }
                                                        </div>
                                                    </div>
                                                }

                                                @if (!string.IsNullOrWhiteSpace(snapshot.StrategicRecommendation))
                                                {
                                                    <div class="marketfp-recommendation">
                                                        <label>
                                                            <i class="bi bi-lightbulb"></i>
                                                            Recommended market path
                                                        </label>
                                                        <p>@snapshot.StrategicRecommendation</p>
                                                    </div>
                                                }

                                                @if (limitations.Any())
                                                {
                                                    <details class="marketfp-limitations">
                                                        <summary>
                                                            <i class="bi bi-shield-exclamation"></i>
                                                            Analysis limitations
                                                            <span>@limitations.Count</span>
                                                        </summary>

                                                        <ul>
                                                            @foreach (var limitation in limitations)
                                                            {
                                                                <li>@limitation</li>
                                                            }
                                                        </ul>
                                                    </details>
                                                }

                                                <div class="marketfp-evidence-status">
                                                    <div>
                                                        <span>Sources</span>
                                                        <strong>@sources.Count</strong>
                                                    </div>

                                                    <div>
                                                        <span>Recognized</span>
                                                        <strong>@verifiedCount</strong>
                                                    </div>

                                                    <div>
                                                        <span>Live research</span>
                                                        <strong>@(snapshot.GroundedInLiveData ? "Yes" : "Limited")</strong>
                                                    </div>

                                                    <div>
                                                        <span>Analyzed</span>
                                                        <strong>@snapshot.AnalyzedAt.ToLocalTime().ToString("MMM d, yyyy")</strong>
                                                    </div>
                                                </div>

                                                @if (sources.Any())
                                                {
                                                    <details class="marketfp-source-disclosure">
                                                        <summary>
                                                            <span>
                                                                <i class="bi bi-journal-text"></i>
                                                                View evidence sources
                                                            </span>
                                                            <small>@sources.Count source(s)</small>
                                                        </summary>

                                                        <ul class="marketfp-sources-list">
                                                            @foreach (var source in sources.Take(6))
                                                            {
                                                                <li>
                                                                    <div>
                                                                        <a href="@source.Url"
                                                                           target="_blank"
                                                                           rel="noopener noreferrer"
                                                                           title="@source.Title">
                                                                            @source.Title
                                                                        </a>

                                                                        @if (!string.IsNullOrWhiteSpace(source.Publisher))
                                                                        {
                                                                            <small>@source.Publisher</small>
                                                                        }
                                                                    </div>

                                                                    @if (source.IsVerified)
                                                                    {
                                                                        <span class="marketfp-verified-badge">
                                                                            <i class="bi bi-patch-check"></i>
                                                                            Recognized
                                                                        </span>
                                                                    }
                                                                </li>
                                                            }
                                                        </ul>
                                                    </details>
                                                }

                                                <div class="marketfp-actions">
                                                    <form method="post"
                                                          asp-page-handler="AnalyzeMarket"
                                                          data-marketfp-analyze-form>
                                                        @Html.AntiForgeryToken()
                                                        <input type="hidden" name="ideaId" value="@idea.Id" />

                                                        <button type="submit" class="marketfp-outline-btn" data-marketfp-submit-btn>
                                                            <i class="bi bi-arrow-clockwise"></i>
                                                            <span data-marketfp-btn-label>Refresh Insight</span>
                                                        </button>
                                                    </form>

                                                    <a href="/Student/MarketDemand?ideaId=@idea.Id" class="marketfp-link-btn">
                                                        <span>Open Full Yearly Intelligence</span>
                                                        <i class="bi bi-arrow-up-right"></i>
                                                    </a>
                                                </div>
                                            </div>
                                        }
                                    </section>

                                    <form method="post" asp-page-handler="Select" class="idea2-detail-actions">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="ideaId" value="@idea.Id" />

                                        <a href="/Student/ProjectDetails?id=@idea.Id" class="btn idea2-outline-btn">
                                            <i class="bi bi-eye me-1"></i>
                                            Details
                                        </a>

                                        <a href="/Student/ProjectDNA?ideaId=@idea.Id" class="btn idea2-outline-btn">
                                            <i class="bi bi-diagram-3 me-1"></i>
                                            DNA
                                        </a>

                                        <a href="/Student/Roadmap?ideaId=@idea.Id" class="btn idea2-outline-btn">
                                            <i class="bi bi-map me-1"></i>
                                            Roadmap
                                        </a>

                                        @if (!idea.IsSelected)
                                        {
                                            <button type="submit" class="btn idea2-primary-btn ms-auto">
                                                <i class="bi bi-check2-circle me-1"></i>
                                                Select Idea
                                            </button>
                                        }
                                        else
                                        {
                                            <span class="idea2-selected ms-auto">
                                                <i class="bi bi-check-circle me-1"></i>
                                                Selected
                                            </span>
                                        }
                                    </form>
                                </div>
                            </div>
                        </article>
                    }
                </div>
            }
            else
            {
                <div class="idea2-empty-state">
                    <div class="idea2-empty-icon">
                        <i class="bi bi-lightbulb"></i>
                    </div>

                    <h2>Generate your first FYP ideas</h2>

                    <p>
                        Your generated ideas will appear here as clean expandable cards.
                        Each idea opens in the same page without moving you away.
                    </p>

                    <div class="idea2-empty-hint">
                        <span>01</span> Set your preferences
                        <span>02</span> Confirm your assessed skills
                        <span>03</span> Generate ideas
                    </div>
                </div>
            }
        </section>
    </div>
</div>
