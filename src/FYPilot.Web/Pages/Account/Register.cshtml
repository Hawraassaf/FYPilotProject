@page
@model FYPilot.Web.Pages.Account.RegisterModel
@{
    Layout = null;
    ViewData["Title"] = "Create Account";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>Create Account — FYPilot</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <style>
        :root {
            --navy: #0f172a;
            --navy-medium: #17345f;
            --navy-light: #245a9b;
            --cream-light: #fffaf3;
            --page-background: linear-gradient(135deg, #0f172a 0%, #17345f 55%, #245a9b 100%);
        }

        body {
            margin: 0;
            min-height: 100vh;
            font-family: Inter, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Arial, sans-serif;
        }

        .auth-wrapper {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 2rem 1rem;
            background: var(--page-background);
        }

        .auth-card {
            width: 100% !important;
            max-width: 500px !important;
            padding: 2.75rem 3rem;
            border-radius: 26px;
            background: #F8FAFC;
            border: 1px solid rgba(255,255,255,0.22);
            box-shadow: 0 30px 85px rgba(2,6,23,0.36);
        }

        .auth-brand {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 0.75rem;
        }

        .auth-brand-logo {
            width: 54px;
            height: 54px;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
            flex-shrink: 0;
            border-radius: 17px;
            background: var(--page-background);
            box-shadow: 0 10px 24px rgba(15,23,42,0.18);
        }

        .auth-brand-logo img {
            width: 44px;
            height: 44px;
            object-fit: contain;
        }

        .auth-logo {
            color: var(--navy);
            font-size: 1.8rem;
            font-weight: 850;
            line-height: 1;
        }

        .form-label {
            color: var(--navy);
        }

        .form-control,
        .form-select {
            min-height: 48px;
            border-radius: 13px;
            border-color: #d8dee8;
        }

        .form-control:focus,
        .form-select:focus {
            border-color: var(--navy-medium);
            box-shadow: 0 0 0 0.2rem rgba(23,52,95,0.14);
        }

        .auth-link {
            color: var(--navy-medium);
            text-decoration: none;
            font-weight: 700;
            transition: color 0.18s ease;
        }

        .auth-link:hover {
            color: var(--navy);
            text-decoration: underline;
        }

        .btn-auth-primary {
            min-height: 50px;
            color: #ffffff;
            border: 0;
            border-radius: 14px;
            background: var(--page-background);
            box-shadow: 0 14px 30px rgba(23,52,95,0.22);
            transition: transform 0.18s ease, box-shadow 0.18s ease;
        }

        .btn-auth-primary:hover {
            color: #ffffff;
            transform: translateY(-1px);
            box-shadow: 0 18px 36px rgba(23,52,95,0.28);
        }

        .text-danger {
            font-size: 0.8rem;
        }

        @@media (max-width: 575px) {
            .auth-card {
                padding: 1.5rem;
                border-radius: 20px;
            }

            .auth-brand-logo {
                width: 48px;
                height: 48px;
            }

            .auth-brand-logo img {
                width: 39px;
                height: 39px;
            }

            .auth-logo {
                font-size: 1.55rem;
            }
        }
    </style>
</head>

<body>
    <div class="auth-wrapper">
        <div class="auth-card">
            <div class="text-center mb-4">
                <div class="auth-brand mb-2">
                    <div class="auth-brand-logo">
                        <img src="/image/FYPilot_logo.png" alt="FYPilot Logo" />
                    </div>

                    <div class="auth-logo">FYPilot</div>
                </div>

                <p class="text-muted small mb-0">Create your account</p>
            </div>

            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="alert alert-danger small">
                    <i class="bi bi-exclamation-triangle me-1"></i>
                    @Model.ErrorMessage
                </div>
            }

            <form method="post">
                <div class="mb-3">
                    <label class="form-label fw-semibold small">Full Name</label>

                    <input asp-for="Input.FullName"
                           class="form-control"
                           placeholder="Your full name"
                           autofocus />

                    <span asp-validation-for="Input.FullName" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-semibold small">Email address</label>

                    <input asp-for="Input.Email"
                           class="form-control"
                           type="email"
                           placeholder="you@example.com" />

                    <span asp-validation-for="Input.Email" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-semibold small">Password</label>

                    <input asp-for="Input.Password"
                           class="form-control"
                           type="password"
                           placeholder="Min. 6 characters" />

                    <span asp-validation-for="Input.Password" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-semibold small">Role</label>

                    <select asp-for="Input.Role" class="form-select">
                        <option value="student">Student</option>
                        <option value="supervisor">Supervisor</option>
                    </select>
                </div>

                <div class="d-grid mt-4">
                    <button type="submit" class="btn btn-auth-primary btn-lg fw-semibold">
                        <i class="bi bi-person-plus me-2"></i>
                        Create Account
                    </button>
                </div>
            </form>

            <hr class="my-4" />

            <div class="text-center small text-muted">
                Already have an account?

                <a asp-page="/Account/Login" class="auth-link">
                    Sign in
                </a>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
