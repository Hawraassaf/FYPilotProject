        .roadmap-gantt-label {
            display: grid;
            grid-template-columns: auto minmax(0, 1fr);
            align-items: center;
            gap: .5rem;
            min-height: 48px;
            padding: .55rem .65rem;
            color: inherit;
            text-align: left;
            background: #fff;
            border: 0;
            border-right: 1px solid var(--roadmap-border);
            border-bottom: 1px solid var(--roadmap-border);
