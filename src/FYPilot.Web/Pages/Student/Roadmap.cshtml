        .roadmap-gantt-bar.is-current {
            background: var(--roadmap-blue);
        }

        .roadmap-gantt-bar.is-upcoming {
            color: #435066;
            background: #dfe4ea;
        }

        .roadmap-details-card {
            overflow: hidden;
