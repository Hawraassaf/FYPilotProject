@page
@model FYPilot.Web.Pages.Student.RoadmapModel
@{
    ViewData["Title"] = "Project Roadmap";
    ViewData["Subtitle"] = "Evidence-based execution plan for your FYP";

    var done = Model.Phases.Count(p => p.IsCompleted);
    var total = Model.Phases.Count;
    var pct = total > 0 ? (int)(done * 100.0 / total) : 0;
}

@if (Model.Idea == null)
{
    <div class="empty-dna-layout">
        <div class="empty-dna-card">
            <div class="empty-dna-content">
                <div class="empty-dna-icon">
                    <i class="bi bi-map"></i>
                </div>

                <h1>No project idea selected yet</h1>

                <p>
                    Select one idea first, then return here to generate its project roadmap.
                    The roadmap will stay empty until an idea is selected.
                </p>

                <div class="empty-dna-actions">
                    <a class="btn btn-primary" asp-page="/Student/IdeaComparison">
                        <i class="bi bi-check2-circle me-2"></i>
                        Choose an Idea
                    </a>

                    <a class="btn btn-outline-secondary" asp-page="/Student/IdeaGenerator">
                        <i class="bi bi-stars me-2"></i>
                        Generate Ideas
                    </a>
                </div>
            </div>
        </div>
    </div>
}
else
{
    <section class="rm-page">

        @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
        {
            <div class="alert alert-warning rm-alert">
                <i class="bi bi-exclamation-triangle me-2"></i>
                @Model.ErrorMessage
            </div>
        }

        <div class="rm-hero-grid">
            <div class="rm-project-card">
                <div class="rm-project-head">
                    <div class="rm-project-icon">
                        <i class="bi bi-map"></i>
                    </div>

                    <div class="rm-project-title">
                        <div class="rm-kicker">Selected Project</div>
                        <h1>@Model.Idea.Title</h1>

                        <div class="rm-chip-row">
                            <span>@Model.Idea.Domain</span>
                            <span class="text-capitalize">@Model.Idea.DifficultyLevel</span>
                            <span>@Model.Idea.ExpectedDurationWeeks weeks total</span>
                        </div>
                    </div>
                </div>

                <p class="rm-project-desc">
                    @Model.Idea.ProblemStatement
                </p>

                <div class="rm-project-actions">
                    @if (!Model.Phases.Any())
                    {
                        <form method="post" asp-page-handler="Generate" id="rmGenerateForm">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="ideaId" value="@Model.Idea.Id" />

                            <button type="submit" class="btn rm-primary-btn">
                                <i class="bi bi-magic me-1"></i>
                                Generate AI Roadmap
                            </button>
                        </form>
                    }
                    else
                    {
                        <form method="post" asp-page-handler="Generate" id="rmGenerateForm">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="ideaId" value="@Model.Idea.Id" />

                            <button type="submit" class="btn rm-outline-btn">
                                <i class="bi bi-arrow-clockwise me-1"></i>
                                Regenerate Roadmap
                            </button>
                        </form>
                    }

                    <a href="/Student/ProjectDNA?ideaId=@Model.Idea.Id" class="btn rm-outline-btn">
                        <i class="bi bi-fingerprint me-1"></i>
                        View Project DNA
                    </a>
                </div>
            </div>

            <div class="rm-progress-card">
                <div class="rm-progress-ring">
                    <strong>@pct%</strong>
                    <span>Done</span>
                </div>

                <div>
                    <div class="rm-kicker">Roadmap Progress</div>
                    <h2>@done / @total phases complete</h2>
                    <p>
                        Mark phases as done when you complete their tasks and checkpoints.
                    </p>
                </div>

                <div class="rm-progress-line">
                    <div style="width:@pct%"></div>
                </div>
            </div>
        </div>

        @if (Model.Phases.Any())
        {
            <div class="rm-timeline-wrap">
                <div class="rm-timeline-head">
                    <div>
                        <div class="rm-kicker">Execution Timeline</div>
                        <h2>AI-generated weekly roadmap</h2>
                    </div>

                    <span class="rm-ai-badge">
                        <i class="bi bi-cpu"></i>
                        AI Roadmap Ready
                    </span>
                </div>

                <div class="rm-timeline">
                    @{
                        var orderedPhases = Model.Phases.OrderBy(p => p.PhaseNumber).ToList();
                    }

                    @for (var i = 0; i < orderedPhases.Count; i++)
                    {
                        var phase = orderedPhases[i];
                        var isLast = i == orderedPhases.Count - 1;

                        <div class="rm-phase-item @(phase.IsCompleted ? "completed" : "")">
                            <div class="rm-phase-marker">
                                <div class="rm-dot">
                                    @if (phase.IsCompleted)
                                    {
                                        <i class="bi bi-check-lg"></i>
                                    }
                                    else
                                    {
                                        @phase.PhaseNumber
                                    }
                                </div>

                                @if (!isLast)
                                {
                                    <div class="rm-line"></div>
                                }
                            </div>

                            <article class="rm-phase-card">
                                <div class="rm-phase-head">
                                    <div>
                                        <span class="rm-phase-number">Phase @phase.PhaseNumber</span>
                                        <h3>@phase.Name</h3>

                                        <div class="rm-phase-meta">
                                            <span>
                                                <i class="bi bi-calendar-week"></i>
                                                @phase.EstimatedWeeks week(s)
                                            </span>

                                            @if (!string.IsNullOrWhiteSpace(phase.Dependencies))
                                            {
                                                <span>
                                                    <i class="bi bi-link-45deg"></i>
                                                    @phase.Dependencies
                                                </span>
                                            }
                                        </div>
                                    </div>

                                    <div class="rm-phase-status">
                                        @if (phase.IsCompleted)
                                        {
                                            <span class="rm-completed-badge">
                                                <i class="bi bi-check-circle me-1"></i>
                                                Completed
                                            </span>
                                        }
                                        else
                                        {
                                            <form method="post" asp-page-handler="Complete">
                                                @Html.AntiForgeryToken()

                                                <input type="hidden"
                                                       name="phaseId"
                                                       value="@phase.Id" />

                                                <input type="hidden"
                                                       name="ideaId"
                                                       value="@Model.Idea!.Id" />

                                                <button type="submit"
                                                        class="btn rm-done-btn">
                                                    Mark Done
                                                </button>
                                            </form>
                                        }
                                    </div>
                                </div>

                                <p class="rm-objective">
                                    @phase.Objective
                                </p>

                                @if (!string.IsNullOrWhiteSpace(phase.TasksJson) && phase.TasksJson != "[]")
                                {
                                    var tasks = System.Text.Json.JsonSerializer.Deserialize<List<string>>(phase.TasksJson) ?? [];

                                    <div class="rm-task-block">
                                        <div class="rm-block-title">
                                            <i class="bi bi-list-check"></i>
                                            Tasks
                                        </div>

                                        <div class="rm-task-grid">
                                            @foreach (var task in tasks)
                                            {
                                                <div class="rm-task-item">
                                                    <i class="bi bi-check2"></i>
                                                    <span>@task</span>
                                                </div>
                                            }
                                        </div>
                                    </div>
                                }

                                <div class="rm-detail-grid">
                                    @if (!string.IsNullOrWhiteSpace(phase.ExpectedOutput))
                                    {
                                        <div class="rm-detail-box">
                                            <label>Expected Output</label>
                                            <p>@phase.ExpectedOutput</p>
                                        </div>
                                    }

                                    @if (!string.IsNullOrWhiteSpace(phase.SuccessCriteria))
                                    {
                                        <div class="rm-detail-box">
                                            <label>Success Criteria</label>
                                            <p>@phase.SuccessCriteria</p>
                                        </div>
                                    }

                                    @if (!string.IsNullOrWhiteSpace(phase.Risks))
                                    {
                                        <div class="rm-detail-box rm-risk-box">
                                            <label>
                                                <i class="bi bi-exclamation-triangle me-1"></i>
                                                Risk Warning
                                            </label>
                                            <p>@phase.Risks</p>
                                        </div>
                                    }
                                </div>
                            </article>
                        </div>
                    }
                </div>
            </div>
        }
        else
        {
            <section class="rm-start-card">
                <div class="rm-start-icon">
                    <i class="bi bi-magic"></i>
                </div>

                <h2>Generate your AI Roadmap</h2>

                <p>
                    Click <strong>Generate AI Roadmap</strong> above. FYPilot will use your selected idea,
                    skills, team size, available hours, and project scope to build a weekly execution plan.
                </p>

                <div class="rm-start-preview">
                    <div>
                        <i class="bi bi-1-circle"></i>
                        Scope and requirements
                    </div>

                    <div>
                        <i class="bi bi-2-circle"></i>
                        Weekly phases and tasks
                    </div>

                    <div>
                        <i class="bi bi-3-circle"></i>
                        Outputs, checkpoints, and risks
                    </div>
                </div>
            </section>
        }

        <div class="rm-loading-overlay d-none" id="rmLoadingOverlay">
            <div class="rm-loading-card">
                <div class="rm-loader-ring"></div>

                <h2>Generating AI Roadmap</h2>

                <p>
                    FYPilot is sending your selected project to the Python AI service and building your roadmap.
                </p>

                <div class="rm-loading-steps">
                    <div class="active">
                        <i class="bi bi-check2-circle"></i>
                        Reading selected idea
                    </div>

                    <div>
                        <i class="bi bi-cpu"></i>
                        Calling ProjectRoadmapAgent
                    </div>

                    <div>
                        <i class="bi bi-calendar-week"></i>
                        Creating weekly phases
                    </div>

                    <div>
                        <i class="bi bi-shield-exclamation"></i>
                        Adding risks and checkpoints
                    </div>
                </div>
            </div>
        </div>
    </section>
}
@section Head {
    <style>
        .empty-dna-layout {
            min-height: calc(100vh - 170px);
            display: grid;
            place-items: center;
            padding: 1.5rem;
        }

        .empty-dna-card {
            width: min(760px, 100%);
            min-height: 670px;
            display: grid;
            place-items: center;
            text-align: center;
            background: #ffffff;
            border: 1px solid #E8ECF2;
            border-radius: 28px;
            box-shadow: 0 24px 55px rgba(15, 23, 42, .08);
            padding: 2.5rem;
        }

        .empty-dna-content {
            max-width: 560px;
            margin: 0 auto;
        }

        .empty-dna-icon {
            width: 78px;
            height: 78px;
            display: grid;
            place-items: center;
            margin: 0 auto 1.35rem;
            border-radius: 26px;
            color: #516C8D;
            background: #EEF2F6;
            font-size: 2rem;
        }

        .empty-dna-content h1,
        .empty-dna-content h2 {
            margin: 0;
            color: #111827;
            font-size: clamp(1.9rem, 3vw, 2.55rem);
            line-height: 1.12;
            font-weight: 800;
            letter-spacing: -0.05em;
        }

        .empty-dna-content p {
            max-width: 540px;
            margin: 0.9rem auto 0;
            color: #64748B;
            font-size: 1rem;
            line-height: 1.65;
        }

        .empty-dna-actions {
            display: flex;
            justify-content: center;
            flex-wrap: wrap;
            gap: .65rem;
            margin-top: 1.35rem;
        }

            .empty-dna-actions .btn,
            .empty-dna-actions a {
                border-radius: 14px;
                padding: .72rem 1rem;
                font-size: .82rem;
                font-weight: 700;
            }

        @@media (max-width: 767px) {
            .empty-dna-layout {
                min-height: calc(100vh - 140px);
                padding: 1rem;
            }

            .empty-dna-card {
                min-height: 540px;
                padding: 1.5rem;
            }
        }

        .empty-dna-actions .btn-primary,
        .empty-dna-actions a.btn-primary {
            color: #ffffff !important;
            background: #28385E !important;
            border-color: #28385E !important;
            box-shadow: none !important;
        }

            .empty-dna-actions .btn-primary:hover,
            .empty-dna-actions a.btn-primary:hover {
                color: #ffffff !important;
                background: #304163 !important;
                border-color: #304163 !important;
            }

        .empty-dna-actions .btn-outline-secondary,
        .empty-dna-actions a.btn-outline-secondary {
            color: #28385E !important;
            background: #ffffff !important;
            border: 1px solid #E8ECF2 !important;
            box-shadow: none !important;
        }

            .empty-dna-actions .btn-outline-secondary:hover,
            .empty-dna-actions a.btn-outline-secondary:hover {
                color: #28385E !important;
                background: #EEF2F6 !important;
                border-color: #D8DEE9 !important;
            }
    </style>
}
@section Scripts {
    <script>
        const roadmapForm = document.getElementById("rmGenerateForm");
        const roadmapOverlay = document.getElementById("rmLoadingOverlay");

        if (roadmapForm && roadmapOverlay) {
            roadmapForm.addEventListener("submit", function () {
                roadmapOverlay.classList.remove("d-none");

                const steps = roadmapOverlay.querySelectorAll(".rm-loading-steps div");
                let currentStep = 0;

                setInterval(function () {
                    steps.forEach(step => step.classList.remove("active"));

                    if (steps[currentStep]) {
                        steps[currentStep].classList.add("active");
                    }

                    currentStep = (currentStep + 1) % steps.length;
                }, 900);
            });
        }
    </script>
}
