@page
@model FYPilot.Web.Pages.Student.MentorChatModel
@{
    ViewData["Title"]    = "Mentor Chat";
    ViewData["Subtitle"] = "AI-powered academic guidance for your FYP";
}

<div class="row g-4">
    <div class="col-lg-8">
        <div class="page-card d-flex flex-column" style="height:520px">
            <!-- Messages -->
            <div id="chat-messages" class="flex-grow-1 p-4 overflow-auto">
                @if (!Model.Messages.Any())
                {
                    <div class="text-center text-muted py-5">
                        <i class="bi bi-chat-dots display-4"></i>
                        <p class="mt-3">Ask anything about your FYP — feasibility, methodology, technologies, or proposal strategy.</p>
                    </div>
                }
                @foreach (var msg in Model.Messages)
                {
                    <div class="mb-3 d-flex @(msg.Role == "user" ? "justify-content-end" : "justify-content-start")">
                        <div class="px-3 py-2 rounded-3 @(msg.Role == "user" ? "bg-primary text-white" : "bg-light")"
                             style="max-width:80%;font-size:0.9rem">
                            @if (msg.Role == "assistant")
                            {
                                <div class="d-flex align-items-center gap-1 mb-1">
                                    <i class="bi bi-stars text-primary" style="font-size:0.75rem"></i>
                                    <span class="small fw-semibold text-primary">FYPilot Mentor</span>
                                </div>
                            }
                            <div>@msg.Content</div>
                            <div class="mt-1 @(msg.Role == "user" ? "text-white-50" : "text-muted-sm")" style="font-size:0.7rem">
                                @msg.CreatedAt.ToString("HH:mm")
                            </div>
                        </div>
                    </div>
                }
            </div>
            <!-- Input -->
            <div class="border-top p-3">
                <form method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="ideaId" value="@Model.SelectedIdeaId" />
                    <div class="d-flex gap-2">
                        <input type="text" name="message" class="form-control" placeholder="Ask your FYP mentor…" required autofocus />
                        <button type="submit" class="btn btn-primary px-3">
                            <i class="bi bi-send"></i>
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="page-card p-4 mb-3">
            <h6 class="fw-bold mb-3"><i class="bi bi-lightbulb me-2 text-warning"></i>Suggested Questions</h6>
            <div class="d-grid gap-2">
                @foreach (var q in new[] {
                    "Is my project idea feasible for a solo FYP?",
                    "What are the main risks in my project?",
                    "How should I structure my methodology?",
                    "Which technologies best fit my skill level?",
                    "How do I validate my dataset?",
                    "What makes a good FYP proposal?",
                    "How do I defend my idea against professors?",
                })
                {
                    <button type="button" class="btn btn-sm btn-outline-secondary text-start"
                            onclick="document.querySelector('[name=message]').value = this.textContent.trim()">
                        @q
                    </button>
                }
            </div>
        </div>

        @if (Model.Ideas.Any())
        {
            <div class="page-card p-4">
                <h6 class="fw-bold mb-2 small text-muted">DISCUSS ABOUT</h6>
                @foreach (var idea in Model.Ideas)
                {
                    <a href="/Student/MentorChat?ideaId=@idea.Id"
                       class="d-block p-2 rounded-2 mb-1 small @(idea.Id == Model.SelectedIdeaId ? "bg-primary-subtle text-primary fw-semibold" : "text-muted")">
                        <i class="bi bi-stars me-1"></i>@idea.Title
                    </a>
                }
            </div>
        }
    </div>
</div>

@section Scripts {
<script>
var msgs = document.getElementById('chat-messages');
if (msgs) msgs.scrollTop = msgs.scrollHeight;
</script>
}
