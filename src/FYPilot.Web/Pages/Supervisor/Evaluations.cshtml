            display: inline-flex;
            width: fit-content;
            border-radius: 999px;
            padding: 0.27rem 0.56rem;
            font-size: 0.7rem;
            font-weight: 600;
            white-space: nowrap;
        }

            .er-pill.pending {
                background: #FFF7ED;
                color: #9A3412;
            }

            .er-pill.approved,
            .er-pill.complete,
            .er-pill.safe {
                background: #ECFDF5;
                color: #047857;
            }

            .er-pill.revision,
            .er-pill.partial,
            .er-pill.medium {
                background: #FEF3C7;
                color: #92400E;
            }

            .er-pill.rejected,
            .er-pill.missing,
            .er-pill.high {
                background: #FEF2F2;
                color: #B91C1C;
            }

