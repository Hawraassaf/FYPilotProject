@page
@model FYPilot.Web.Pages.Student.MarketDemandModel
@using System.Text.Json
@{
    ViewData["Title"] = "Market Demand Intelligence";
    ViewData["Subtitle"] = "Evidence-backed yearly demand analysis for your project ideas";

    var analysis = Model.Analysis;
    var demandTone = analysis == null ? "neutral" : analysis.DemandScore >= 75 ? "good" : analysis.DemandScore >= 55 ? "warn" : "bad";
    var confidenceTone = analysis == null ? "neutral" : analysis.ConfidenceScore >= 75 ? "good" : analysis.ConfidenceScore >= 50 ? "warn" : "bad";
    var trendTone = analysis?.TrendDirection switch
    {
        "rising" => "good",
        "falling" => "bad",
        "unstable" => "warn",
        _ => "neutral"
    };
}

<style>
    :root {
        --md-ink: #102a43;
        --md-text: #334e68;
        --md-muted: #6b7c93;
        --md-primary: #2457e6;
        --md-primary-dark: #173e70;
        --md-bg: #f4f7fb;
        --md-card: #fff;
        --md-border: #dfe8f3;
        --md-good: #118a66;
        --md-warn: #c98105;
        --md-bad: #c84444;
        --md-shadow: 0 14px 36px rgba(27, 54, 93, .07);
    }

    .md-page {
        background: var(--md-bg);
        border-radius: 24px;
        padding: 22px;
        min-height: calc(100vh - 80px);
    }

    .md-hero {
        position: relative;
        overflow: hidden;
        padding: 28px;
        border-radius: 22px;
        color: #fff;
        background: linear-gradient(125deg, #102a43 0%, #173e70 55%, #2457e6 130%);
        box-shadow: var(--md-shadow);
        margin-bottom: 16px;
    }

        .md-hero::after {
            content: "";
            position: absolute;
            width: 230px;
            height: 230px;
            right: -65px;
            top: -120px;
            border-radius: 50%;
            background: rgba(255,255,255,.09);
        }

    .md-kicker {
        font-size: .72rem;
        font-weight: 900;
        letter-spacing: .12em;
        text-transform: uppercase;
        color: #a9c3ff;
        margin-bottom: 6px;
    }

    .md-hero h1 {
        margin: 0 0 7px;
        font-weight: 900;
        font-size: clamp(1.65rem, 3vw, 2.35rem);
    }

    .md-hero p {
        max-width: 760px;
        margin: 0;
        color: rgba(255,255,255,.78);
    }

    .md-card,
    .md-toolbar,
    .md-why {
        background: var(--md-card);
        border: 1px solid var(--md-border);
        border-radius: 18px;
        box-shadow: var(--md-shadow);
    }

    .md-why {
        padding: 18px;
        margin-bottom: 16px;
    }

    .md-why-head {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 14px;
    }

    .md-icon-box {
        width: 42px;
        height: 42px;
        border-radius: 13px;
        display: grid;
        place-items: center;
        color: var(--md-primary);
        background: #edf3ff;
        flex: 0 0 auto;
    }

    .md-why-grid {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 10px;
    }

    .md-why-item {
        background: #f8fafd;
        border: 1px solid #e7edf5;
        border-radius: 14px;
        padding: 13px;
    }

        .md-why-item strong {
            display: block;
            color: var(--md-ink);
            margin-bottom: 3px;
        }

        .md-why-item span {
            color: var(--md-muted);
            font-size: .86rem;
        }

    .md-toolbar {
        padding: 14px;
        margin-bottom: 16px;
    }

    .md-toolbar-grid {
        display: grid;
        grid-template-columns: minmax(280px, 1.6fr) minmax(140px, .55fr) minmax(130px, .45fr) minmax(130px, .45fr) auto;
        gap: 10px;
        align-items: end;
    }

    .md-field label {
        display: block;
        margin-bottom: 6px;
        color: var(--md-ink);
        font-size: .74rem;
        font-weight: 850;
    }

    .md-control {
        min-height: 44px;
        border: 1px solid var(--md-border);
        border-radius: 12px;
        background: #fbfcfe;
        font-weight: 650;
    }

    .md-btn {
        min-height: 44px;
        border: 0;
        border-radius: 12px;
        padding: 0 17px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        color: #fff;
        font-weight: 850;
        background: linear-gradient(135deg, var(--md-primary), #173eae);
        box-shadow: 0 10px 20px rgba(36,87,230,.2);
    }

        .md-btn:hover {
            color: #fff;
            transform: translateY(-1px);
        }

    .md-project {
        padding: 4px 2px 14px;
    }

        .md-project h2 {
            color: var(--md-ink);
            margin: 0 0 4px;
            font-weight: 900;
        }

        .md-project p {
            color: var(--md-muted);
            margin: 0;
        }

    .md-kpis {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 12px;
        margin-bottom: 14px;
    }

    .md-kpi {
        padding: 16px;
        min-height: 128px;
    }

    .md-kpi-label {
        font-size: .69rem;
        letter-spacing: .09em;
        text-transform: uppercase;
        font-weight: 900;
        color: var(--md-muted);
    }

    .md-kpi-value {
        color: var(--md-ink);
        font-size: 1.8rem;
        font-weight: 900;
        margin: 10px 0 9px;
        line-height: 1;
    }

        .md-kpi-value small {
            font-size: .72rem;
            color: var(--md-muted);
        }

    .md-pill {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 6px 9px;
        border-radius: 999px;
        font-size: .72rem;
        font-weight: 850;
    }

        .md-pill.good {
            color: var(--md-good);
            background: #e7f7f1;
        }

        .md-pill.warn {
            color: var(--md-warn);
            background: #fff4d7;
        }

        .md-pill.bad {
            color: var(--md-bad);
            background: #fff0f0;
        }

        .md-pill.neutral {
            color: #50657d;
            background: #edf2f7;
        }

    .md-main-grid {
        display: grid;
        grid-template-columns: minmax(0, 1.65fr) minmax(280px, .72fr);
        gap: 14px;
        margin-bottom: 14px;
    }

    .md-card {
        padding: 18px;
    }

    .md-card-head {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 12px;
        margin-bottom: 14px;
    }

        .md-card-head h3 {
            margin: 0 0 3px;
            color: var(--md-ink);
            font-weight: 900;
        }

        .md-card-head p {
            margin: 0;
            color: var(--md-muted);
            font-size: .86rem;
        }

    .md-chart {
        min-height: 350px;
    }

    .md-forecast-list {
        display: grid;
        gap: 9px;
    }

    .md-forecast-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 10px;
        padding: 11px;
        border-radius: 12px;
        background: #f8fafd;
        border: 1px solid #e7edf5;
    }

        .md-forecast-row strong {
            color: var(--md-ink);
        }

        .md-forecast-row span {
            color: var(--md-primary);
            font-weight: 900;
        }

    .md-note {
        margin-top: 12px;
        padding: 11px 12px;
        border-radius: 12px;
        background: #fff8e7;
        color: #7d5a08;
        font-size: .84rem;
    }

    .md-two {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 14px;
        margin-bottom: 14px;
    }

    .md-prose {
        color: var(--md-text);
        line-height: 1.65;
        margin: 0;
    }

    .md-list {
        display: grid;
        gap: 8px;
        margin: 0;
        padding: 0;
        list-style: none;
    }

        .md-list li {
            display: flex;
            gap: 9px;
            padding: 10px 11px;
            border-radius: 11px;
            background: #f8fafd;
            border: 1px solid #e7edf5;
            color: var(--md-text);
        }

        .md-list i {
            color: var(--md-good);
            margin-top: 2px;
        }

        .md-list.risk i {
            color: var(--md-warn);
        }

    .md-details {
        margin-bottom: 10px;
        overflow: hidden;
    }

        .md-details summary {
            list-style: none;
            cursor: pointer;
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 10px;
            color: var(--md-ink);
            font-weight: 900;
        }

            .md-details summary::-webkit-details-marker {
                display: none;
            }

        .md-details[open] summary {
            margin-bottom: 14px;
        }

    .md-detail-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0,1fr));
        gap: 10px;
    }

    .md-detail-item {
        padding: 12px;
        border-radius: 12px;
        background: #f8fafd;
        border: 1px solid #e7edf5;
    }

        .md-detail-item h4 {
            color: var(--md-ink);
            font-size: .9rem;
            font-weight: 900;
            margin: 0 0 5px;
        }

        .md-detail-item p {
            color: var(--md-muted);
            font-size: .84rem;
            margin: 0;
        }

    .md-source-link {
        display: inline-flex;
        gap: 5px;
        margin-top: 8px;
        color: var(--md-primary);
        text-decoration: none;
        font-size: .8rem;
        font-weight: 850;
    }

    .md-empty {
        text-align: center;
        padding: 46px 20px;
    }

        .md-empty i {
            font-size: 2rem;
            color: var(--md-primary);
        }

        .md-empty h2 {
            color: var(--md-ink);
            font-weight: 900;
            margin: 12px 0 6px;
        }

        .md-empty p {
            color: var(--md-muted);
            max-width: 650px;
            margin: 0 auto 18px;
        }

    .md-alert {
        border: 0;
        border-radius: 14px;
        box-shadow: var(--md-shadow);
    }

    @@media (max-width: 1180px) {
        .md-toolbar-grid {
            grid-template-columns: 1fr 1fr 1fr;
        }

        .md-main-grid {
            grid-template-columns: 1fr;
        }

        .md-why-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @@media (max-width: 760px) {
        .md-page {
            padding: 12px;
            border-radius: 16px;
        }

        .md-toolbar-grid,
        .md-kpis,
        .md-two,
        .md-why-grid,
        .md-detail-grid {
            grid-template-columns: 1fr;
        }

        .md-chart {
            min-height: 300px;
        }
    }
</style>

<div class="md-page">
    @if (!string.IsNullOrWhiteSpace(Model.SuccessMessage))
    {
        <div class="alert alert-success md-alert">
            <i class="bi bi-check-circle me-2"></i>@Model.SuccessMessage
        </div>
    }
    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="alert alert-danger md-alert">
            <i class="bi bi-exclamation-triangle me-2"></i>@Model.ErrorMessage
        </div>
    }

    <section class="md-hero">
        <div class="position-relative" style="z-index:1">
            <div class="md-kicker">Market intelligence</div>
            <h1>Yearly Market Demand Validation</h1>
            <p>
                Measure the current need, build a source-backed annual demand index,
                and forecast the next years without treating repeated app refreshes as market history.
            </p>
        </div>
    </section>

    <section class="md-why">
        <div class="md-why-head">
            <div class="md-icon-box"><i class="bi bi-compass"></i></div>
            <div>
                <h2 class="h5 mb-1 fw-bold">Why do we need to know market demand?</h2>
                <p class="text-muted mb-0 small">It turns a project idea into a defensible product and research decision.</p>
            </div>
        </div>
        <div class="md-why-grid">
            <div class="md-why-item"><strong>Prove the problem</strong><span>Show that target users face a real, documented need.</span></div>
            <div class="md-why-item"><strong>Choose the right scope</strong><span>Prioritize features that match adoption and sector priorities.</span></div>
            <div class="md-why-item"><strong>Reduce project risk</strong><span>Detect weak demand, crowded competition, or evidence gaps early.</span></div>
            <div class="md-why-item"><strong>Defend your decisions</strong><span>Use sources, annual trends, and transparent scoring in the defense.</span></div>
        </div>
    </section>

    @if (!Model.UserIdeas.Any())
    {
        <section class="md-card md-empty">
            <i class="bi bi-lightbulb"></i>
            <h2>No project ideas found</h2>
            <p>Generate an idea first, then return here to validate its market demand.</p>
            <a asp-page="/Student/IdeaGenerator" class="md-btn text-decoration-none">Open Idea Generator</a>
        </section>
    }
    else
    {
        <section class="md-toolbar">
            <form method="post" asp-page-handler="Analyze">
                @Html.AntiForgeryToken()
                <div class="md-toolbar-grid">
                    <div class="md-field">
                        <label>Project idea</label>
                        <select asp-for="IdeaId" class="form-select md-control">
                            @foreach (var item in Model.UserIdeas)
                            {
                                <option value="@item.Id">@item.Title</option>
                            }
                        </select>
                    </div>
                    <div class="md-field">
                        <label>Market scope</label>
                        <select asp-for="CountryContext" class="form-select md-control">
                            <option value="Lebanon">Lebanon</option>
                            <option value="MENA">MENA</option>
                            <option value="Global">Global</option>
                        </select>
                    </div>
                    <div class="md-field">
                        <label>History window</label>
                        <select asp-for="HistoryYears" class="form-select md-control">
                            <option value="4">4 years</option>
                            <option value="5">5 years</option>
                            <option value="6">6 years</option>
                            <option value="8">8 years</option>
                            <option value="10">10 years</option>
                        </select>
                    </div>
                    <div class="md-field">
                        <label>Forecast</label>
                        <select asp-for="ForecastYears" class="form-select md-control">
                            <option value="2">2 years</option>
                            <option value="3">3 years</option>
                            <option value="4">4 years</option>
                            <option value="5">5 years</option>
                        </select>
                    </div>
                    <button type="submit" class="md-btn">
                        <i class="bi bi-search"></i>
                        @(analysis == null ? "Analyze" : "Refresh")
                    </button>
                </div>
            </form>
        </section>

        @if (Model.Idea != null)
        {
            <section class="md-project">
                <div class="md-kicker text-primary mb-1">Selected idea</div>
                <h2 class="h4">@Model.Idea.Title</h2>
                <p>@Model.Idea.ProblemStatement</p>
            </section>
        }

        @if (analysis == null)
        {
            <section class="md-card md-empty">
                <i class="bi bi-graph-up-arrow"></i>
                <h2>Ready for market validation</h2>
                <p>
                    The analysis will use live sources, calculate the current evidence score,
                    extract defensible annual signals, and forecast only when enough yearly data exists.
                </p>
            </section>
        }
        else
        {
            <section class="md-kpis">
                <article class="md-card md-kpi">
                    <div class="md-kpi-label">Current demand</div>
                    <div class="md-kpi-value">@analysis.DemandScore<small>/100</small></div>
                    <span class="md-pill @demandTone"><i class="bi bi-speedometer2"></i>@analysis.MarketDemand</span>
                </article>
                <article class="md-card md-kpi">
                    <div class="md-kpi-label">Evidence confidence</div>
                    <div class="md-kpi-value">@analysis.ConfidenceScore<small>/100</small></div>
                    <span class="md-pill @confidenceTone"><i class="bi bi-shield-check"></i>@analysis.ConfidenceLevel</span>
                </article>
                <article class="md-card md-kpi">
                    <div class="md-kpi-label">Annual trend</div>
                    <div class="md-kpi-value">
                        @(analysis.TrendSlopePerYear?.ToString("+0.0;-0.0;0.0") ?? "—")
                        <small> pts/year</small>
                    </div>
                    <span class="md-pill @trendTone"><i class="bi bi-activity"></i>@analysis.TrendDirection</span>
                </article>
                <article class="md-card md-kpi">
                    <div class="md-kpi-label">Source-backed years</div>
                    <div class="md-kpi-value">@Model.SourceBackedYearCount<small> years</small></div>
                    <span class="md-pill @(analysis.GroundedInLiveData ? "good" : "warn")"><i class="bi bi-globe2"></i>@analysis.Sources.Count real sources</span>
                </article>
            </section>

            <section class="md-main-grid">
                <article class="md-card">
                    <div class="md-card-head">
                        <div>
                            <h3 class="h5">Historical yearly demand and forecast</h3>
                            <p>Observed annual evidence indices and future prediction intervals.</p>
                        </div>
                        <span class="md-pill @(analysis.ForecastReliable ? "good" : analysis.ForecastReady ? "warn" : "neutral")">
                            <i class="bi bi-stars"></i>
                            @(analysis.ForecastReliable ? "Reliable forecast" : analysis.ForecastReady ? "Early forecast" : "Forecast not ready")
                        </span>
                    </div>
                    <div class="md-chart"><canvas id="annualChart"></canvas></div>
                    <div class="md-note"><i class="bi bi-info-circle me-1"></i>@Model.HistoricalDataNote</div>
                </article>

                <aside class="md-card">
                    <div class="md-card-head">
                        <div>
                            <h3 class="h5">Forecast summary</h3>
                            <p>Next-year demand index estimates.</p>
                        </div>
                    </div>

                    @if (analysis.ForecastReady && Model.ForecastPoints.Any())
                    {
                        <div class="md-forecast-list">
                            @foreach (var point in Model.ForecastPoints.OrderBy(item => item.Year))
                            {
                                <div class="md-forecast-row">
                                    <strong>@point.Year</strong>
                                    <span>@point.PredictedScore.ToString("0.0")</span>
                                </div>
                            }
                        </div>
                        <hr />
                        <p class="small text-muted mb-1"><strong>Model:</strong> @(analysis.ForecastModel ?? "—")</p>
                        <p class="small text-muted mb-1"><strong>Validation MAE:</strong> @(analysis.ForecastMae?.ToString("0.00") ?? "—")</p>
                        <p class="small text-muted mb-0"><strong>R²:</strong> @(analysis.TrendRSquared?.ToString("0.000") ?? "—")</p>
                    }
                    else
                    {
                        <div class="md-note mt-0">
                            <strong>No forecast yet.</strong><br />
                            At least four distinct, source-backed years spanning three years are required.
                        </div>
                    }

                    @if (!string.IsNullOrWhiteSpace(analysis.ForecastWarning))
                    {
                        <div class="md-note">@analysis.ForecastWarning</div>
                    }
                </aside>
            </section>

            <section class="md-two">
                <article class="md-card">
                    <div class="md-card-head"><div><h3 class="h5">Market fit</h3><p>How well the idea matches the selected scope.</p></div></div>
                    <p class="md-prose">@analysis.LebaneseMarketFit</p>
                </article>
                <article class="md-card">
                    <div class="md-card-head"><div><h3 class="h5">Recommendation</h3><p>The strongest next decision for this idea.</p></div></div>
                    <p class="md-prose">@analysis.Recommendation</p>
                </article>
            </section>

            <section class="md-two">
                <article class="md-card">
                    <div class="md-card-head"><div><h3 class="h5">Problem evidence</h3><p>Why the target problem is real.</p></div></div>
                    <ul class="md-list">
                        @foreach (var item in Model.ProblemEvidence.Take(5))
                        {
                            <li><i class="bi bi-check-circle-fill"></i><span>@item</span></li>
                        }
                    </ul>
                </article>
                <article class="md-card">
                    <div class="md-card-head"><div><h3 class="h5">Main risks</h3><p>Adoption, evidence, and competition concerns.</p></div></div>
                    <ul class="md-list risk">
                        @foreach (var item in Model.Risks.Take(5))
                        {
                            <li><i class="bi bi-exclamation-triangle-fill"></i><span>@item</span></li>
                        }
                    </ul>
                </article>
            </section>

            <details class="md-card md-details" open>
                <summary><span><i class="bi bi-calendar3 me-2"></i>Annual evidence timeline</span><span class="md-pill neutral">@analysis.YearlyPoints.Count years</span></summary>
                <div class="md-detail-grid">
                    @foreach (var point in analysis.YearlyPoints.OrderByDescending(item => item.Year))
                    {
                        <div class="md-detail-item">
                            <div class="d-flex justify-content-between gap-2 mb-1">
                                <h4>@point.Year</h4>
                                <span class="md-pill @(point.ConfidenceScore >= 70 ? "good" : point.ConfidenceScore >= 45 ? "warn" : "bad")">@point.DemandIndex.ToString("0.0") / 100</span>
                            </div>
                            <p>@point.EvidenceSummary</p>
                            <div class="small text-muted mt-2">Confidence: @point.ConfidenceScore/100</div>
                        </div>
                    }
                </div>
            </details>

            <details class="md-card md-details">
                <summary><span><i class="bi bi-bar-chart me-2"></i>Score breakdown</span><span class="md-pill neutral">5 factors</span></summary>
                <div style="min-height:300px"><canvas id="breakdownChart"></canvas></div>
            </details>

            <details class="md-card md-details">
                <summary><span><i class="bi bi-compass me-2"></i>Qualitative signals and similar solutions</span><span class="md-pill neutral">Research detail</span></summary>
                <div class="md-detail-grid">
                    @foreach (var signal in analysis.TrendSignals)
                    {
                        <div class="md-detail-item">
                            <h4>@signal.Topic <span class="md-pill @(signal.Direction == "rising" ? "good" : signal.Direction == "falling" ? "bad" : "neutral")">@signal.Direction</span></h4>
                            <p>@signal.Evidence</p>
                            @if (!string.IsNullOrWhiteSpace(signal.SourceUrl))
                            {
                                <a class="md-source-link" href="@signal.SourceUrl" target="_blank" rel="noopener noreferrer">Open evidence <i class="bi bi-box-arrow-up-right"></i></a>
                            }
                        </div>
                    }
                    @foreach (var solution in analysis.SimilarSolutions)
                    {
                        <div class="md-detail-item">
                            <h4>@solution.Name <span class="md-pill neutral">@solution.Similarity similarity</span></h4>
                            <p>@solution.Description</p>
                        </div>
                    }
                </div>
            </details>

            <details class="md-card md-details">
                <summary><span><i class="bi bi-journal-check me-2"></i>Next steps</span><span class="md-pill neutral">Action plan</span></summary>
                <ul class="md-list">
                    @foreach (var item in Model.NextSteps)
                    {
                        <li><i class="bi bi-arrow-right-circle-fill"></i><span>@item</span></li>
                    }
                </ul>
            </details>

            <details class="md-card md-details">
                <summary><span><i class="bi bi-globe2 me-2"></i>Real research sources</span><span class="md-pill @(analysis.GroundedInLiveData ? "good" : "warn")">@analysis.Sources.Count sources</span></summary>
                <div class="md-detail-grid">
                    @foreach (var source in analysis.Sources.OrderByDescending(item => item.IsVerified).ThenByDescending(item => item.RelevanceScore))
                    {
                        <div class="md-detail-item">
                            <div class="d-flex justify-content-between gap-2">
                                <h4>@source.Title</h4>
                                <span class="md-pill @(source.IsVerified ? "good" : "neutral")">@(source.IsVerified ? "Recognized" : source.SourceType)</span>
                            </div>
                            <p>@source.Relevance</p>
                            <a class="md-source-link" href="@source.Url" target="_blank" rel="noopener noreferrer">Open source <i class="bi bi-box-arrow-up-right"></i></a>
                        </div>
                    }
                </div>
            </details>
        }
    }
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.7/dist/chart.umd.min.js"></script>
    <script>
        (() => {
        const annual = @Html.Raw(Model.AnnualChartJson);
        const annualCanvas = document.getElementById("annualChart");

        if (annualCanvas && typeof Chart !== "undefined") {
        const labels = annual.map(item => String(item.year));
        const observed = annual.map(item => item.observed);
        const forecast = annual.map(item => item.forecast);
        const lower = annual.map(item => item.lower);
        const upper = annual.map(item => item.upper);

        new Chart(annualCanvas, {
        type: "line",
        data: {
        labels,
        datasets: [
        {
        label: "Observed annual demand index",
        data: observed,
        borderColor: "#2457e6",
        backgroundColor: "rgba(36,87,230,.10)",
        borderWidth: 3,
        pointRadius: 5,
        pointHoverRadius: 7,
        tension: .28
        },
        {
        label: "Forecast lower bound",
        data: lower,
        borderColor: "rgba(112,78,170,.30)",
        borderDash: [4,4],
        pointRadius: 0,
        borderWidth: 1
        },
        {
        label: "Forecast upper bound",
        data: upper,
        borderColor: "rgba(112,78,170,.30)",
        backgroundColor: "rgba(112,78,170,.12)",
        borderDash: [4,4],
        pointRadius: 0,
        borderWidth: 1,
        fill: "-1"
        },
        {
        label: "Forecast annual demand index",
        data: forecast,
        borderColor: "#704eaa",
        borderDash: [8,5],
        borderWidth: 3,
        pointRadius: 5,
        tension: .24
        }
        ]
        },
        options: {
        responsive: true,
        maintainAspectRatio: false,
        interaction: { mode: "index", intersect: false },
        plugins: { legend: { labels: { usePointStyle: true } } },
        scales: {
        x: { grid: { display: false }, title: { display: true, text: "Year" } },
        y: { beginAtZero: true, max: 100, title: { display: true, text: "Evidence demand index" } }
        }
        }
        });
        }

        const breakdown = @Html.Raw(Model.BreakdownJson);
        const breakdownCanvas = document.getElementById("breakdownChart");
        if (breakdownCanvas && typeof Chart !== "undefined") {
        new Chart(breakdownCanvas, {
        type: "bar",
        data: {
        labels: breakdown.map(item => item.label),
        datasets: [{
        label: "Score",
        data: breakdown.map(item => item.value),
        backgroundColor: ["#2457e6", "#118a66", "#704eaa", "#d08a13", "#28a4bd"],
        borderRadius: 8
        }]
        },
        options: {
        indexAxis: "y",
        responsive: true,
        maintainAspectRatio: false,
        plugins: { legend: { display: false } },
        scales: {
        x: { beginAtZero: true, max: 100 },
        y: { grid: { display: false } }
        }
        }
        });
        }
        })();
    </script>
}
