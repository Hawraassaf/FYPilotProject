@page
@model FYPilot.Web.Pages.Student.MentorChatModel
@{
    ViewData["Title"] = "Mentor Chat";
    ViewData["Subtitle"] = "AI-powered academic guidance for your FYP";

    var selectedIdeaTitle = Model.SelectedIdea?.Title ?? "No project selected";
    var selectedDomain = Model.SelectedIdea?.Domain ?? "Choose an idea first";
}

<section class="fyc-page">

    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="alert alert-warning fyc-alert">
            <i class="bi bi-exclamation-triangle me-2"></i>
            @Model.ErrorMessage
        </div>
    }

    <header class="fyc-top">
        <div class="fyc-brand">
            <div class="fyc-logo">
                <i class="bi bi-stars"></i>
            </div>

            <div class="min-w-0">
                <h1>FYPilot Mentor</h1>
                <p>Ask anything about your final year project</p>
            </div>
        </div>

        <div class="fyc-project">
            <i class="bi bi-lightbulb"></i>

            <div class="min-w-0">
                <span>Project context</span>
                <strong title="@selectedIdeaTitle">@selectedIdeaTitle</strong>
                <small>@selectedDomain</small>
            </div>
        </div>
    </header>

    <main class="fyc-chat-shell">

        <div id="fycMessages" class="fyc-messages">
            <div class="fyc-thread" id="fycThread">

                @if (!Model.Messages.Any())
                {
                    <section class="fyc-welcome">
                        <div class="fyc-welcome-icon">
                            <i class="bi bi-chat-dots"></i>
                        </div>

                        <h2>How can I help with your project?</h2>

                        <p>
                            Ask about next steps, risks, code, roadmap, methodology, testing, documentation, or defense.
                        </p>

                        <div class="fyc-starters">
                            <button type="button" data-prompt="What should I work on next?">
                                <i class="bi bi-rocket-takeoff"></i>
                                What should I work on next?
                            </button>

                            <button type="button" data-prompt="What are the main risks in my project?">
                                <i class="bi bi-shield-exclamation"></i>
                                What are the main risks?
                            </button>

                            <button type="button" data-prompt="Help me plan the implementation of my project.">
                                <i class="bi bi-tools"></i>
                                Help me plan implementation
                            </button>

                            <button type="button" data-prompt="How should I defend this idea in front of professors?">
                                <i class="bi bi-mortarboard"></i>
                                How do I defend this idea?
                            </button>
                        </div>
                    </section>
                }

                @foreach (var msg in Model.Messages)
                {
                    var isUser = msg.Role == "user";
                    var isServiceNotice =
                        msg.Role == "assistant" &&
                        msg.Content.Contains("Python AI service", StringComparison.OrdinalIgnoreCase);

                    <div class="fyc-msg @(isUser ? "is-user" : "is-ai") @(isServiceNotice ? "is-service" : "")">
                        <div class="fyc-avatar @(isUser ? "is-user" : "is-ai")">
                            <i class="bi @(isUser ? "bi-person" : "bi-stars")"></i>
                        </div>

                        <article class="fyc-bubble">
                            @if (!isUser)
                            {
                                <div class="fyc-meta">
                                    <strong>FYPilot Mentor</strong>
                                    <span>@(isServiceNotice ? "Service notice" : "AI guidance")</span>
                                </div>
                            }

                            <div class="fyc-text">@msg.Content</div>

                            <time>@msg.CreatedAt.ToString("HH:mm")</time>
                        </article>
                    </div>
                }
            </div>
        </div>

        <form method="post" asp-page-handler="Send" id="fycForm" class="fyc-composer">
            @Html.AntiForgeryToken()

            <input type="hidden" name="ideaId" value="@Model.SelectedIdeaId" />

            <div class="fyc-composer-box">
                <textarea asp-for="MessageText"
                          id="mentorMessage"
                          class="form-control fyc-input"
                          rows="1"
                          placeholder="Message FYPilot Mentor..."
                          required
                          autofocus></textarea>

                <button type="submit" class="btn fyc-send" aria-label="Send message">
                    <i class="bi bi-arrow-up"></i>
                </button>
            </div>

            <div class="fyc-note">
                Paste code directly in the chat. The mentor will understand it from your message.
            </div>
        </form>
    </main>
</section>

@section Scripts {
    <script>
        const fycMessages = document.getElementById("fycMessages");
        const fycThread = document.getElementById("fycThread");
        const fycInput = document.getElementById("mentorMessage");
        const fycForm = document.getElementById("fycForm");

        function scrollMentorToBottom() {
            if (fycMessages) {
                fycMessages.scrollTop = fycMessages.scrollHeight;
            }
        }

        function resizeMentorInput() {
            if (!fycInput) {
                return;
            }

            fycInput.style.height = "auto";
            fycInput.style.height = Math.min(fycInput.scrollHeight, 150) + "px";
        }

        function getCurrentTime() {
            const now = new Date();
            return now.toLocaleTimeString([], {
                hour: "2-digit",
                minute: "2-digit"
            });
        }

        scrollMentorToBottom();
        resizeMentorInput();

        if (fycInput) {
            fycInput.addEventListener("input", resizeMentorInput);

            fycInput.addEventListener("keydown", function (event) {
                if (event.key === "Enter" && !event.shiftKey) {
                    event.preventDefault();

                    if (fycForm) {
                        fycForm.requestSubmit();
                    }
                }
            });
        }

        document.querySelectorAll("[data-prompt]").forEach(button => {
            button.addEventListener("click", function () {
                if (!fycInput) {
                    return;
                }

                fycInput.value = this.dataset.prompt;
                resizeMentorInput();
                fycInput.focus();
            });
        });

        if (fycForm && fycThread && fycInput) {
            fycForm.addEventListener("submit", function (event) {
                event.preventDefault();

                const value = fycInput.value.trim();

                if (!value) {
                    return;
                }

                // Prevent double submit
                const sendButton = fycForm.querySelector("button[type='submit']");
                if (sendButton) {
                    sendButton.disabled = true;
                }

                // 1. Show the user's message immediately, before backend reload
                const userRow = document.createElement("div");
                userRow.className = "fyc-msg is-user";
                userRow.innerHTML = `
                    <div class="fyc-avatar is-user">
                        <i class="bi bi-person"></i>
                    </div>

                    <article class="fyc-bubble">
                        <div class="fyc-text"></div>
                        <time>${getCurrentTime()}</time>
                    </article>
                `;

                userRow.querySelector(".fyc-text").textContent = value;
                fycThread.appendChild(userRow);

                // 2. Show the small loading bubble inside the chat
                const thinkingRow = document.createElement("div");
                thinkingRow.className = "fyc-msg is-ai is-thinking";
                thinkingRow.innerHTML = `
                    <div class="fyc-avatar is-ai">
                        <i class="bi bi-stars"></i>
                    </div>

                    <article class="fyc-bubble fyc-thinking-bubble">
                        <div class="fyc-meta">
                            <strong>FYPilot Mentor</strong>
                            <span>Thinking</span>
                        </div>

                        <div class="fyc-thinking">
                            <span></span>
                            <span></span>
                            <span></span>
                        </div>
                    </article>
                `;

                fycThread.appendChild(thinkingRow);

                // 3. Clear the visible textarea immediately
                fycInput.value = "";
                fycInput.style.height = "auto";

                scrollMentorToBottom();

                // 4. Send the original message to backend using hidden input
                const oldHiddenMessage = fycForm.querySelector("input[data-temp-message='true']");
                if (oldHiddenMessage) {
                    oldHiddenMessage.remove();
                }

                const hiddenMessage = document.createElement("input");
                hiddenMessage.type = "hidden";
                hiddenMessage.name = "MessageText";
                hiddenMessage.value = value;
                hiddenMessage.setAttribute("data-temp-message", "true");
                fycForm.appendChild(hiddenMessage);

                // Remove name from textarea so backend receives only hidden MessageText
                fycInput.removeAttribute("name");

                // Small delay so user can see his message + loading bubble
                setTimeout(function () {
                    HTMLFormElement.prototype.submit.call(fycForm);
                }, 500);
            });
        }
    </script>
}
