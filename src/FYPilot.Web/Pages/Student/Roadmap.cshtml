        }

        .roadmap-gantt-label strong {
            font-size: .7rem;
            line-height: 1.25;
            overflow-wrap: anywhere;
        }

        .roadmap-gantt-track {
            position: relative;
            display: grid;
            grid-template-columns: repeat(var(--week-count), minmax(42px, 1fr));
            align-items: center;
            min-height: 48px;
            background-image:
                repeating-linear-gradient(
                    to right,
                    transparent,
                    transparent calc((100% / var(--week-count)) - 1px),
                    var(--roadmap-border) calc((100% / var(--week-count)) - 1px),
                    var(--roadmap-border) calc(100% / var(--week-count))
                );
            border-bottom: 1px solid var(--roadmap-border);
