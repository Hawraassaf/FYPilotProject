        .roadmap-detail-panel h3 {
            margin: .25rem 0 .35rem;
            font-size: clamp(1.2rem, 2vw, 1.55rem);
            font-weight: 800;
        }

        .roadmap-detail-panel > .roadmap-detail-header p {
            max-width: 720px;
            margin: 0;
            color: var(--roadmap-muted);
            line-height: 1.6;
        }

        .roadmap-complete-badge {
            display: inline-flex;
            align-items: center;
            gap: .35rem;
            padding: .5rem .65rem;
            color: var(--roadmap-success);
            background: var(--roadmap-success-soft);
            border-radius: 10px;
            font-size: .76rem;
            font-weight: 800;
        }

        .roadmap-phase-facts {
            display: grid;
            grid-template-columns: repeat(3, minmax(0, 1fr));
            gap: .6rem;
            margin: 1rem 0;
        }

        .roadmap-phase-facts div {
            min-width: 0;
            padding: .7rem .75rem;
            background: #f7f9fb;
            border: 1px solid var(--roadmap-border);
            border-radius: 11px;
        }

        .roadmap-phase-facts span,
        .roadmap-info-box span {
            display: block;
            margin-bottom: .2rem;
            color: var(--roadmap-muted);
            font-size: .66rem;
            font-weight: 800;
