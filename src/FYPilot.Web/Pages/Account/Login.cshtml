@page
@model FYPilot.Web.Pages.Account.LoginModel
@{
    Layout = null;
    ViewData["Title"] = "Sign In";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Sign In — FYPilot</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
<div class="auth-wrapper">
    <div class="auth-card">
        <div class="text-center mb-4">
            <div class="auth-logo mb-1">FYPilot</div>
            <p class="text-muted small">Academic Intelligence System</p>
        </div>

        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="alert alert-danger small"><i class="bi bi-exclamation-triangle me-1"></i>@Model.ErrorMessage</div>
        }

        <form method="post">
                @if (TempData["PasswordResetMessage"] is string passwordResetMessage)
                {
                    <div id="passwordResetAlert" class="alert alert-success small mb-3">
                        <i class="bi bi-check-circle me-1"></i>
                        @passwordResetMessage
                    </div>
                }
            <div class="mb-3">
                <label class="form-label fw-semibold small">Email address</label>
                <input asp-for="Input.Email" class="form-control" type="email" placeholder="you@example.com" autofocus />
            </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold small">Password</label>
                    <input asp-for="Input.Password" class="form-control" type="password" placeholder="••••••••" />

                    <div class="text-end mt-1">
                        <a asp-page="/Account/ForgotPassword" class="small">Forgot your password?</a>
                    </div>
                </div>
            <div class="d-grid mt-4">
                <button type="submit" class="btn btn-primary btn-lg fw-semibold">
                    <i class="bi bi-box-arrow-in-right me-2"></i>Sign In
                </button>
            </div>
        </form>

        <hr class="my-4" />
        <div class="text-center small text-muted">
            Don't have an account? <a href="/Account/Register" class="fw-semibold">Create one</a>
        </div>

        <div class="mt-4 p-3 rounded-3" style="background:#f8fafc;border:1px solid #e2e8f0">
            <div class="small fw-semibold text-muted mb-2">Demo Accounts (password: password123)</div>
            <div class="d-flex flex-column gap-1">
                <button type="button" class="btn btn-sm btn-outline-secondary text-start" onclick="fillDemo('student@fyp.com')">
                    <i class="bi bi-person-badge me-1"></i>student@fyp.com
                </button>
                <button type="button" class="btn btn-sm btn-outline-secondary text-start" onclick="fillDemo('supervisor@fyp.com')">
                    <i class="bi bi-person-check me-1"></i>supervisor@fyp.com
                </button>
                <button type="button" class="btn btn-sm btn-outline-secondary text-start" onclick="fillDemo('admin@fyp.com')">
                    <i class="bi bi-shield-check me-1"></i>admin@fyp.com
                </button>
            </div>
        </div>
    </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script>
function fillDemo(email) {
    document.querySelector('[name="Input.Email"]').value = email;
    document.querySelector('[name="Input.Password"]').value = 'password123';
}
        setTimeout(function () {
        const alertBox = document.getElementById("passwordResetAlert");

        if (alertBox) {
        alertBox.style.transition = "opacity 0.5s ease";
        alertBox.style.opacity = "0";

        setTimeout(function () {
        alertBox.remove();
        }, 500);
        }
        }, 3000);
</script>
</body>
</html>
