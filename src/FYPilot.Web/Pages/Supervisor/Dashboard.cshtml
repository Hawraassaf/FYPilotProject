@page
@using System
@using System.Linq
@using System.Collections.Generic
@model FYPilot.Web.Pages.Supervisor.IdeaReviewModel
@{
    ViewData["Title"] = "Supervisor Dashboard";
    ViewData["Subtitle"] = "Review student ideas, guide progress, and manage meetings.";

    var totalIdeas = Model.AllIdeas.Count;

    var pendingIdeas = Model.AllIdeas.Count(i => NormalizeStatus(i.Status) == "pending");
    var revisionIdeas = Model.AllIdeas.Count(i => NormalizeStatus(i.Status) == "needs_revision");
    var approvedIdeas = Model.AllIdeas.Count(i => NormalizeStatus(i.Status) == "approved");
    var rejectedIdeas = Model.AllIdeas.Count(i => NormalizeStatus(i.Status) == "rejected");

    var actionNeeded = pendingIdeas + revisionIdeas;
    var atRiskProjects = revisionIdeas + rejectedIdeas;

    var activeStudents = Model.AllIdeas
        .Select(i => ValueOrStudent(i.StudentName))
        .Distinct(StringComparer.OrdinalIgnoreCase)
        .Count();

    var priorityIdeas = Model.AllIdeas
        .Where(i => NormalizeStatus(i.Status) == "pending" || NormalizeStatus(i.Status) == "needs_revision")
        .OrderByDescending(i => NormalizeStatus(i.Status) == "needs_revision")
        .ThenBy(i => i.CreatedAt)
        .Take(4)
        .ToList();

    var studentRows = Model.AllIdeas
        .GroupBy(i => ValueOrStudent(i.StudentName), StringComparer.OrdinalIgnoreCase)
        .Select(g => new
        {
            Name = g.Key,
            Latest = g.OrderByDescending(x => x.CreatedAt).First(),
            Ideas = g.Count(),
            Pending = g.Count(x => NormalizeStatus(x.Status) == "pending"),
            Revision = g.Count(x => NormalizeStatus(x.Status) == "needs_revision"),
            Approved = g.Count(x => NormalizeStatus(x.Status) == "approved"),
            Rejected = g.Count(x => NormalizeStatus(x.Status) == "rejected"),
            LastActivity = g.Max(x => x.CreatedAt)
        })
        .OrderByDescending(x => x.Pending + x.Revision + x.Rejected)
        .ThenByDescending(x => x.LastActivity)
        .Take(5)
        .ToList();

    var followUpRows = studentRows
        .Where(s => s.Pending + s.Revision + s.Rejected > 0)
        .Take(3)
        .ToList();

    if (!followUpRows.Any())
    {
        followUpRows = studentRows.Take(3).ToList();
    }
}

<section class="sd-page">

    <header class="sd-hero">
        <div>
            <span class="sd-eyebrow">Supervisor Dashboard</span>
            <h1>Review, guide, and follow up with your assigned students.</h1>
            <p>
                A focused workspace for pending reviews, student follow-up, meetings,
                and academic supervision decisions.
            </p>

            <div class="sd-hero-actions">
                <a href="/Supervisor/IdeaReview" class="sd-hero-btn primary">
                    <i class="bi bi-journal-check"></i>
                    Review workspace
                </a>

                <a href="/Supervisor/Meetings" class="sd-hero-btn light">
                    <i class="bi bi-calendar-plus"></i>
                    Schedule meeting
                </a>
            </div>
        </div>

        <div class="sd-hero-focus">
            <span>@actionNeeded</span>
            <small>items need attention</small>
        </div>
    </header>

    @if (!Model.AllIdeas.Any())
    {
        <section class="sd-empty">
            <div class="sd-empty-icon">
                <i class="bi bi-inbox"></i>
            </div>

            <h2>No assigned student ideas yet</h2>
            <p>
                Once your assigned students submit ideas, their reviews and follow-up
                items will appear here.
            </p>

            <a href="/Supervisor/IdeaReview" class="sd-hero-btn primary">
                Open review workspace
            </a>
        </section>
    }
    else
    {
        <section class="sd-stats">
            <article class="sd-stat-card">
                <div class="sd-stat-icon orange">
                    <i class="bi bi-hourglass-split"></i>
                </div>

                <div>
                    <small>Pending Reviews</small>
                    <strong>@pendingIdeas</strong>
                    <span>Needs your attention</span>
                </div>

                <i class="bi bi-chevron-right sd-stat-arrow"></i>
            </article>

            <article class="sd-stat-card">
                <div class="sd-stat-icon blue">
                    <i class="bi bi-people"></i>
                </div>

                <div>
                    <small>Students Assigned</small>
                    <strong>@activeStudents</strong>
                    <span>Under your supervision</span>
                </div>

                <i class="bi bi-chevron-right sd-stat-arrow"></i>
            </article>

            <article class="sd-stat-card">
                <div class="sd-stat-icon green">
                    <i class="bi bi-check2-circle"></i>
                </div>

                <div>
                    <small>Approved Ideas</small>
                    <strong>@approvedIdeas</strong>
                    <span>Ready to progress</span>
                </div>

                <i class="bi bi-chevron-right sd-stat-arrow"></i>
            </article>

            <article class="sd-stat-card">
                <div class="sd-stat-icon red">
                    <i class="bi bi-exclamation-triangle"></i>
                </div>

                <div>
                    <small>At-Risk Projects</small>
                    <strong>@atRiskProjects</strong>
                    <span>Requires follow-up</span>
                </div>

                <i class="bi bi-chevron-right sd-stat-arrow"></i>
            </article>
        </section>

        <section class="sd-grid-top">

            <article class="sd-panel">
                <div class="sd-panel-head">
                    <div>
                        <span class="sd-eyebrow">Priority</span>
                        <h2>Priority Review Queue</h2>
                    </div>

                    <a href="/Supervisor/IdeaReview">View all (@actionNeeded)</a>
                </div>

                @if (!priorityIdeas.Any())
                {
                    <div class="sd-soft-empty">
                        <i class="bi bi-check2-circle"></i>
                        <p>No pending reviews right now.</p>
                    </div>
                }
                else
                {
                    <div class="sd-review-list">
                        @foreach (var idea in priorityIdeas)
                        {
                            var status = StatusMeta(idea.Status);

                            <a href="/Supervisor/IdeaReview?ideaId=@idea.Id" class="sd-review-card">
                                <div class="sd-avatar">@Initials(idea.StudentName)</div>

                                <div class="sd-review-main">
                                    <div class="sd-review-top">
                                        <span>@ValueOrStudent(idea.StudentName)</span>
                                        <small>Submitted @TimeAgo(idea.CreatedAt)</small>
                                    </div>

                                    <h3>@idea.Title</h3>

                                    <div class="sd-chip-row">
                                        <b class="@status.ClassName">@status.Label</b>
                                        <span>@ValueOrDash(idea.Domain)</span>
                                        <span>@ValueOrDash(idea.DifficultyLevel)</span>
                                    </div>
                                </div>

                                <i class="bi bi-chevron-right sd-card-arrow"></i>
                            </a>
                        }
                    </div>
                }
            </article>

            <article class="sd-panel">
                <div class="sd-panel-head">
                    <div>
                        <span class="sd-eyebrow">Quick Actions</span>
                        <h2>Supervision Tools</h2>
                    </div>
                </div>

                <div class="sd-action-grid">
                    <a href="/Supervisor/IdeaReview" class="sd-action-tile">
                        <i class="bi bi-journal-check"></i>
                        <div>
                            <strong>Review Workspace</strong>
                            <small>Approve, request changes, or provide feedback.</small>
                        </div>
                    </a>

                    <a href="/Supervisor/Meetings" class="sd-action-tile">
                        <i class="bi bi-calendar-plus"></i>
                        <div>
                            <strong>Schedule Meeting</strong>
                            <small>Plan follow-up or review sessions.</small>
                        </div>
                    </a>

                    <a href="/Supervisor/IdeaReview" class="sd-action-tile">
                        <i class="bi bi-chat-dots"></i>
                        <div>
                            <strong>Message Students</strong>
                            <small>Send academic guidance and feedback.</small>
                        </div>
                    </a>

                    <a href="/Supervisor/ProgressTracking" class="sd-action-tile">
                        <i class="bi bi-bar-chart-line"></i>
                        <div>
                            <strong>Track Progress</strong>
                            <small>Check progress, risks, and next steps.</small>
                        </div>
                    </a>
                </div>
            </article>

        </section>

        <section class="sd-grid-bottom">

            <article class="sd-panel">
                <div class="sd-panel-head">
                    <div>
                        <span class="sd-eyebrow">Students</span>
                        <h2>Student Follow-up Overview</h2>
                    </div>

                    <a href="/Supervisor/ProgressTracking">View progress</a>
                </div>

                @if (!studentRows.Any())
                {
                    <div class="sd-soft-empty">
                        <p>No student activity yet.</p>
                    </div>
                }
                else
                {
                    <div class="sd-student-list">
                        @foreach (var student in studentRows)
                        {
                            var needsAction = student.Pending + student.Revision + student.Rejected;
                            var studentStatus = StudentStatus(student.Pending, student.Revision, student.Rejected, student.Approved);

                            <a href="/Supervisor/IdeaReview?ideaId=@student.Latest.Id" class="sd-student-row">
                                <div class="sd-avatar small">@Initials(student.Name)</div>

                                <div class="sd-student-info">
                                    <strong>@student.Name</strong>
                                    <small>@student.Ideas project@(student.Ideas == 1 ? "" : "s")</small>
                                </div>

                                <div class="sd-student-status">
                                    <span class="@studentStatus.ClassName">@studentStatus.Label</span>
                                </div>

                                <div class="sd-next-action">
                                    <i class="@studentStatus.Icon"></i>
                                    <div>
                                        <strong>@NextActionLabel(student.Pending, student.Revision, student.Rejected)</strong>
                                        <small>@TimeAgo(student.LastActivity)</small>
                                    </div>
                                </div>

                                <i class="bi bi-chevron-right sd-card-arrow"></i>
                            </a>
                        }
                    </div>
                }
            </article>

            <article class="sd-panel">
                <div class="sd-panel-head">
                    <div>
                        <span class="sd-eyebrow">Follow-up</span>
                        <h2>Upcoming Meetings</h2>
                    </div>

                    <a href="/Supervisor/Meetings">View calendar</a>
                </div>

                <div class="sd-meeting-list">
                    @if (!followUpRows.Any())
                    {
                        <div class="sd-soft-empty compact">
                            <i class="bi bi-calendar-check"></i>
                            <p>No follow-up needed right now.</p>
                        </div>
                    }
                    else
                    {
                        var index = 0;

                        @foreach (var student in followUpRows)
                        {
                            index++;
                            var meetingStatus = StudentStatus(student.Pending, student.Revision, student.Rejected, student.Approved);

                            <a href="/Supervisor/Meetings" class="sd-meeting-row">
                                <div class="sd-date-box">
                                    <span>Next</span>
                                    <strong>@index.ToString("00")</strong>
                                </div>

                                <div class="sd-meeting-main">
                                    <strong>@student.Name</strong>
                                    <small>@MeetingPurpose(student.Pending, student.Revision, student.Rejected)</small>
                                    <p>@NextMeetingHint(student.Pending, student.Revision, student.Rejected)</p>
                                </div>

                                <span class="@meetingStatus.ClassName">@meetingStatus.Label</span>

                                <i class="bi bi-three-dots-vertical sd-dots"></i>
                            </a>
                        }
                    }
                </div>
            </article>

        </section>
    }
</section>

