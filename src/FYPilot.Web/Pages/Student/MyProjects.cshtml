@page
@model FYPilot.Web.Pages.Student.MyProjectsModel
@{
    ViewData["Title"] = "My Projects";
    ViewData["Subtitle"] =
    "Choose a project and open its dedicated workspace.";
}

<section class="my-projects-page">
    @if (!string.IsNullOrWhiteSpace(Model.SuccessMessage))
    {
        <div class="projects-alert projects-alert-success"
             role="status">
            <i class="bi bi-check-circle-fill"></i>

            <span>@Model.SuccessMessage</span>

            <button type="button"
                    class="alert-close-button"
                    aria-label="Close message">
                <i class="bi bi-x-lg"></i>
            </button>
        </div>
    }

    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="projects-alert projects-alert-error"
             role="alert">
            <i class="bi bi-exclamation-circle-fill"></i>

            <span>@Model.ErrorMessage</span>

            <button type="button"
                    class="alert-close-button"
                    aria-label="Close message">
                <i class="bi bi-x-lg"></i>
            </button>
        </div>
    }

    <header class="projects-hero">
        <div class="projects-hero-content">
            <span class="page-eyebrow">
                Project management
            </span>

            <h1>My Projects</h1>

            <p>
                Manage the projects you own and the teams you
                collaborate with. Each project keeps its own idea,
                analysis, roadmap, documentation and progress.
            </p>

            <div class="hero-feature-list">
                <span>
                    <i class="bi bi-shield-check"></i>
                    Secure project access
                </span>

                <span>
                    <i class="bi bi-people"></i>
                    Shared collaboration
                </span>

                <span>
                    <i class="bi bi-grid"></i>
                    Dedicated project dashboard
                </span>
            </div>
        </div>

        <form method="post"
              asp-page-handler="CreateProject"
              class="create-project-form">

            <button type="submit"
                    class="create-project-button">

                <span class="create-button-icon">
                    <i class="bi bi-plus-lg"></i>
                </span>

                <span>
                    <strong>Create New Project</strong>
                    <small>
                        Start with an untitled project
                    </small>
                </span>
            </button>
        </form>

        <div class="hero-orb hero-orb-one"></div>
        <div class="hero-orb hero-orb-two"></div>
    </header>

    <div class="project-statistics">
        <article class="stat-card">
            <div class="stat-icon stat-icon-blue">
                <i class="bi bi-folder2-open"></i>
            </div>

            <div class="stat-content">
                <span>Total Projects</span>
                <strong>@Model.TotalProjects</strong>
                <small>All active memberships</small>
            </div>

            <div class="stat-decoration stat-decoration-blue">
                <i class="bi bi-grid-1x2-fill"></i>
            </div>
        </article>

        <article class="stat-card">
            <div class="stat-icon stat-icon-green">
                <i class="bi bi-crown"></i>
            </div>

            <div class="stat-content">
                <span>Owned Projects</span>
                <strong>@Model.OwnedProjects</strong>
                <small>Projects you created</small>
            </div>

            <div class="stat-decoration stat-decoration-green">
                <i class="bi bi-star-fill"></i>
            </div>
        </article>

        <article class="stat-card">
            <div class="stat-icon stat-icon-orange">
                <i class="bi bi-people"></i>
            </div>

            <div class="stat-content">
                <span>Collaborating On</span>
                <strong>@Model.CollaboratingProjects</strong>
                <small>Shared team projects</small>
            </div>

            <div class="stat-decoration stat-decoration-orange">
                <i class="bi bi-person-check-fill"></i>
            </div>
        </article>
    </div>

    <section class="projects-section">
        <div class="projects-section-heading">
            <div>
                <span class="page-eyebrow">
                    Project library
                </span>

                <h2>Your project workspaces</h2>

                <p>
                    Open a project to activate its Dashboard and shared workspace.
                </p>
            </div>

            <span class="project-count-label">
                @Model.TotalProjects
                @(Model.TotalProjects == 1
                    ? "project"
                    : "projects")
            </span>
        </div>

        <div class="project-toolbar">
            <label class="project-search">
                <i class="bi bi-search"></i>

                <input type="search"
                       id="projectSearch"
                       placeholder="Search by project, idea or domain..."
                       autocomplete="off" />
            </label>

            <label class="project-filter">
                <span class="visually-hidden">
                    Filter projects by role
                </span>

                <select id="roleFilter">
                    <option value="all">All Roles</option>
                    <option value="owner">Owner</option>
                    <option value="collaborator">
                        Collaborator
                    </option>
                </select>

                <i class="bi bi-chevron-down"></i>
            </label>

            <label class="project-filter">
                <span class="visually-hidden">
                    Filter projects by status
                </span>

                <select id="statusFilter">
                    <option value="all">All Statuses</option>
                    <option value="draft">Draft</option>
                    <option value="planning">Planning</option>
                    <option value="active">Active</option>
                    <option value="in_progress">
                        In Progress
                    </option>
                    <option value="completed">
                        Completed
                    </option>
                </select>

                <i class="bi bi-chevron-down"></i>
            </label>

            <label class="project-filter project-sort">
                <span class="visually-hidden">
                    Sort projects
                </span>

                <select id="sortProjects">
                    <option value="newest">
                        Newest First
                    </option>
                    <option value="oldest">
                        Oldest First
                    </option>
                    <option value="name">
                        Project Name
                    </option>
                    <option value="team">
                        Team Size
                    </option>
                </select>

                <i class="bi bi-filter-left"></i>
            </label>
        </div>

        @if (Model.Projects.Count == 0)
        {
            <section class="projects-empty-state">
                <div class="empty-state-illustration">
                    <div class="empty-folder">
                        <i class="bi bi-folder-plus"></i>
                    </div>

                    <span class="empty-dot empty-dot-one"></span>
                    <span class="empty-dot empty-dot-two"></span>
                    <span class="empty-dot empty-dot-three"></span>
                </div>

                <span class="page-eyebrow">
                    Start your journey
                </span>

                <h2>No projects yet</h2>

                <p>
                    Create an empty project first, then generate or
                    select an idea for that specific project.
                </p>

                <form method="post"
                      asp-page-handler="CreateProject">

                    <button type="submit"
                            class="primary-empty-button">
                        <i class="bi bi-plus-lg"></i>
                        Create Your First Project
                    </button>
                </form>
            </section>
        }
        else
        {
            <div class="projects-grid"
                 id="projectsGrid">

                @foreach (var project in Model.Projects)
                {
                    <article class="project-card
                        @(project.IsActiveProject
                                 ? "active-project-card"
                                 : "")"
                             data-project-card
                             data-name="@project.Title.ToLowerInvariant()"
                             data-idea="@project.SelectedIdeaTitle.ToLowerInvariant()"
                             data-domain="@project.Domain.ToLowerInvariant()"
                             data-role="@project.Role"
                             data-status="@project.Status"
                             data-created="@project.CreatedSortValue"
                             data-team="@project.ActiveMembersCount">

                        @if (project.IsActiveProject)
                        {
                            <div class="active-project-ribbon">
                                <i class="bi bi-lightning-charge-fill"></i>
                                Active Project
                            </div>
                        }

                        <header class="project-card-header">
                            <div class="project-title-group">
                                <div class="project-icon
                                    @project.IconCssClass">
                                    <i class="@project.IconClass"></i>
                                </div>

                                <div class="project-heading-text">
                                    <h3 title="@project.Title">
                                        @project.Title
                                    </h3>

                                    <span title="@project.Domain">
                                        @project.Domain
                                    </span>
                                </div>
                            </div>

                            <button type="button"
                                    class="project-more-button"
                                    data-open-rename
                                    data-project-id="@project.Id"
                                    data-project-title="@project.Title"
                                    aria-label="Rename @project.Title"
                                    title="Rename project">

                                <i class="bi bi-pencil-square"></i>
                            </button>
                        </header>

                        <div class="project-badges">
                            <span class="role-badge
                                @(project.Role == "owner"
                                      ? "owner-badge"
                                      : "collaborator-badge")">

                                <i class="bi
                                @(project.Role == "owner"
                                       ? "bi-crown-fill"
                                       : "bi-people-fill")"></i>

                                @project.RoleLabel
                            </span>

                            <span class="status-badge
                                @project.StatusCssClass">

                                <i class="bi
                                @(project.Status == "active"
                                       ? "bi-circle-fill"
                                       : "bi-clock")"></i>

                                @project.StatusLabel
                            </span>
                        </div>

                        <div class="selected-idea-panel
                            @(project.HasSelectedIdea
                                 ? "idea-selected"
                                 : "idea-missing")">

                            <div class="selected-idea-icon">
                                <i class="bi
                                @(project.HasSelectedIdea
                                       ? "bi-lightbulb-fill"
                                       : "bi-lightbulb")"></i>
                            </div>

                            <div>
                                <span>
                                    Selected Project Idea
                                </span>

                                <strong>
                                    @project.SelectedIdeaTitle
                                </strong>
                            </div>
                        </div>

                        <p class="project-description">
                            @project.Description
                        </p>

                        <div class="project-members-row">
                            <div class="member-count">
                                <i class="bi bi-people"></i>

                                <span>
                                    @project.ActiveMembersCount
                                    of
                                    @project.MaximumMembers
                                    members
                                </span>
                            </div>

                            <div class="member-avatars"
                                 aria-label="Project members">

                                @foreach (var member
                                    in project.Members.Take(3))
                                {
                                    <div class="member-avatar"
                                         title="@member.FullName — @member.Role">

                                        @member.Initials
                                    </div>
                                }

                                @for (
                                    var slot =
                                        project.ActiveMembersCount;
                                    slot <
                                        project.MaximumMembers &&
                                    slot < 3;
                                    slot++)
                                {
                                    <div class="member-avatar
                                        empty-avatar"
                                         title="Available team position">
                                        <i class="bi bi-plus"></i>
                                    </div>
                                }
                            </div>
                        </div>

                        <div class="team-progress-row">
                            <div class="team-progress-track">
                                <div class="team-progress-value"
                                     style="width:
                                    @project.TeamFillPercentage%">
                                </div>
                            </div>

                            <span>
                                @project.TeamFillPercentage%
                            </span>
                        </div>

                        <div class="project-metadata">
                            <span>
                                <i class="bi bi-calendar3"></i>
                                Created
                                @project.CreatedAt
                                .ToLocalTime()
                                .ToString("MMM d, yyyy")
                            </span>

                            <span>
                                <i class="bi bi-arrow-clockwise"></i>
                                Updated
                                @project.UpdatedAt
                                .ToLocalTime()
                                .ToString("MMM d")
                            </span>
                        </div>

                        @if (!string.IsNullOrWhiteSpace(
                            project.LastActivityDescription))
                        {
                            <div class="latest-activity">
                                <div class="activity-line"></div>

                                <div>
                                    <span>Latest activity</span>

                                    <p>
                                        @project.LastActivityDescription
                                    </p>
                                </div>
                            </div>
                        }

                        <footer class="project-card-actions">
                            <form method="post"
                                  asp-page-handler="OpenProject">

                                <input type="hidden"
                                       name="projectId"
                                       value="@project.Id" />

                                <button type="submit"
                                        class="open-project-button">

                                    <span>
                                        @(project.IsActiveProject
                                            ? "Continue Project"
                                            : "Open Project")
                                    </span>

                                    <i class="bi
                                    @(project.IsActiveProject
                                           ? "bi-arrow-right"
                                           : "bi-box-arrow-up-right")"></i>
                                </button>
                            </form>

                            <button type="button"
                                    class="team-project-button"
                                    data-team-notice
                                    data-team-action="@project.TeamActionText">

                                <i class="bi
                                @(project.Role == "owner"
                                       ? "bi-person-plus"
                                       : "bi-people")"></i>

                                <span>
                                    @project.TeamActionText
                                </span>
                            </button>
                        </footer>
                    </article>
                }
            </div>

            <section class="filtered-empty-state"
                     id="filteredEmptyState">

                <div class="filtered-empty-icon">
                    <i class="bi bi-search"></i>
                </div>

                <h2>No matching projects</h2>

                <p>
                    Change the search term or remove one of the
                    selected filters.
                </p>
            </section>
        }
    </section>
</section>

<div class="project-modal"
     id="renameProjectModal"
     aria-hidden="true">

    <div class="project-modal-backdrop"
         data-close-rename>
    </div>

    <section class="project-modal-dialog"
             role="dialog"
             aria-modal="true"
             aria-labelledby="renameModalTitle">

        <header class="project-modal-header">
            <div class="modal-title-icon">
                <i class="bi bi-pencil-square"></i>
            </div>

            <div>
                <span class="page-eyebrow">
                    Shared project setting
                </span>

                <h2 id="renameModalTitle">
                    Rename Project
                </h2>
            </div>

            <button type="button"
                    class="modal-close-button"
                    data-close-rename
                    aria-label="Close rename window">

                <i class="bi bi-x-lg"></i>
            </button>
        </header>

        <p class="modal-description">
            The new project name will appear immediately for the
            owner and every active collaborator.
        </p>

        <form method="post"
              asp-page-handler="RenameProject"
              id="renameProjectForm">

            <input type="hidden"
                   name="projectId"
                   id="renameProjectId" />

            <label class="rename-field">
                <span>Project name</span>

                <input type="text"
                       name="title"
                       id="renameProjectTitle"
                       minlength="3"
                       maxlength="120"
                       required
                       autocomplete="off" />

                <small>
                    Between 3 and 120 characters.
                </small>
            </label>

            <div class="modal-actions">
                <button type="button"
                        class="modal-secondary-button"
                        data-close-rename>
                    Cancel
                </button>

                <button type="submit"
                        class="modal-primary-button">

                    <i class="bi bi-check-lg"></i>
                    Save Project Name
                </button>
            </div>
        </form>
    </section>
</div>

<div class="project-toast"
     id="teamFeatureToast"
     role="status"
     aria-live="polite">

    <i class="bi bi-info-circle-fill"></i>

    <div>
        <strong>Collaboration setup</strong>

        <span>
            Email invitations and team management are connected
            in the next collaboration stage.
        </span>
    </div>
</div>

@section Head {
    <style>
        :root {
            --projects-deep: #071d49;
            --projects-navy: #173463;
            --projects-steel: #516c8d;
            --projects-primary: #155eef;
            --projects-primary-dark: #0b4dd8;
            --projects-border: #e2e8f0;
            --projects-muted: #64748b;
            --projects-soft: #f6f8fb;
            --projects-green: #047857;
            --projects-orange: #d97706;
            --projects-purple: #7c3aed;
        }

        .my-projects-page {
            max-width: 1500px;
            margin: 0 auto;
            padding-bottom: 2.5rem;
            color: #111827;
        }

        .projects-alert {
            display: grid;
            grid-template-columns: auto minmax(0, 1fr) auto;
            gap: .75rem;
            align-items: center;
            margin-bottom: 1rem;
            padding: .9rem 1rem;
            border-radius: 13px;
            font-size: .78rem;
            font-weight: 700;
            animation: slideAlert .25s ease;
        }

        .projects-alert-success {
            border: 1px solid #a7e7cc;
            color: #066746;
            background: #ecfbf5;
        }

        .projects-alert-error {
            border: 1px solid #fecaca;
            color: #b42318;
            background: #fff1f2;
        }

        .alert-close-button {
            width: 30px;
            height: 30px;
            display: grid;
            place-items: center;
            border: 0;
            border-radius: 8px;
            color: inherit;
            background: transparent;
        }

        .projects-hero {
            min-height: 230px;
            position: relative;
            display: grid;
            grid-template-columns: minmax(0, 1fr) auto;
            gap: 1.5rem;
            align-items: center;
            margin-bottom: 1rem;
            padding: 2rem;
            overflow: hidden;
            border-radius: 22px;
            color: #fff;
            background: radial-gradient( circle at 82% 8%, rgba(112, 162, 255, .3), transparent 28%), linear-gradient( 135deg, #061943, #12336e 58%, #31567d);
            box-shadow: 0 20px 42px rgba(7, 29, 73, .18);
        }

        .projects-hero-content {
            position: relative;
            z-index: 2;
            max-width: 820px;
        }

        .page-eyebrow {
            display: block;
            margin-bottom: .3rem;
            color: var(--projects-steel);
            font-size: .67rem;
            font-weight: 800;
            letter-spacing: .12em;
            text-transform: uppercase;
        }

        .projects-hero .page-eyebrow {
            color: rgba(255, 255, 255, .62);
        }

        .projects-hero h1 {
            margin: 0;
            font-size: clamp(2rem, 4vw, 3.25rem);
            font-weight: 850;
            letter-spacing: -.05em;
        }

        .projects-hero p {
            max-width: 780px;
            margin: .75rem 0 0;
            color: rgba(255, 255, 255, .76);
            font-size: .88rem;
            line-height: 1.7;
        }

        .hero-feature-list {
            display: flex;
            gap: .55rem;
            flex-wrap: wrap;
            margin-top: 1.15rem;
        }

            .hero-feature-list span {
                display: inline-flex;
                align-items: center;
                gap: .4rem;
                padding: .44rem .7rem;
                border: 1px solid rgba(255, 255, 255, .14);
                border-radius: 999px;
                color: rgba(255, 255, 255, .86);
                background: rgba(255, 255, 255, .09);
                backdrop-filter: blur(10px);
                font-size: .65rem;
                font-weight: 700;
            }

        .create-project-form {
            position: relative;
            z-index: 3;
        }

        .create-project-button {
            min-width: 245px;
            display: grid;
            grid-template-columns: auto minmax(0, 1fr);
            gap: .8rem;
            align-items: center;
            padding: .9rem 1rem;
            border: 1px solid rgba(255, 255, 255, .25);
            border-radius: 16px;
            color: #0b2b65;
            background: rgba(255, 255, 255, .96);
            box-shadow: 0 16px 35px rgba(0, 0, 0, .16);
            text-align: left;
            transition: .18s ease;
        }

            .create-project-button:hover {
                transform: translateY(-2px);
                background: #fff;
            }

        .create-button-icon {
            width: 45px;
            height: 45px;
            display: grid;
            place-items: center;
            border-radius: 13px;
            color: #fff;
            background: linear-gradient( 135deg, var(--projects-primary), #558cff);
            font-size: 1.05rem;
        }

        .create-project-button strong,
        .create-project-button small {
            display: block;
        }

        .create-project-button strong {
            font-size: .8rem;
        }

        .create-project-button small {
            margin-top: .18rem;
            color: #748197;
            font-size: .62rem;
            font-weight: 600;
        }

        .hero-orb {
            position: absolute;
            border-radius: 50%;
            pointer-events: none;
        }

        .hero-orb-one {
            width: 135px;
            height: 135px;
            right: 24%;
            bottom: -80px;
            background: rgba(72, 125, 244, .25);
        }

        .hero-orb-two {
            width: 90px;
            height: 90px;
            right: 5%;
            top: -45px;
            background: rgba(255, 255, 255, .09);
        }

        .project-statistics {
            display: grid;
            grid-template-columns: repeat(3, minmax(0, 1fr));
            gap: 1rem;
            margin-bottom: 1rem;
        }

        .stat-card {
            min-height: 112px;
            position: relative;
            display: grid;
            grid-template-columns: auto minmax(0, 1fr) auto;
            align-items: center;
            gap: 1rem;
            padding: 1.1rem;
            overflow: hidden;
            border: 1px solid var(--projects-border);
            border-radius: 16px;
            background: #fff;
            box-shadow: 0 8px 24px rgba(15, 23, 42, .055);
        }

        .stat-icon {
            width: 58px;
            height: 58px;
            display: grid;
            place-items: center;
            border-radius: 14px;
            font-size: 1.4rem;
        }

        .stat-icon-blue {
            color: var(--projects-primary);
            background: #eaf1ff;
        }

        .stat-icon-green {
            color: #059669;
            background: #e6f8f2;
        }

        .stat-icon-orange {
            color: #ea8b00;
            background: #fff3df;
        }

        .stat-content span,
        .stat-content small {
            display: block;
        }

        .stat-content span {
            color: var(--projects-muted);
            font-size: .73rem;
            font-weight: 700;
        }

        .stat-content strong {
            display: block;
            margin-top: .15rem;
            color: #111827;
            font-size: 1.75rem;
            line-height: 1;
        }

        .stat-content small {
            margin-top: .3rem;
            color: #94a3b8;
            font-size: .6rem;
        }

        .stat-decoration {
            width: 47px;
            height: 47px;
            display: grid;
            place-items: center;
            border-radius: 50%;
            font-size: 1.05rem;
        }

        .stat-decoration-blue {
            color: var(--projects-primary);
            background: #f0f5ff;
        }

        .stat-decoration-green {
            color: #059669;
            background: #edfaf6;
        }

        .stat-decoration-orange {
            color: #ea8b00;
            background: #fff7e9;
        }

        .projects-section {
            padding: 1.25rem;
            border: 1px solid #e5eaf1;
            border-radius: 20px;
            background: #fff;
            box-shadow: 0 10px 30px rgba(15, 23, 42, .045);
        }

        .projects-section-heading {
            display: flex;
            justify-content: space-between;
            gap: 1rem;
            align-items: flex-end;
            margin-bottom: 1rem;
        }

            .projects-section-heading h2 {
                margin: 0;
                color: #111827;
                font-size: 1.2rem;
                font-weight: 800;
            }

            .projects-section-heading p {
                margin: .3rem 0 0;
                color: var(--projects-muted);
                font-size: .72rem;
            }

        .project-count-label {
            padding: .42rem .7rem;
            border-radius: 999px;
            color: #2f5aa8;
            background: #eef4ff;
            font-size: .65rem;
            font-weight: 800;
        }

        .project-toolbar {
            display: grid;
            grid-template-columns: minmax(280px, 1.6fr) minmax(145px, .55fr) minmax(155px, .6fr) minmax(170px, .65fr);
            gap: .7rem;
            margin-bottom: 1rem;
        }

        .project-search,
        .project-filter {
            min-height: 46px;
            position: relative;
            display: grid;
            align-items: center;
            border: 1px solid #d9e1ec;
            border-radius: 11px;
            background: #fbfcfe;
            transition: .15s ease;
