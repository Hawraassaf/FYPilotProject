@page
@model FYPilot.Web.Pages.Student.ScopeOptimizerModel
@{
    ViewData["Title"]    = "Scope Optimizer";
    ViewData["Subtitle"] = "Detect scope risks and build a focused MVP";
}

@if (Model.Idea == null)
{
    <div class="page-card p-5 text-center">
        <i class="bi bi-funnel display-3 text-muted"></i>
        <h5 class="mt-3">No Project Selected</h5>
        <a href="/Student/IdeaGenerator" class="btn btn-primary mt-2">Generate Ideas First</a>
    </div>
}
else
{
<div class="row g-4">
    <div class="col-lg-5">
        <div class="page-card p-4 mb-3">
            <h6 class="fw-bold mb-1">@Model.Idea.Title</h6>
            <span class="badge bg-primary-subtle text-primary">@Model.Idea.Domain</span>
            <span class="badge bg-warning-subtle text-warning text-capitalize">@Model.Idea.DifficultyLevel</span>
            <span class="badge bg-secondary-subtle text-secondary">@Model.Idea.ExpectedDurationWeeks weeks</span>
            <p class="text-muted small mt-2 mb-0">@Model.Idea.ProblemStatement</p>
        </div>

        <div class="page-card p-4">
            <h6 class="fw-bold mb-3"><i class="bi bi-exclamation-octagon me-2 text-warning"></i>Scope Risk Assessment</h6>
            @foreach (var risk in Model.ScopeRisks)
            {
                <div class="mb-3 p-3 rounded-2 risk-@risk.Level.ToLower()">
                    <div class="d-flex align-items-center gap-2 mb-1">
                        <span class="badge @(risk.Level == "high" ? "bg-danger" : risk.Level == "medium" ? "bg-warning text-dark" : "bg-success")">@risk.Level.ToUpper()</span>
                        <span class="fw-semibold small">@risk.Category</span>
                    </div>
                    <div class="small">@risk.Description</div>
                    <div class="small text-muted mt-1"><i class="bi bi-lightbulb me-1"></i>@risk.Fix</div>
                </div>
            }
        </div>
    </div>

    <div class="col-lg-7">
        <div class="page-card p-4 mb-3">
            <h6 class="fw-bold mb-3"><i class="bi bi-check2-square me-2 text-success"></i>Recommended MVP</h6>
            <div class="alert alert-success-subtle border-success mb-3" style="background:#f0fdf4;border:1px solid #bbf7d0">
                <strong>MVP Focus:</strong> @Model.MvpDescription
            </div>
            <div class="row g-3">
                <div class="col-6">
                    <h6 class="small fw-bold text-success mb-2">✓ Features to Keep</h6>
                    <ul class="small text-muted mb-0 ps-3">
                        @foreach (var f in Model.FeaturesToKeep) { <li>@f</li> }
                    </ul>
                </div>
                <div class="col-6">
                    <h6 class="small fw-bold text-muted mb-2">⏸ Defer to v2</h6>
                    <ul class="small text-muted mb-0 ps-3">
                        @foreach (var f in Model.FeaturesToDefer) { <li>@f</li> }
                    </ul>
                </div>
            </div>
        </div>

        <div class="page-card p-4">
            <h6 class="fw-bold mb-3"><i class="bi bi-calendar3 me-2 text-primary"></i>Optimised Timeline</h6>
            <div class="row g-2 text-center">
                @foreach (var (phase, weeks, color) in Model.Timeline)
                {
                    <div class="col-4">
                        <div class="p-3 rounded-2" style="background:@(color)25;border:1px solid @(color)55">
                            <div class="fw-bold" style="color:@color">@weeks wks</div>
                            <div class="small text-muted">@phase</div>
                        </div>
                    </div>
                }
            </div>
            <div class="mt-3 text-muted small">
                <i class="bi bi-info-circle me-1"></i>
                Total optimised duration: <strong>@Model.Timeline.Sum(t => t.Weeks) weeks</strong>
                (originally @Model.Idea.ExpectedDurationWeeks weeks)
            </div>
        </div>
    </div>
</div>
}
