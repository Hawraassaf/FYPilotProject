            place-items: center;
            border-radius: 26px;
            color: var(--defense-blue);
            background: #eef2f7;
            font-size: 2rem;
        }

        .defense-placeholder p,
        .defense-empty p {
            max-width: 590px;
            margin: 0;
            color: var(--defense-muted);
            font-size: .84rem;
            line-height: 1.6;
        }

        .defense-side-card header {
            padding: 1.1rem 1.1rem .9rem;
            border-bottom: 1px solid var(--defense-border);
        }

        .defense-side-card h3 {
            margin-top: .3rem;
            font-size: .96rem;
            font-weight: 640;
            line-height: 1.4;
        }

        .defense-side-card header p {
            margin: .4rem 0 0;
            color: var(--defense-muted);
            font-size: .72rem;
            line-height: 1.55;
        }

        .defense-answer-guide {
            display: grid;
            gap: 0;
            padding: .4rem 1.05rem 1rem;
        }

            .defense-answer-guide > div {
                display: grid;
                grid-template-columns: auto minmax(0, 1fr);
                gap: .7rem;
                align-items: flex-start;
                padding: .85rem 0;
                border-bottom: 1px solid #edf1f5;
            }

                .defense-answer-guide > div:last-child {
                    border-bottom: 0;
                }

                .defense-answer-guide > div > span {
                    width: 30px;
                    height: 30px;
                    display: grid;
                    place-items: center;
                    border-radius: 10px;
                    color: #fff;
                    background: var(--defense-blue);
                    font-size: .7rem;
                    font-weight: 600;
                }

            .defense-answer-guide h4 {
                margin: 0;
                color: var(--defense-ink);
                font-size: .78rem;
                font-weight: 620;
                line-height: 1.35;
            }

            .defense-answer-guide p {
                margin: .2rem 0 0;
                color: var(--defense-muted);
                font-size: .69rem;
                line-height: 1.5;
            }

        .defense-checklist {
            display: grid;
            gap: .15rem;
            margin: 0;
            padding: .65rem 1.05rem .8rem;
            list-style: none;
        }

            .defense-checklist li {
                display: grid;
                grid-template-columns: auto minmax(0, 1fr);
                gap: .6rem;
                align-items: flex-start;
                padding: .62rem 0;
                color: #475569;
                border-bottom: 1px solid #edf1f5;
                font-size: .72rem;
                line-height: 1.5;
            }

                .defense-checklist li:last-child {
                    border-bottom: 0;
                }

            .defense-checklist i {
                width: 24px;
                height: 24px;
                display: grid;
                place-items: center;
                margin-top: .02rem;
                border-radius: 8px;
                color: var(--defense-blue);
                background: #eef2f7;
                font-size: .72rem;
            }

        .defense-side-note {
            display: grid;
            grid-template-columns: auto minmax(0, 1fr);
            gap: .55rem;
            align-items: flex-start;
            margin: 0 1.05rem 1.05rem;
            padding: .75rem;
            border: 1px solid #dbe5ef;
            border-radius: 14px;
            color: #52647f;
            background: #f8fafc;
            font-size: .68rem;
            line-height: 1.5;
        }

            .defense-side-note i {
                margin-top: .08rem;
                color: var(--defense-blue);
            }

        .defense-busy {
            position: fixed;
            inset: 0;
            z-index: 9999;
            display: grid;
            place-items: center;
            padding: 1rem;
            background: rgba(7, 29, 73, .42);
            backdrop-filter: blur(4px);
        }

            .defense-busy[hidden] {
                display: none;
            }

            .defense-busy > div {
                min-width: 270px;
                display: grid;
                justify-items: center;
                gap: .45rem;
                padding: 1.4rem;
                border-radius: 22px;
                color: var(--defense-ink);
                background: #fff;
                box-shadow: 0 24px 60px rgba(15,23,42,.24);
            }

            .defense-busy strong {
                margin-top: .25rem;
                font-size: .86rem;
            }

            .defense-busy small {
                color: var(--defense-muted);
                font-size: .7rem;
            }

        .defense-spinner {
            width: 42px;
            height: 42px;
            border: 4px solid #dbe5ef;
            border-top-color: var(--defense-blue);
            border-radius: 50%;
            animation: defense-spin .8s linear infinite;
        }

        @@keyframes defense-spin {
            to {
                transform: rotate(360deg);
            }
        }

        .defense-page strong,
        .defense-page b {
            font-weight: 560;
        }

        .defense-page h1 {
            font-weight: 650;
        }

        .defense-page h2,
        .defense-page h3,
        .defense-page h4 {
            font-weight: 600;
        }

        .defense-page .defense-button,
        .defense-page .defense-kicker,
        .defense-page .defense-hero__eyebrow {
            font-weight: 600;
        }

        .defense-page h1,
        .defense-page h2,
        .defense-page h3,
        .defense-page h4 {
            text-wrap: balance;
        }

        .defense-panel,
        .defense-side-card,
        .defense-context,
        .defense-question-card {
            transition: box-shadow .16s ease, border-color .16s ease;
        }

        @@media (max-width: 1200px) {
            .defense-hero,
            .defense-grid {
                grid-template-columns: 1fr;
            }

            .defense-hero__stats {
                min-width: 0;
            }

            .defense-sidebar {
                grid-template-columns: repeat(2, minmax(0, 1fr));
            }
        }

        @@media (max-width: 900px) {
            .defense-area-grid {
                grid-template-columns: repeat(2, minmax(0, 1fr));
            }

            .defense-context,
            .defense-panel__header--session,
            .defense-config-footer {
                align-items: flex-start;
                flex-direction: column;
            }

            .defense-context__tags,
            .defense-session__actions {
                justify-content: flex-start;
            }

            .defense-score-grid {
                grid-template-columns: 1fr;
            }
        }

        @@media (max-width: 700px) {
            .defense-toast-stack {
                top: .75rem;
                right: .75rem;
                left: .75rem;
                width: auto;
            }

            .defense-hero__stats,
            .defense-sidebar,
            .defense-feedback-grid,
            .defense-area-grid {
                grid-template-columns: 1fr;
            }

            .defense-count-picker {
                grid-template-columns: repeat(5, minmax(48px, 1fr));
            }

            .defense-hero__actions,
            .defense-session__actions {
                width: 100%;
            }

                .defense-hero__actions .defense-button,
                .defense-session__actions form,
                .defense-session__actions .defense-button {
                    width: 100%;
                }

            .defense-question-card__header {
                grid-template-columns: 1fr;
            }

            .defense-answer-form__footer,
            .defense-evaluation__heading {
                align-items: flex-start;
                flex-direction: column;
            }
        }
    </style>
}

@section Scripts {
    <script>
        (() => {
            const busy = document.getElementById("defense-busy");
            const toastStack = document.getElementById("defense-toast-stack");
            const areaGrid = document.getElementById("defense-area-grid");

            const dismissToast = toast => {
                if (!toast || toast.dataset.dismissing === "true") {
                    return;
                }

                toast.dataset.dismissing = "true";
                toast.classList.add("is-leaving");
                toast.classList.remove("is-visible");

                window.setTimeout(() => {
                    toast.remove();
                }, 260);
            };

            const scheduleToastDismissal = toast => {
                const delay = Number(toast.dataset.autoDismiss || 5000);

                window.setTimeout(() => {
                    dismissToast(toast);
                }, delay);
            };

            const showToast = (
                title,
                message,
                type = "error",
                duration = 5000
            ) => {
                if (!toastStack) {
                    return;
                }

                const toast = document.createElement("div");
                toast.className =
                    `defense-toast defense-toast--${type}`;
                toast.setAttribute(
                    "role",
                    type === "error" ? "alert" : "status"
                );
                toast.dataset.defenseToast = "";
                toast.dataset.autoDismiss = String(duration);
                toast.style.setProperty(
                    "--toast-duration",
                    `${duration}ms`
                );

                const iconClass =
                    type === "error"
                        ? "bi-exclamation-circle"
                        : "bi-check2-circle";

                toast.innerHTML = `
                    <span class="defense-toast__icon">
                        <i class="bi ${iconClass}"></i>
                    </span>

                    <div class="defense-toast__content">
                        <strong></strong>
                        <span></span>
                    </div>

                    <button type="button"
                            class="defense-toast__close"
                            data-toast-close
                            aria-label="Dismiss message">
                        <i class="bi bi-x-lg"></i>
                    </button>

                    <span class="defense-toast__timer"></span>
                `;

                toast.querySelector("strong").textContent = title;
                toast.querySelector(
                    ".defense-toast__content > span"
                ).textContent = message;

                toastStack.appendChild(toast);

                window.requestAnimationFrame(() => {
                    toast.classList.add("is-visible");
                });

                scheduleToastDismissal(toast);
            };

            document
                .querySelectorAll("[data-defense-toast]")
                .forEach(toast => {
                    const duration = Number(
                        toast.dataset.autoDismiss || 5000
                    );

                    toast.style.setProperty(
                        "--toast-duration",
                        `${duration}ms`
                    );

                    scheduleToastDismissal(toast);
                });

            document.addEventListener("click", event => {
                const closeButton =
                    event.target.closest("[data-toast-close]");

                if (!closeButton) {
                    return;
                }

                dismissToast(
                    closeButton.closest("[data-defense-toast]")
                );
            });

            document.querySelectorAll("form").forEach(form => {
                form.addEventListener("submit", event => {
                    if (form.id === "defense-config-form") {
                        const checkedAreas =
                            form.querySelectorAll(
                                'input[name="FocusAreas"]:checked'
                            );

                        if (checkedAreas.length === 0) {
                            event.preventDefault();

                            areaGrid?.classList.remove(
                                "has-validation-error"
                            );

                            window.requestAnimationFrame(() => {
                                areaGrid?.classList.add(
                                    "has-validation-error"
                                );
                            });

                            showToast(
                                "Choose a defense field",
                                "Select at least one area before generating your practice questions.",
                                "error",
                                4800
                            );

                            document
                                .getElementById("practice-config")
                                ?.scrollIntoView({
                                    behavior: "smooth",
                                    block: "start"
                                });

                            return;
                        }

                        areaGrid?.classList.remove(
                            "has-validation-error"
                        );
                    }

                    if (busy) {
                        busy.hidden = false;
                    }

                    form
                        .querySelectorAll(
                            'button[type="submit"]'
                        )
                        .forEach(button => {
                            button.disabled = true;
                        });
                });
            });

            document
                .querySelectorAll(
                    'input[name="FocusAreas"]'
                )
                .forEach(input => {
                    input.addEventListener("change", () => {
                        if (
                            document.querySelectorAll(
                                'input[name="FocusAreas"]:checked'
                            ).length > 0
                        ) {
                            areaGrid?.classList.remove(
                                "has-validation-error"
                            );
                        }
                    });
                });

            document
                .querySelectorAll("[data-answer-textarea]")
                .forEach(textarea => {
                    const form =
                        textarea.closest("[data-answer-form]");
                    const output =
                        form?.querySelector("[data-word-count]");

                    const updateCount = () => {
                        const words = textarea.value
                            .trim()
                            .split(/\s+/)
                            .filter(Boolean)
                            .length;

                        if (output) {
                            output.textContent =
                                `${words} word${words === 1 ? "" : "s"}`;
                        }
                    };

                    textarea.addEventListener(
                        "input",
                        updateCount
                    );

                    updateCount();
                });
        })();
    </script>
}
