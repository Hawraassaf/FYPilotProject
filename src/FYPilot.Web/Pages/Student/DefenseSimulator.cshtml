@page
@model FYPilot.Web.Pages.Student.DefenseSimulatorModel
@{
    ViewData["Title"]    = "Defense Simulator";
    ViewData["Subtitle"] = "Prepare for your FYP proposal defense with professor-style Q&A";
}

<div class="row g-4">
    <div class="col-lg-7">
        <div class="page-card p-4">
            <div class="d-flex align-items-center justify-content-between mb-4">
                <h6 class="fw-bold mb-0"><i class="bi bi-shield-check me-2 text-danger"></i>Defense Q&A Practice</h6>
                @if (Model.Idea != null)
                {
                    <span class="badge bg-primary-subtle text-primary">@Model.Idea.Title.Substring(0, Math.Min(Model.Idea.Title.Length, 30))…</span>
                }
            </div>

            @if (Model.Idea == null)
            {
                <div class="text-center py-4 text-muted">
                    <i class="bi bi-shield display-4"></i>
                    <p class="mt-3">No project selected. <a href="/Student/IdeaGenerator">Generate an idea first.</a></p>
                </div>
            }
            else
            {
                @foreach (var (q, a, category) in Model.QnA)
                {
                    <div class="mb-4 p-3 rounded-3" style="border:1px solid #e2e8f0">
                        <div class="d-flex align-items-start gap-2 mb-2">
                            <span class="badge bg-danger flex-shrink-0 mt-1">Professor</span>
                            <div class="fw-semibold small">@q</div>
                        </div>
                        <div class="ms-4 mt-2">
                            <div class="small text-muted fw-semibold mb-1">
                                <span class="badge bg-success-subtle text-success me-1">Suggested Answer</span>
                                <span class="badge bg-secondary-subtle text-secondary">@category</span>
                            </div>
                            <p class="small mb-0 text-muted">@a</p>
                        </div>
                    </div>
                }
            }
        </div>
    </div>

    <div class="col-lg-5">
        <div class="page-card p-4 mb-3">
            <h6 class="fw-bold mb-3"><i class="bi bi-mortarboard me-2 text-warning"></i>Defense Tips</h6>
            <div class="d-flex flex-column gap-2">
                @foreach (var tip in new[] {
                    "Know your problem inside out — not just your solution",
                    "Have your dataset or data source ready to explain",
                    "Prepare a clear 2-minute project pitch",
                    "Anticipate 'Why not just use X?' questions",
                    "Be ready to justify every technology choice",
                    "Have measurable success criteria defined",
                    "Show awareness of limitations and future work",
                })
                {
                    <div class="d-flex gap-2 align-items-start">
                        <i class="bi bi-check-circle-fill text-success mt-1 flex-shrink-0"></i>
                        <span class="small">@tip</span>
                    </div>
                }
            </div>
        </div>

        <div class="page-card p-4">
            <h6 class="fw-bold mb-3"><i class="bi bi-lightning me-2 text-primary"></i>Defense Scoring Rubric</h6>
            @foreach (var (criterion, weight) in new[] {
                ("Problem Statement Clarity", 20),
                ("Solution Novelty",          20),
                ("Technical Feasibility",     25),
                ("Methodology Soundness",     20),
                ("Presentation Quality",      15),
            })
            {
                <div class="mb-2">
                    <div class="d-flex justify-content-between small mb-1">
                        <span>@criterion</span><span class="text-muted">@weight%</span>
                    </div>
                    <div class="progress" style="height:6px">
                        <div class="progress-bar bg-primary" style="width:@weight%"></div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>
