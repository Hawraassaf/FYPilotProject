@page
@model FYPilot.Web.Pages.Student.ProjectDNAModel
@{
    ViewData["Title"] = "Project DNA Analyzer";
    ViewData["Subtitle"] = "AI-based technical profile analysis of your selected project";
}

<div class="pdna-page">

    @if (Model.Idea == null)
    {
        <section class="pdna-empty-card">
            <div class="pdna-empty-icon">
                <i class="bi bi-diagram-3"></i>
            </div>

            <h1>No project idea selected yet</h1>

            <p>
                Select one idea first, then return here to generate its AI Project DNA analysis.
                The DNA report will stay empty until an idea is selected.
            </p>

            <div class="pdna-empty-actions">
                <a href="/Student/IdeaComparison" class="btn pdna-primary-btn">
                    <i class="bi bi-check2-circle me-1"></i>
                    Choose an Idea
                </a>

                <a href="/Student/IdeaGenerator" class="btn pdna-outline-btn">
                    <i class="bi bi-stars me-1"></i>
                    Generate Ideas
                </a>
            </div>
        </section>
    }
    else
    {
        @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
        {
            <div class="alert alert-warning pdna-alert">
                <i class="bi bi-exclamation-triangle me-2"></i>
                @Model.ErrorMessage
            </div>
        }

        @if (Model.LatestReview != null)
        {
            var (badgeClass, badgeLabel) = Model.DescribeReview(Model.LatestReview);
            <div class="mb-3">
                <span class="badge @badgeClass" title="@Model.LatestReview.DecisionReason">
                    <i class="bi bi-shield-check"></i> @badgeLabel
                </span>
            </div>
        }

        <section class="pdna-shell">

            <aside class="pdna-idea-card">
                <div class="pdna-idea-top">
                    <div class="pdna-idea-icon">
                        <i class="bi bi-fingerprint"></i>
                    </div>

                    <div>
                        <div class="pdna-kicker">Selected Idea</div>
                        <h1>@Model.Idea.Title</h1>
                    </div>
                </div>

                <div class="pdna-chip-row">
                    <span>@Model.Idea.Domain</span>
                    <span class="text-capitalize">@Model.Idea.DifficultyLevel</span>
                    <span>@Model.Idea.ExpectedDurationWeeks weeks</span>

                    @if (Model.Idea.IsSelected)
                    {
                        <span class="pdna-selected-chip">
                            <i class="bi bi-check-circle me-1"></i>
                            Selected
                        </span>
                    }
                </div>

                <div class="pdna-summary-block">
                    <label>Problem Statement</label>
                    <p>@Model.Idea.ProblemStatement</p>
                </div>

                <div class="pdna-summary-grid">
                    <div>
                        <label>Target Users</label>
                        <p>@Model.Idea.TargetUsers</p>
                    </div>

                    <div>
                        <label>Technologies</label>
                        <p>@Model.Idea.RequiredTechnologies</p>
                    </div>
                </div>

                <form method="post" asp-page-handler="Analyze" id="pdnaAnalyzeForm" class="pdna-generate-form">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="ideaId" value="@Model.Idea.Id" />

                    <button type="submit" class="btn pdna-primary-btn w-100">
                        <i class="bi bi-cpu me-2"></i>
                        Generate DNA AI Analysis
                    </button>
                </form>
                <a href="/Student/ProjectDetails?ideaId=@Model.Idea.Id" class="btn pdna-outline-btn w-100 mt-2">
                  <i class="bi bi-file-earmark-text me-2"></i>
                        View Project Details
                </a>
                
                @if (Model.Analysis == null)
                {
                    <div class="pdna-before-note">
                        <i class="bi bi-info-circle"></i>
                        <span>
                            No DNA analysis is shown yet. Click the button to ask the Python AI agent to analyze this project.
                        </span>
                    </div>
                }
                else
                {
                    <div class="pdna-ready-note">
                        <i class="bi bi-check-circle"></i>
                        <span>
                            AI DNA Analysis generated using @(Model.LlmUsed ? "Ollama / ProjectDNAAgent" : "fallback AI analysis").
                        </span>
                    </div>
                }
            </aside>

            <main class="pdna-analysis-card">
                @if (Model.Analysis == null)
                {
                    <div class="pdna-waiting-state">
                        <div class="pdna-waiting-orb">
                            <i class="bi bi-cpu"></i>
                        </div>

                        <h2>Ready to generate Project DNA</h2>

                        <p>
                            The report will appear here after the AI agent analyzes your selected idea,
                            skill profile, project scope, risks, and feasibility.
                        </p>

                        <div class="pdna-preview-list">
                            <div>
                                <i class="bi bi-diagram-3"></i>
                                Project identity and DNA type
                            </div>

                            <div>
                                <i class="bi bi-bar-chart-line"></i>
                                Technical, skill, feasibility, and market scores
                            </div>

                            <div>
                                <i class="bi bi-shield-exclamation"></i>
                                Risks, skill gaps, and scope advice
                            </div>
                        </div>
                    </div>
                }
                else
                {
                    <div class="pdna-analysis-head">
                        <div>
                            <div class="pdna-kicker">AI Project DNA Report</div>
                            <h2>@Model.Analysis.ProjectDNAType</h2>
                            <p>@Model.Analysis.Summary</p>
                        </div>

                        <div class="pdna-overall-score">
                            <strong>@Model.Analysis.OverallScore%</strong>
                            <span>Overall</span>
                        </div>
                    </div>

                    <div class="pdna-meta-strip">
                        <div>
                            <span>Risk Level</span>
                            <strong>@Model.Analysis.RiskLevel</strong>
                        </div>

                        <div>
                            <span>Source</span>
                            <strong>@(Model.LlmUsed ? "Ollama Agent" : "Fallback Engine")</strong>
                        </div>

                        <div>
                            <span>Idea Domain</span>
                            <strong>@Model.Idea.Domain</strong>
                        </div>
                    </div>

                    <section class="pdna-section">
                        <div class="pdna-section-title">
                            <i class="bi bi-sliders"></i>
                            DNA Dimensions
                        </div>

                        <div class="pdna-dimension-grid">
                            @foreach (var (label, value, color) in Model.DnaDimensions)
                            {
                                <div class="pdna-dimension-card">
                                    <div class="pdna-dimension-top">
                                        <span>@label</span>
                                        <strong>@value%</strong>
                                    </div>

                                    <div class="pdna-progress">
                                        <div style="width:@value%; background:@color"></div>
                                    </div>
                                </div>
                            }
                        </div>
                    </section>

                    <section class="pdna-section">
                        <div class="pdna-section-title">
                            <i class="bi bi-check2-circle"></i>
                            Strengths and Weaknesses
                        </div>

                        <div class="pdna-two-column">
                            <div class="pdna-list-card">
                                <h3>Strengths</h3>

                                @foreach (var strength in Model.Analysis.Strengths)
                                {
                                    <div class="pdna-list-item success">
                                        <i class="bi bi-check-circle"></i>
                                        <span>@strength</span>
                                    </div>
                                }
                            </div>

                            <div class="pdna-list-card">
                                <h3>Weaknesses</h3>

                                @foreach (var weakness in Model.Analysis.Weaknesses)
                                {
                                    <div class="pdna-list-item warning">
                                        <i class="bi bi-exclamation-circle"></i>
                                        <span>@weakness</span>
                                    </div>
                                }
                            </div>
                        </div>
                    </section>

                    <section class="pdna-section">
                        <div class="pdna-section-title">
                            <i class="bi bi-shield-exclamation"></i>
                            Risk Profile
                        </div>

                        <div class="pdna-risk-grid">
                            @foreach (var risk in Model.Risks)
                            {
                                var level = (risk.Level ?? "").Trim().ToLowerInvariant();
                                var levelClass = level == "high" ? "high" : level == "medium" ? "medium" : "low";

                                <div class="pdna-risk-card @levelClass">
                                    <div class="pdna-risk-head">
                                        <h3>@risk.Category</h3>
                                        <span>@risk.Level</span>
                                    </div>

                                    <p>@risk.Description</p>

                                    <div class="pdna-mitigation">
                                        <i class="bi bi-lightbulb"></i>
                                        @risk.Mitigation
                                    </div>
                                </div>
                            }
                        </div>
                    </section>

                    <section class="pdna-section">
                        <div class="pdna-section-title">
                            <i class="bi bi-person-check"></i>
                            Required Skills vs Your Profile
                        </div>

                        <div class="pdna-skills-list">
                            @if (Model.RequiredSkillsAnalysis.Any())
                            {
                                @foreach (var skill in Model.RequiredSkillsAnalysis)
                                {
                                    var status = (skill.Status ?? "").Trim().ToLowerInvariant();
                                    var statusClass = status == "matched" ? "matched" : status == "partial" ? "partial" : "missing";

                                    <div class="pdna-skill-row @statusClass">
                                        <div>
                                            <strong>@skill.SkillName</strong>
                                            <p>@skill.Explanation</p>
                                        </div>

                                        <span>@skill.Status</span>
                                    </div>
                                }
                            }
                            else
                            {
                                <div class="pdna-no-data">
                                    The AI response did not return required skill analysis.
                                </div>
                            }
                        </div>
                    </section>

                    <section class="pdna-section">
                        <div class="pdna-section-title">
                            <i class="bi bi-lightbulb"></i>
                            Recommended Improvements
                        </div>

                        <div class="pdna-improvement-list">
                            @foreach (var improvement in Model.Analysis.RecommendedImprovements)
                            {
                                <div>
                                    <i class="bi bi-arrow-right-circle"></i>
                                    <span>@improvement</span>
                                </div>
                            }
                        </div>
                    </section>

                    <div class="pdna-next-actions">
                        <a href="/Student/ProjectDetails?ideaId=@Model.Idea.Id" class="btn pdna-outline-btn">
                            <i class="bi bi-file-earmark-text me-1"></i>
                            View Project Details
                        </a>
                        <a href="/Student/Roadmap?ideaId=@Model.Idea.Id" class="btn pdna-primary-btn">
                            <i class="bi bi-map me-1"></i>
                            Continue to Roadmap
                        </a>

                        <a href="/Student/DefenseSimulator?ideaId=@Model.Idea.Id" class="btn pdna-outline-btn">
                            <i class="bi bi-shield-check me-1"></i>
                            Prepare Defense
                        </a>
                    </div>
                }
            </main>
        </section>

        <div class="pdna-loading-overlay d-none" id="pdnaLoadingOverlay">
            <div class="pdna-loading-card">
                <div class="pdna-loader-ring">
                    <span></span>
                </div>

                <h2>Generating Project DNA</h2>

                <p>
                    Please wait while FYPilot sends your selected idea to the Python AI agent.
                </p>

                <div class="pdna-loading-steps">
                    <div class="active">
                        <i class="bi bi-check2-circle"></i>
                        Reading selected idea
                    </div>

                    <div>
                        <i class="bi bi-cpu"></i>
                        Sending to ProjectDNAAgent
                    </div>

                    <div>
                        <i class="bi bi-diagram-3"></i>
                        Analyzing technical DNA
                    </div>

                    <div>
                        <i class="bi bi-shield-exclamation"></i>
                        Building risks and recommendations
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@section Scripts {
    <script>
        const dnaForm = document.getElementById("pdnaAnalyzeForm");
        const dnaOverlay = document.getElementById("pdnaLoadingOverlay");

        if (dnaForm && dnaOverlay) {
            dnaForm.addEventListener("submit", function () {
                dnaOverlay.classList.remove("d-none");

                const steps = dnaOverlay.querySelectorAll(".pdna-loading-steps div");
                let currentStep = 0;

                setInterval(function () {
                    steps.forEach(step => step.classList.remove("active"));

                    if (steps[currentStep]) {
                        steps[currentStep].classList.add("active");
                    }

                    currentStep = (currentStep + 1) % steps.length;
                }, 900);
            });
        }
    </script>
}
