@page
@model FYPilot.Web.Pages.Account.ForgotPasswordModel
@{
    ViewData["Title"] = "Forgot Password";
    Layout = "_Layout";
}

<div class="d-flex justify-content-center align-items-center" style="min-height: 75vh;">
    <div class="page-card p-5" style="max-width: 520px; width: 100%;">

        <div class="text-center mb-4">
            <div class="mx-auto mb-3 d-flex align-items-center justify-content-center rounded-circle bg-primary-subtle text-primary"
                 style="width: 64px; height: 64px;">
                <i class="bi bi-shield-lock fs-3"></i>
            </div>

            <h2 class="fw-bold mb-2">Forgot Password?</h2>
            <p class="text-muted mb-0">
                Enter your email address and we will generate a secure password reset link.
            </p>
        </div>

        @if (!string.IsNullOrWhiteSpace(Model.Message))
        {
            <div class="alert alert-info small">
                <i class="bi bi-info-circle me-1"></i>
                @Model.Message
            </div>
        }

        @if (!string.IsNullOrWhiteSpace(Model.DemoResetLink))
        {
            <div class="alert alert-warning small">
                <div class="fw-semibold mb-1">
                    <i class="bi bi-exclamation-triangle me-1"></i>Demo Mode
                </div>

                <div class="mb-3">
                    In a real system, this reset link would be sent to the user by email.
                    For the demo, you can open it directly below.
                </div>

                <a href="@Model.DemoResetLink" class="btn btn-warning btn-sm w-100">
                    <i class="bi bi-key me-1"></i>Open Reset Password Page
                </a>
            </div>
        }

        <form method="post">
            <div class="mb-3">
                <label asp-for="Input.Email" class="form-label fw-semibold small">Email address</label>
                <input asp-for="Input.Email" class="form-control" type="email" placeholder="you@example.com" autofocus />
                <span asp-validation-for="Input.Email" class="text-danger small"></span>
            </div>

            <button type="submit" class="btn btn-primary w-100 fw-semibold">
                <i class="bi bi-send me-1"></i>Generate Reset Link
            </button>
        </form>

        <div class="text-center mt-4">
            <a asp-page="/Account/Login" class="small text-decoration-none">
                <i class="bi bi-arrow-left me-1"></i>Back to Login
            </a>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}