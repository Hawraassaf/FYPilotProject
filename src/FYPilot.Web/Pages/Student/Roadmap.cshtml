        }

        .roadmap-gantt-label span {
            width: 24px;
            height: 24px;
            display: grid;
            place-items: center;
            color: var(--roadmap-navy);
            background: var(--roadmap-blue-soft);
            border-radius: 7px;
            font-size: .65rem;
