@section Scripts {
    <script>
        (function () {
            const phaseButtons = document.querySelectorAll("[data-phase-select]");
            const phasePanels = document.querySelectorAll("[data-phase-panel]");

            function selectPhase(phaseId, moveFocus) {
                phasePanels.forEach(function (panel) {
                    const isActive = panel.getAttribute("data-phase-panel") === phaseId;
                    panel.classList.toggle("is-active", isActive);
                    panel.setAttribute("aria-hidden", isActive ? "false" : "true");
                });

                phaseButtons.forEach(function (button) {
                    const isActive = button.getAttribute("data-phase-select") === phaseId;

                    if (button.getAttribute("role") === "tab") {
                        button.classList.toggle("is-selected", isActive);
                        button.setAttribute("aria-selected", isActive ? "true" : "false");
                    }
                });

                if (moveFocus) {
                    const selector = `[data-phase-panel="${phaseId.replace(/"/g, '\\"')}"]`;
                    const panel = document.querySelector(selector);

                    if (panel) {
                        panel.scrollIntoView({
                            behavior: window.matchMedia("(prefers-reduced-motion: reduce)").matches
                                ? "auto"
                                : "smooth",
                            block: "start"
                        });
                    }
                }
            }

            phaseButtons.forEach(function (button) {
                button.addEventListener("click", function () {
                    const phaseId = button.getAttribute("data-phase-select");

                    if (phaseId) {
                        selectPhase(phaseId, button.getAttribute("role") !== "tab");
                    }
                });

                if (button.getAttribute("role") === "tab") {
                    button.addEventListener("keydown", function (event) {
                        const tabs = Array.from(document.querySelectorAll('[role="tab"][data-phase-select]'));
                        const index = tabs.indexOf(button);
                        let nextIndex = -1;

                        if (event.key === "ArrowDown" || event.key === "ArrowRight") {
                            nextIndex = (index + 1) % tabs.length;
                        } else if (event.key === "ArrowUp" || event.key === "ArrowLeft") {
                            nextIndex = (index - 1 + tabs.length) % tabs.length;
                        } else if (event.key === "Home") {
                            nextIndex = 0;
                        } else if (event.key === "End") {
                            nextIndex = tabs.length - 1;
                        }

                        if (nextIndex >= 0) {
                            event.preventDefault();
                            tabs[nextIndex].focus();

                            const phaseId = tabs[nextIndex].getAttribute("data-phase-select");

                            if (phaseId) {
                                selectPhase(phaseId, false);
                            }
                        }
                    });
                }
            });
        })();

        (function () {
            const overlay = document.getElementById("rmLoadingOverlay");
            const forms = [
                document.getElementById("rmGenerateForm"),
                document.getElementById("rmGenerateFormEmpty")
            ].filter(Boolean);

            if (!overlay || forms.length === 0) {
                return;
            }

            const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
            const steps = Array.from(overlay.querySelectorAll(".roadmap-loading-steps li"));
            let timerId = null;

            forms.forEach(function (form) {
                form.addEventListener("submit", function () {
                    overlay.classList.remove("d-none");

                    if (reduceMotion || steps.length === 0) {
                        return;
                    }

                    let currentIndex = 0;

                    timerId = window.setInterval(function () {
                        steps.forEach(function (step, index) {
                            step.classList.toggle("is-active", index === currentIndex);
                        });

                        currentIndex = (currentIndex + 1) % steps.length;
                    }, 1300);
                });
            });

            window.addEventListener("pageshow", function () {
                overlay.classList.add("d-none");

                if (timerId) {
                    window.clearInterval(timerId);
                    timerId = null;
                }
            });
        })();
    </script>
}
