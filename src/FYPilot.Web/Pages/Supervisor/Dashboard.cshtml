        .sd-meeting-row {
            display: grid;
            grid-template-columns: auto minmax(0, 1fr) auto auto;
            gap: .75rem;
            align-items: center;
            padding: .82rem;
        }

        .sd-date-box {
            width: 54px;
            height: 58px;
            display: grid;
            place-items: center;
            align-content: center;
            border-radius: 16px;
            color: var(--sd-blue);
            background: #F3F6FB;
        }

            .sd-date-box span {
                color: var(--sd-steel);
                font-size: .62rem;
                font-weight: 500;
                text-transform: uppercase;
                letter-spacing: .06em;
            }

            .sd-date-box strong {
                color: var(--sd-blue);
                font-size: 1.28rem;
                line-height: 1;
                font-weight: 500;
            }

        .sd-meeting-main strong {
            display: block;
            color: var(--sd-text);
            font-size: .84rem;
            font-weight: 500;
        }

        .sd-meeting-main small {
            display: block;
            margin-top: .12rem;
            color: var(--sd-muted);
            font-size: .72rem;
        }

        .sd-meeting-main p {
            margin: .18rem 0 0;
            color: #475569;
            font-size: .7rem;
        }

        .sd-soft-empty {
            min-height: 150px;
            margin: .85rem;
            display: grid;
            place-items: center;
            align-content: center;
            text-align: center;
            gap: .35rem;
            padding: 1rem;
            border: 1px dashed var(--sd-border);
            border-radius: 18px;
            color: var(--sd-muted);
        }

            .sd-soft-empty.compact {
                min-height: 190px;
            }

            .sd-soft-empty i {
                color: var(--sd-green);
                font-size: 1.35rem;
            }

            .sd-soft-empty p {
                margin: 0;
                font-size: .82rem;
            }

        .sd-empty {
            min-height: 460px;
            display: grid;
            place-items: center;
            align-content: center;
            text-align: center;
            gap: .65rem;
            padding: 2rem;
        }

        .sd-empty-icon {
            width: 76px;
            height: 76px;
            display: grid;
            place-items: center;
            color: var(--sd-steel);
            background: #EEF2F6;
            border-radius: 26px;
            font-size: 1.95rem;
        }

        .sd-empty h2 {
            margin: 0;
            font-size: 1.3rem;
            font-weight: 500;
        }

        .sd-empty p {
            max-width: 560px;
            margin: 0;
            color: var(--sd-muted);
            line-height: 1.6;
        }

        @@media (max-width: 1280px) {
            .sd-hero,
            .sd-grid-top,
            .sd-grid-bottom {
                grid-template-columns: 1fr;
            }

            .sd-stats {
                grid-template-columns: repeat(2, minmax(0, 1fr));
            }
        }

        @@media (max-width: 767px) {
            .sd-stats,
            .sd-action-grid {
                grid-template-columns: 1fr;
            }

            .sd-hero {
                padding: 1rem;
            }

            .sd-hero-focus {
                min-height: 105px;
            }

            .sd-review-card,
            .sd-student-row,
            .sd-meeting-row {
                grid-template-columns: auto minmax(0, 1fr);
            }

            .sd-card-arrow,
            .sd-dots,
            .sd-student-status {
                display: none;
            }
        }
    </style>
}

@functions {
    private static string NormalizeStatus(string? status)
    {
        return string.IsNullOrWhiteSpace(status)
            ? "pending"
            : status.Trim().ToLowerInvariant();
    }

    private static (string Label, string ClassName) StatusMeta(string? status)
    {
        return NormalizeStatus(status) switch
        {
            "approved" => ("Approved", "sd-status approved"),
            "needs_revision" => ("Needs Revision", "sd-status revision"),
            "rejected" => ("Rejected", "sd-status rejected"),
            _ => ("Pending", "sd-status pending")
        };
    }

    private static (string Label, string ClassName, string Icon) StudentStatus(
        int pending,
        int revision,
        int rejected,
        int approved)
    {
        if (rejected > 0)
        {
            return ("At Risk", "sd-status risk", "bi bi-exclamation-triangle");
        }

        if (revision > 0)
        {
            return ("Needs Revision", "sd-status revision", "bi bi-pencil-square");
        }

        if (pending > 0)
        {
            return ("Pending", "sd-status pending", "bi bi-hourglass-split");
        }

        return ("On Track", "sd-status ontrack", "bi bi-check2-circle");
    }

    private static string NextActionLabel(int pending, int revision, int rejected)
    {
        if (rejected > 0)
        {
            return "Follow up";
        }

        if (revision > 0)
        {
            return "Review feedback";
        }

        if (pending > 0)
        {
            return "Review idea";
        }

        return "Progress check";
    }

    private static string MeetingPurpose(int pending, int revision, int rejected)
    {
        if (rejected > 0)
        {
            return "Recovery discussion";
        }

        if (revision > 0)
        {
            return "Revision follow-up";
        }

        if (pending > 0)
        {
            return "Proposal review meeting";
        }

        return "Progress check-in";
    }

    private static string NextMeetingHint(int pending, int revision, int rejected)
    {
        if (rejected > 0)
        {
            return "Discuss a new project direction.";
        }

        if (revision > 0)
        {
            return "Clarify required changes.";
        }

        if (pending > 0)
        {
            return "Prepare review decision.";
        }

        return "Check milestones and next tasks.";
    }

    private static string Initials(string? name)
    {
        if (string.IsNullOrWhiteSpace(name))
        {
            return "ST";
        }

        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries).Take(2).ToList();

        return parts.Count == 0
            ? "ST"
            : string.Join("", parts.Select(part => part[0])).ToUpperInvariant();
    }

    private static string ValueOrStudent(string? value)
    {
        return string.IsNullOrWhiteSpace(value) ? "Student" : value;
    }

    private static string ValueOrDash(string? value)
    {
        return string.IsNullOrWhiteSpace(value) ? "Uncategorized" : value;
    }

    private static string TimeAgo(DateTime date)
    {
        var value = date.Kind == DateTimeKind.Utc
            ? date
            : DateTime.SpecifyKind(date, DateTimeKind.Utc);

        var span = DateTime.UtcNow - value;

        if (span.TotalDays >= 7)
        {
            return value.ToLocalTime().ToString("MMM d");
        }

        if (span.TotalDays >= 1)
        {
            var days = (int)Math.Floor(span.TotalDays);
            return days == 1 ? "1 day ago" : $"{days} days ago";
        }

        if (span.TotalHours >= 1)
        {
            var hours = (int)Math.Floor(span.TotalHours);
            return hours == 1 ? "1 hour ago" : $"{hours} hours ago";
        }

        if (span.TotalMinutes >= 1)
        {
            var minutes = (int)Math.Floor(span.TotalMinutes);
            return minutes == 1 ? "1 min ago" : $"{minutes} mins ago";
        }

        return "Just now";
    }
}