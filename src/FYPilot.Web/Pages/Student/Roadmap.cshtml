        .roadmap-detail-panel {
            display: none;
            padding: 1.05rem;
        }

        .roadmap-detail-panel.is-active {
            display: block;
        }

        .roadmap-detail-header {
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
            gap: 1rem;
            padding-bottom: 1rem;
            border-bottom: 1px solid var(--roadmap-border);
        }

        .roadmap-detail-kicker {
            display: flex;
            align-items: center;
            flex-wrap: wrap;
            gap: .45rem;
            color: var(--roadmap-blue);
            font-size: .7rem;
            font-weight: 800;
            text-transform: uppercase;
        }

        .roadmap-detail-kicker span {
            padding: .18rem .4rem;
            color: var(--roadmap-muted);
            background: #f4f6f8;
            border-radius: 999px;
            font-size: .62rem;
            text-transform: none;
