@page
@model FYPilot.Web.Pages.Supervisor.IdeaReviewModel
@{
    ViewData["Title"]    = "Idea Review";
    ViewData["Subtitle"] = "Evaluate and provide feedback on student project ideas";
}

<div class="row g-4">
    <!-- Ideas list -->
    <div class="col-lg-4">
        <div class="page-card p-3">
            <h6 class="fw-bold mb-3 small text-muted text-uppercase">Student Ideas</h6>
            @foreach (var idea in Model.AllIdeas)
            {
                <a href="/Supervisor/IdeaReview?ideaId=@idea.Id"
                   class="d-block p-3 rounded-2 mb-1 text-decoration-none @(idea.Id == Model.SelectedIdea?.Id ? "bg-primary-subtle" : "bg-light hover-bg-light")">
                    <div class="d-flex align-items-start justify-content-between">
                        <div>
                            <div class="small fw-semibold text-dark">@idea.Title.Substring(0, Math.Min(idea.Title.Length, 35))…</div>
                            <div class="text-muted-sm">@(idea.User?.FullName ?? "Student")</div>
                        </div>
                        <span class="badge @(idea.Id == Model.SelectedIdea?.Id ? "bg-primary" : "bg-secondary-subtle text-secondary")">@idea.FeasibilityScore%</span>
                    </div>
                </a>
            }
            @if (!Model.AllIdeas.Any())
            {
                <div class="text-muted small p-2">No ideas submitted for review.</div>
            }
        </div>
    </div>

    <!-- Review form -->
    <div class="col-lg-8">
        @if (Model.SelectedIdea == null)
        {
            <div class="page-card p-5 text-center text-muted">
                <i class="bi bi-card-checklist display-4"></i>
                <p class="mt-3">Select a student idea from the list to review it.</p>
            </div>
        }
        else
        {
            var idea = Model.SelectedIdea;
            <div class="page-card p-4 mb-3">
                <div class="d-flex align-items-start justify-content-between mb-3">
                    <div>
                        <h5 class="fw-bold mb-1">@idea.Title</h5>
                        <div class="d-flex gap-1 flex-wrap">
                            <span class="badge bg-primary-subtle text-primary">@idea.Domain</span>
                            <span class="badge bg-warning-subtle text-warning text-capitalize">@idea.DifficultyLevel</span>
                            <span class="badge bg-secondary-subtle text-secondary">@idea.ExpectedDurationWeeks weeks</span>
                        </div>
                    </div>
                    <div class="text-end">
                        <div class="score-ring text-success" style="width:56px;height:56px;font-size:0.9rem">@idea.FeasibilityScore%</div>
                    </div>
                </div>
                <div class="row g-3 mb-2 small">
                    <div class="col-6">
                        <div class="fw-semibold text-muted mb-1">Problem</div>
                        <div>@idea.ProblemStatement</div>
                    </div>
                    <div class="col-6">
                        <div class="fw-semibold text-muted mb-1">Target Users</div>
                        <div>@idea.TargetUsers</div>
                    </div>
                    <div class="col-6">
                        <div class="fw-semibold text-muted mb-1">Technologies</div>
                        <div>@idea.RequiredTechnologies</div>
                    </div>
                    <div class="col-6">
                        <div class="fw-semibold text-muted mb-1">Dataset</div>
                        <div>@(string.IsNullOrEmpty(idea.DatasetNeeded) ? "None" : idea.DatasetNeeded)</div>
                    </div>
                </div>
                <div class="d-flex gap-3 small">
                    <div>Innovation: <strong>@idea.InnovationScore%</strong></div>
                    <div>Market: <strong>@idea.MarketDemandScore%</strong></div>
                </div>
            </div>

            <div class="page-card p-4">
                <h6 class="fw-bold mb-3"><i class="bi bi-pencil-square me-2"></i>Supervisor Evaluation</h6>
                <form method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="IdeaId" value="@idea.Id" />
                    <div class="mb-3">
                        <label class="form-label fw-semibold small">Decision</label>
                        @{
                            var evalStatus = Model.Evaluation?.Status ?? "pending";
                        }
                        <select name="Status" class="form-select">
                            @if (evalStatus == "pending") { <option value="pending" selected>Pending Review</option> } else { <option value="pending">Pending Review</option> }
                            @if (evalStatus == "approved") { <option value="approved" selected>Approve</option> } else { <option value="approved">Approve</option> }
                            @if (evalStatus == "needs_revision") { <option value="needs_revision" selected>Needs Revision</option> } else { <option value="needs_revision">Needs Revision</option> }
                            @if (evalStatus == "rejected") { <option value="rejected" selected>Reject</option> } else { <option value="rejected">Reject</option> }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold small">Comments</label>
                        <textarea name="Comment" class="form-control" rows="4" placeholder="Provide detailed feedback…">@Model.Evaluation?.Comment</textarea>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold small">Improvement Suggestions</label>
                        <textarea name="ImprovementSuggestions" class="form-control" rows="3" placeholder="Specific improvements the student should make…">@Model.Evaluation?.ImprovementSuggestions</textarea>
                    </div>
                    <div class="row g-2 mb-3">
                        <div class="col-6">
                            <label class="form-label fw-semibold small">Originality Score (0–100)</label>
                            <input type="number" name="OriginalityScore" class="form-control" min="0" max="100" value="@(Model.Evaluation?.OriginalityScore ?? 75)" />
                        </div>
                        <div class="col-6">
                            <label class="form-label fw-semibold small">Similarity Score (0–100)</label>
                            <input type="number" name="SimilarityScore" class="form-control" min="0" max="100" value="@(Model.Evaluation?.SimilarityScore ?? 25)" />
                        </div>
                    </div>
                    <button type="submit" class="btn btn-primary fw-semibold">
                        <i class="bi bi-save me-2"></i>Save Evaluation
                    </button>
                </form>
            </div>
        }
    </div>
</div>
