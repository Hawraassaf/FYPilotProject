        .pd-light-btn {
            border-radius: 14px;
            padding: 0.65rem 0.95rem;
            font-size: 0.86rem;
            font-weight: 760;
        }

        .pd-primary-btn {
            color: #ffffff;
            background: linear-gradient(135deg, #304163, #516C8D);
            border: 1px solid rgba(81,108,141,0.25);
        }

            .pd-primary-btn:hover {
                color: #ffffff;
                background: linear-gradient(135deg, #28385E, #304163);
            }

        .pd-light-btn {
            color: #304163;
            background: #ffffff;
            border: 1px solid #DDE5EF;
        }

            .pd-light-btn:hover {
                color: #28385E;
                background: #F7F8FA;
            }

        @@media (max-width: 1199px) {
            .pd-hero,
            .pd-layout {
                grid-template-columns: 1fr;
            }

            .pd-sidebar {
                position: static;
            }
        }

        @@media (max-width: 767px) {
            .pd-hero {
                padding: 1rem;
            }

            .pd-overview-grid,
            .pd-tech-grid {
                grid-template-columns: 1fr;
            }

            .pd-info-block,
            .pd-info-block.wide {
                grid-column: auto;
            }

            .pd-info-block {
                flex-direction: column;
            }

            .pd-empty-actions {
                flex-direction: column;
                width: 100%;
            }

                .pd-empty-actions .btn {
                    width: 100%;
                }
        }
    </style>
}

@functions {
    private static bool HasText(string? value)
    {
        return !string.IsNullOrWhiteSpace(value);
    }

    private static List<string> SplitItems(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return [];
        }

        return value
            .Split(new[] { ',', ';', '\n', '\r' }, StringSplitOptions.RemoveEmptyEntries)
            .Select(item => item.Trim())
            .Where(item => item.Length > 0)
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .ToList();
    }

    private static bool HasUsefulDataset(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return false;
        }

        var normalized = value.Trim();

        if (normalized.Equals("None", StringComparison.OrdinalIgnoreCase) ||
            normalized.Equals("No", StringComparison.OrdinalIgnoreCase) ||
            normalized.Equals("N/A", StringComparison.OrdinalIgnoreCase) ||
            normalized.Contains("not required", StringComparison.OrdinalIgnoreCase) ||
            normalized.Contains("no dataset", StringComparison.OrdinalIgnoreCase))
        {
            return false;
        }

        return true;
    }

    private static string NormalizeSkill(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return "";
        }

        return value
            .Trim()
            .ToLowerInvariant()
            .Replace(" ", "")
            .Replace("-", "")
            .Replace("_", "");
    }

    private static int ClampScore(int value)
    {
        return Math.Clamp(value, 0, 100);
    }

    private static string ScoreLabel(int score)
    {
        score = ClampScore(score);

        if (score >= 85)
        {
            return "Excellent";
        }

        if (score >= 70)
        {
            return "Strong";
        }

        if (score >= 55)
        {
            return "Moderate";
        }

        return "Needs Review";
    }
}
