@page
@model FYPilot.Web.Pages.Student.DefenseSimulatorModel
@{
    ViewData["Title"] = "Defense Simulator";
    ViewData["Subtitle"] = "Project-aware AI practice with answer evaluation.";

    var hasQuestions = Model.State.Questions.Count > 0;
    var totalQuestions = Model.State.Questions.Count;
    var selectedFocusSet = Model.FocusAreas.ToHashSet(StringComparer.OrdinalIgnoreCase);
}

<section class="defense-page">
    <header class="defense-hero">
        <div class="defense-hero__content">
            <div class="defense-hero__eyebrow">
                <span class="defense-live-dot"></span>
                AI Defense Simulator
            </div>

            <h1>Train for your FYP defense with questions built around your real project.</h1>

            <p>
                Choose the technical areas you want to practice, answer before seeing the reference response,
                and receive AI feedback on coverage, clarity, missing points, and confidence.
            </p>

            <div class="defense-hero__actions">
                <a href="#practice-config" class="defense-button defense-button--light">
                    <i class="bi bi-play-circle"></i>
                    Start practice
                </a>

                <a asp-page="/Student/IdeaGenerator" class="defense-button defense-button--ghost">
                    <i class="bi bi-lightbulb"></i>
                    Change idea
                </a>

                <a asp-page="/Student/Dashboard" class="defense-button defense-button--ghost">
                    <i class="bi bi-grid"></i>
                    Dashboard
                </a>
            </div>
        </div>

        <div class="defense-hero__stats">
            <article>
                <span>@totalQuestions</span>
                <small>Questions</small>
            </article>

            <article>
                <span>@Model.EvaluatedCount</span>
                <small>Evaluated</small>
            </article>

            <article>
                <span>@Model.CompletionPercent%</span>
                <small>Progress</small>
            </article>
        </div>
    </header>

    <div class="defense-toast-stack"
         id="defense-toast-stack"
         aria-live="polite"
         aria-atomic="true">

        @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
        {
            <div class="defense-toast defense-toast--error is-visible"
                 role="alert"
                 data-defense-toast
                 data-auto-dismiss="5200">

                <span class="defense-toast__icon">
                    <i class="bi bi-exclamation-circle"></i>
                </span>

                <div class="defense-toast__content">
                    <strong>Unable to continue</strong>
                    <span>@Model.ErrorMessage</span>
                </div>

                <button type="button"
                        class="defense-toast__close"
                        data-toast-close
                        aria-label="Dismiss message">
                    <i class="bi bi-x-lg"></i>
                </button>

                <span class="defense-toast__timer"></span>
            </div>
        }

        @if (!string.IsNullOrWhiteSpace(Model.SuccessMessage))
        {
            <div class="defense-toast defense-toast--info is-visible"
                 role="status"
                 data-defense-toast
                 data-auto-dismiss="4200">

                <span class="defense-toast__icon">
                    <i class="bi bi-check2-circle"></i>
                </span>

                <div class="defense-toast__content">
                    <strong>Completed</strong>
                    <span>@Model.SuccessMessage</span>
                </div>

                <button type="button"
                        class="defense-toast__close"
                        data-toast-close
                        aria-label="Dismiss message">
                    <i class="bi bi-x-lg"></i>
                </button>

                <span class="defense-toast__timer"></span>
            </div>
        }
    </div>

    @if (Model.Idea == null)
    {
        <section class="defense-empty">
            <div class="defense-empty__icon">
                <i class="bi bi-shield-exclamation"></i>
            </div>

            <span class="defense-kicker">Project required</span>
            <h2>Select a project before starting a defense session.</h2>
            <p>
                The simulator needs your idea, technologies, target users, roadmap, and skills
                to produce realistic professor-style questions.
            </p>

            <a asp-page="/Student/IdeaGenerator" class="defense-button defense-button--primary">
                <i class="bi bi-lightbulb"></i>
                Select a project idea
            </a>
        </section>
    }
    else
    {
        <section class="defense-context">
            <div class="defense-context__main">
                <span class="defense-kicker">Active project context</span>
                <h2>@Model.Idea.Title</h2>
                <p>
                    @(
                        string.IsNullOrWhiteSpace(Model.Idea.ProblemStatement)
                            ? "No problem statement is available."
                            : Model.Idea.ProblemStatement
                    )
                </p>
            </div>

            <div class="defense-context__tags">
                <span>
                    <i class="bi bi-folder2-open"></i>
                    @(string.IsNullOrWhiteSpace(Model.Idea.Domain) ? "General domain" : Model.Idea.Domain)
                </span>

                <span>
                    <i class="bi bi-cpu"></i>
                    @(string.IsNullOrWhiteSpace(Model.Idea.RequiredTechnologies) ? "Technology stack" : Model.Idea.RequiredTechnologies)
                </span>

                <span>
                    <i class="bi bi-shield-check"></i>
                    Answers stay hidden until evaluation
                </span>
            </div>
        </section>

        <div class="defense-grid">
            <main class="defense-main">
                <section class="defense-panel" id="practice-config">
                    <div class="defense-panel__header">
                        <div>
                            <span class="defense-kicker">Practice setup</span>
                            <h2>Build your question set</h2>
                            <p>Choose 1–5 questions and at least one defense field.</p>
                        </div>

                        <div class="defense-step-badge">
                            <i class="bi bi-sliders"></i>
                            Session setup
                        </div>
                    </div>

                    <form method="post"
                          asp-page-handler="Generate"
                          id="defense-config-form"
                          class="defense-config-form">

                        <fieldset class="defense-fieldset">
                            <legend>
                                <span>01</span>
                                Number of questions
                            </legend>

                            <div class="defense-count-picker" role="radiogroup" aria-label="Number of questions">
                                @for (var number = 1; number <= 5; number++)
                                {
                                    var id = $"question-count-{number}";

                                    <label for="@id">
                                        @if (Model.NumberOfQuestions == number)
                                        {
                                            <input id="@id"
                                                   type="radio"
                                                   name="NumberOfQuestions"
                                                   value="@number"
                                                   checked />
                                        }
                                        else
                                        {
                                            <input id="@id"
                                                   type="radio"
                                                   name="NumberOfQuestions"
                                                   value="@number" />
                                        }

                                        <span>@number</span>
                                    </label>
                                }
                            </div>
                        </fieldset>

                        <fieldset class="defense-fieldset">
                            <legend>
                                <span>02</span>
                                Defense fields
                            </legend>

                            <div class="defense-area-grid" id="defense-area-grid">
                                @foreach (var area in Model.AvailableFocusAreas)
                                {
                                    var id = $"focus-{area.Value.GetHashCode():X}";

                                    <label class="defense-area-card" for="@id">
                                        @if (selectedFocusSet.Contains(area.Value))
                                        {
                                            <input id="@id"
                                                   type="checkbox"
                                                   name="FocusAreas"
                                                   value="@area.Value"
                                                   checked />
                                        }
                                        else
                                        {
                                            <input id="@id"
                                                   type="checkbox"
                                                   name="FocusAreas"
                                                   value="@area.Value" />
                                        }

                                        <span class="defense-area-card__icon">
                                            <i class="bi @area.Icon"></i>
                                        </span>

                                        <span class="defense-area-card__copy">
                                            <strong>@area.Title</strong>
                                            <small>@area.Description</small>
                                        </span>

                                        <span class="defense-area-card__check">
                                            <i class="bi bi-check-lg"></i>
                                        </span>
                                    </label>
                                }
                            </div>
                        </fieldset>

                        <div class="defense-config-footer">
                            <div class="defense-config-note">
                                <i class="bi bi-lock"></i>
                                Reference points are not shown before the student submits an answer.
                            </div>

                            <button type="submit" class="defense-button defense-button--primary defense-button--large">
                                <i class="bi bi-stars"></i>
                                Generate questions
                            </button>
                        </div>
                    </form>
                </section>

                @if (hasQuestions)
                {
                    <section class="defense-panel defense-session">
                        <div class="defense-panel__header defense-panel__header--session">
                            <div>
                                <span class="defense-kicker">Active practice session</span>
                                <h2>Professor-style questions</h2>

                                <div class="defense-session__meta">
                                    <span>
                                        <i class="bi bi-stars"></i>
                                        Project-aware questions
                                    </span>

                                    <span>
                                        <i class="bi bi-clock-history"></i>
                                        @Model.State.GeneratedAt.ToLocalTime().ToString("dd MMM, HH:mm")
                                    </span>
                                </div>
                            </div>

                            <div class="defense-session__actions">
                                <form method="post" asp-page-handler="Regenerate">
                                    <button type="submit" class="defense-button defense-button--secondary">
                                        <i class="bi bi-arrow-repeat"></i>
                                        Regenerate same fields
                                    </button>
                                </form>

                                <form method="post" asp-page-handler="Reset">
                                    <button type="submit" class="defense-button defense-button--quiet">
                                        <i class="bi bi-sliders"></i>
                                        Choose different fields
                                    </button>
                                </form>
                            </div>
                        </div>

                        <div class="defense-progress-card">
                            <div>
                                <strong>@Model.EvaluatedCount of @totalQuestions evaluated</strong>
                                <span>Complete every answer to finish this practice round.</span>
                            </div>

                            <b>@Model.CompletionPercent%</b>

                            <div class="defense-progress-track" aria-label="Session completion">
                                <span style="width:@Model.CompletionPercent%"></span>
                            </div>
                        </div>

                        <div class="defense-selected-areas">
                            @foreach (var area in Model.State.FocusAreas)
                            {
                                <span>
                                    <i class="bi bi-check2-circle"></i>
                                    @area
                                </span>
                            }
                        </div>

                        <div class="defense-question-list">
                            @for (var index = 0; index < Model.State.Questions.Count; index++)
                            {
                                var item = Model.State.Questions[index];
                                var question = item.Question;
                                var evaluation = item.Evaluation;
                                var answerId = $"student-answer-{index}";

                                <article class="defense-question-card @(evaluation != null ? "is-evaluated" : "")">
                                    <header class="defense-question-card__header">
                                        <div class="defense-question-number">
                                            @((index + 1).ToString("00"))
                                        </div>

                                        <div class="defense-question-title">
                                            <div class="defense-question-tags">
                                                <span>
                                                    <i class="bi bi-tag"></i>
                                                    @(string.IsNullOrWhiteSpace(question.Category) ? "General" : question.Category)
                                                </span>

                                                <span>
                                                    <i class="bi bi-bar-chart"></i>
                                                    @(string.IsNullOrWhiteSpace(question.Difficulty) ? "Medium" : question.Difficulty)
                                                </span>

                                                @if (evaluation != null)
                                                {
                                                    <span class="is-complete">
                                                        <i class="bi bi-check-circle-fill"></i>
                                                        Evaluated
                                                    </span>
                                                }
                                            </div>

                                            <h3>@question.Question</h3>
                                        </div>
                                    </header>

                                    <div class="defense-question-card__body">
                                        <form method="post"
                                              asp-page-handler="Evaluate"
                                              class="defense-answer-form"
                                              data-answer-form>

                                            <input type="hidden" name="QuestionIndex" value="@index" />

                                            <label for="@answerId">
                                                Your answer
                                                <small>
                                                    Explain your reasoning in your own words. Exact wording is not required.
                                                </small>
                                            </label>

                                            <textarea id="@answerId"
                                                      name="StudentAnswer"
                                                      rows="6"
                                                      maxlength="4000"
                                                      data-answer-textarea
                                                      placeholder="Write your defense answer here...">@item.StudentAnswer</textarea>

                                            <div class="defense-answer-form__footer">
                                                <span data-word-count>0 words</span>

                                                <button type="submit" class="defense-button defense-button--primary">
                                                    <i class="bi bi-clipboard-check"></i>
                                                    @(evaluation == null ? "Check my answer" : "Re-check answer")
                                                </button>
                                            </div>
                                        </form>

                                        @if (evaluation == null)
                                        {
                                            <div class="defense-locked">
                                                <i class="bi bi-lock"></i>
                                                <div>
                                                    <strong>Reference answer locked</strong>
                                                    <span>Submit your answer first to reveal feedback and the suggested response.</span>
                                                </div>
                                            </div>
                                        }
                                        else
                                        {
                                            <section class="defense-evaluation">
                                                <div class="defense-evaluation__heading">
                                                    <div>
                                                        <span class="defense-kicker">AI evaluation</span>
                                                        <h4>@evaluation.Level</h4>
                                                    </div>

                                                    <div class="defense-score-ring"
                                                         style="--score:@evaluation.Score">
                                                        <strong>@evaluation.Score</strong>
                                                        <small>/100</small>
                                                    </div>
                                                </div>

                                                <div class="defense-score-grid">
                                                    <article>
                                                        <span>Overall score</span>
                                                        <strong>@evaluation.Score%</strong>
                                                        <div><i style="width:@evaluation.Score%"></i></div>
                                                    </article>

                                                    @if (evaluation.SimilarityScore.HasValue)
                                                    {
                                                        <article>
                                                            <span>Semantic coverage</span>
                                                            <strong>@evaluation.SimilarityScore.Value%</strong>
                                                            <div><i style="width:@evaluation.SimilarityScore.Value%"></i></div>
                                                        </article>
                                                    }

                                                    @if (evaluation.ConfidenceScore.HasValue)
                                                    {
                                                        <article>
                                                            <span>AI confidence</span>
                                                            <strong>@evaluation.ConfidenceScore.Value%</strong>
                                                            <div><i style="width:@evaluation.ConfidenceScore.Value%"></i></div>
                                                        </article>
                                                    }
                                                </div>

                                                @if (!string.IsNullOrWhiteSpace(evaluation.FeedbackSummary))
                                                {
                                                    <div class="defense-feedback-summary">
                                                        <i class="bi bi-chat-square-quote"></i>
                                                        <p>@evaluation.FeedbackSummary</p>
                                                    </div>
                                                }

                                                <div class="defense-feedback-grid">
                                                    <article class="defense-feedback-card defense-feedback-card--positive">
                                                        <header>
                                                            <i class="bi bi-check-circle"></i>
                                                            Strengths
                                                        </header>

                                                        @if (evaluation.Strengths.Count == 0)
                                                        {
                                                            <p>No specific strengths were returned.</p>
                                                        }
                                                        else
                                                        {
                                                            <ul>
                                                                @foreach (var strength in evaluation.Strengths)
                                                                {
                                                                    <li>@strength</li>
                                                                }
                                                            </ul>
                                                        }
                                                    </article>

                                                    <article class="defense-feedback-card defense-feedback-card--warning">
                                                        <header>
                                                            <i class="bi bi-exclamation-circle"></i>
                                                            Missing points
                                                        </header>

                                                        @if (evaluation.MissingPoints.Count == 0)
                                                        {
                                                            <p>No major missing points were identified.</p>
                                                        }
                                                        else
                                                        {
                                                            <ul>
                                                                @foreach (var point in evaluation.MissingPoints)
                                                                {
                                                                    <li>@point</li>
                                                                }
                                                            </ul>
                                                        }
                                                    </article>
                                                </div>

                                                <details class="defense-reference">
                                                    <summary>
                                                        <span>
                                                            <i class="bi bi-stars"></i>
                                                            View suggested answer
                                                        </span>

                                                        <i class="bi bi-chevron-down"></i>
                                                    </summary>

                                                    <div class="defense-reference__body">
                                                        @if (!string.IsNullOrWhiteSpace(evaluation.ImprovedAnswer))
                                                        {
                                                            <div>
                                                                <span class="defense-reference__label">Improved answer</span>
                                                                <p>@evaluation.ImprovedAnswer</p>
                                                            </div>
                                                        }

                                                        @if (question.ExpectedPoints?.Count > 0)
                                                        {
                                                            <div>
                                                                <span class="defense-reference__label">Expected coverage</span>
                                                                <ul>
                                                                    @foreach (var point in question.ExpectedPoints)
                                                                    {
                                                                        <li>@point</li>
                                                                    }
                                                                </ul>
                                                            </div>
                                                        }
                                                    </div>
                                                </details>

                                                @if (!string.IsNullOrWhiteSpace(evaluation.FollowUpQuestion))
                                                {
                                                    <div class="defense-follow-up">
                                                        <i class="bi bi-arrow-return-right"></i>
                                                        <div>
                                                            <span>Professor follow-up</span>
                                                            <strong>@evaluation.FollowUpQuestion</strong>
                                                        </div>
                                                    </div>
                                                }
                                            </section>
                                        }
                                    </div>
                                </article>
                            }
                        </div>
                    </section>
                }
                else
                {
                    <section class="defense-placeholder">
                        <div class="defense-placeholder__visual">
                            <i class="bi bi-mortarboard"></i>
                        </div>

                        <span class="defense-kicker">Ready when you are</span>
                        <h2>Your questions will appear here.</h2>
                        <p>
                            Select the number of questions and the defense fields above,
                            then generate a focused practice session.
                        </p>
                    </section>
                }
            </main>

            <aside class="defense-sidebar">
                <article class="defense-side-card defense-side-card--guide">
                    <header>
                        <span class="defense-kicker">Answer clearly</span>
                        <h3>A simple structure for every response</h3>
                        <p>Keep your explanation direct and connected to your own project.</p>
                    </header>

                    <div class="defense-answer-guide">
                        <div>
                            <span>1</span>
                            <div>
                                <h4>State your decision</h4>
                                <p>Begin with the main answer in one clear sentence.</p>
                            </div>
                        </div>

                        <div>
                            <span>2</span>
                            <div>
                                <h4>Explain your reason</h4>
                                <p>Connect the choice to your users, architecture, data, or requirements.</p>
                            </div>
                        </div>

                        <div>
                            <span>3</span>
                            <div>
                                <h4>Mention a trade-off</h4>
                                <p>Show that you understand one limitation and how you would handle it.</p>
                            </div>
                        </div>
                    </div>
                </article>

                <article class="defense-side-card defense-side-card--check">
                    <header>
                        <span class="defense-kicker">Before you submit</span>
                        <h3>Quick answer check</h3>
                        <p>Use these points to make your answer easier to evaluate.</p>
                    </header>

                    <ul class="defense-checklist">
                        <li>
                            <i class="bi bi-check2"></i>
                            <span>Did I answer the exact question first?</span>
                        </li>
                        <li>
                            <i class="bi bi-check2"></i>
                            <span>Did I connect the explanation to my project?</span>
                        </li>
                        <li>
                            <i class="bi bi-check2"></i>
                            <span>Did I explain why this choice is suitable?</span>
                        </li>
                        <li>
                            <i class="bi bi-check2"></i>
                            <span>Did I mention evidence, testing, or one limitation?</span>
                        </li>
                    </ul>

                    <div class="defense-side-note">
                        <i class="bi bi-info-circle"></i>
                        <span>Natural wording is accepted. The evaluator checks meaning, not memorized sentences.</span>
                    </div>
                </article>
            </aside>
        </div>
    }
</section>

<div class="defense-busy" id="defense-busy" hidden>
    <div>
        <span class="defense-spinner"></span>
        <strong>Working with the AI service…</strong>
        <small>This may take a few seconds.</small>
    </div>
</div>

@section Head {
    <style>
        :root {
            --defense-ink: #0f172a;
            --defense-muted: #64748b;
            --defense-border: #e2e8f0;
            --defense-soft: #f8fafc;
            --defense-navy: #071d49;
            --defense-blue: #304163;
            --defense-steel: #516c8d;
            --defense-accent: #516c8d;
            --defense-amber: #b45309;
            --defense-red: #b91c1c;
            --defense-shadow: 0 12px 30px rgba(15, 23, 42, .055);
        }

        .defense-page {
            max-width: 1500px;
            margin: 0 auto;
            padding-bottom: 2rem;
            color: var(--defense-ink);
        }

        .defense-hero {
            position: relative;
            display: grid;
            grid-template-columns: minmax(0, 1fr) auto;
            gap: 1.5rem;
            align-items: center;
            margin-bottom: 1rem;
            padding: clamp(1.35rem, 3vw, 2.2rem);
            overflow: hidden;
            border-radius: 26px;
            color: #fff;
            background: radial-gradient(circle at 8% 0%, rgba(255,255,255,.17), transparent 28%), radial-gradient(circle at 94% 12%, rgba(255,255,255,.11), transparent 22%), linear-gradient(135deg, #061a43 0%, #233759 55%, #516c8d 130%);
            box-shadow: 0 18px 42px rgba(7, 29, 73, .14);
        }

            .defense-hero::after {
                content: "";
                position: absolute;
                right: -80px;
                bottom: -120px;
                width: 310px;
                height: 310px;
                border: 1px solid rgba(255,255,255,.12);
                border-radius: 50%;
                box-shadow: 0 0 0 35px rgba(255,255,255,.035), 0 0 0 70px rgba(255,255,255,.025);
            }

        .defense-hero__content,
        .defense-hero__stats {
            position: relative;
            z-index: 1;
        }

        .defense-hero__eyebrow,
        .defense-kicker {
            display: inline-flex;
            align-items: center;
            gap: .45rem;
            color: var(--defense-steel);
            font-size: .72rem;
            font-weight: 650;
            letter-spacing: .11em;
            text-transform: uppercase;
        }

        .defense-hero__eyebrow {
            color: rgba(255,255,255,.78);
        }

        .defense-live-dot {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background: #bfdbfe;
            box-shadow: 0 0 0 6px rgba(191, 219, 254, .16);
        }

        .defense-hero h1 {
            max-width: 900px;
            margin: .55rem 0 0;
            font-size: clamp(1.85rem, 3vw, 2.75rem);
            font-weight: 660;
            line-height: 1.12;
            letter-spacing: -.035em;
        }

        .defense-hero p {
            max-width: 820px;
            margin: .9rem 0 0;
            color: rgba(255,255,255,.78);
            font-size: .98rem;
            line-height: 1.72;
        }

        .defense-hero__actions {
            display: flex;
            flex-wrap: wrap;
            gap: .65rem;
            margin-top: 1.2rem;
        }

        .defense-hero__stats {
            display: grid;
            grid-template-columns: repeat(3, minmax(95px, 1fr));
            gap: .65rem;
            min-width: 330px;
        }

            .defense-hero__stats article {
                padding: 1rem .8rem;
                text-align: center;
                border: 1px solid rgba(255,255,255,.14);
                border-radius: 22px;
                background: rgba(255,255,255,.1);
                backdrop-filter: blur(10px);
            }

            .defense-hero__stats span {
                display: block;
                font-size: 1.8rem;
                font-weight: 680;
                line-height: 1;
            }

            .defense-hero__stats small {
                display: block;
                margin-top: .4rem;
                color: rgba(255,255,255,.68);
                font-size: .72rem;
            }

        .defense-button {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: .48rem;
            min-height: 42px;
            padding: .72rem 1rem;
            border: 1px solid transparent;
            border-radius: 14px;
            text-decoration: none;
            font-size: .84rem;
            font-weight: 640;
            cursor: pointer;
            transition: transform .16s ease, box-shadow .16s ease, background .16s ease;
        }

            .defense-button:hover {
                transform: translateY(-1px);
            }

        .defense-button--primary {
            color: #fff;
            background: linear-gradient(135deg, var(--defense-navy), var(--defense-blue));
            box-shadow: 0 12px 24px rgba(48, 65, 99, .18);
        }

            .defense-button--primary:hover {
