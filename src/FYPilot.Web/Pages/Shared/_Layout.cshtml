@using Microsoft.EntityFrameworkCore
@using FYPilot.Infrastructure.Data
@inject ApplicationDbContext Db

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] — FYPilot</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    @RenderSection("Head", required: false)
</head>

<body>
    @{
        var role = User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value;
        var userName = User.FindFirst(System.Security.Claims.ClaimTypes.Name)?.Value ?? "User";
        var isAuth = User.Identity?.IsAuthenticated == true;

        var userEmail =
            User.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value ?? "";

        var isMainAdmin = string.Equals(
            userEmail,
            "admin@fyp.com",
            StringComparison.OrdinalIgnoreCase);

        var path = Context.Request.Path.Value ?? "";

        string? navProfileImagePath = null;
        string? topbarProfileHref = null;

        if (isAuth)
        {
            var userIdValue = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;

            if (int.TryParse(userIdValue, out var navUserId))
            {
                var currentUserName = await Db.Users
                    .AsNoTracking()
                    .Where(u => u.Id == navUserId)
                    .Select(u => u.FullName)
                    .FirstOrDefaultAsync();

                if (!string.IsNullOrWhiteSpace(currentUserName))
                {
                    userName = currentUserName;
                }

                if (role == "student")
                {
                    topbarProfileHref = "/Student/Profile";

                    navProfileImagePath = await Db.StudentProfiles
                        .AsNoTracking()
                        .Where(p => p.UserId == navUserId)
                        .Select(p => p.ProfileImagePath)
                        .FirstOrDefaultAsync();
                }
                else if (role == "supervisor")
                {
                    topbarProfileHref = "/Supervisor/Profile";

                    navProfileImagePath = await Db.SupervisorProfiles
                        .AsNoTracking()
                        .Where(p => p.UserId == navUserId)
                        .Select(p => p.ProfileImagePath)
                        .FirstOrDefaultAsync();
                }
            }
        }

        string NavLink(string href, string icon, string label)
        {
            var active = path.Equals(href, StringComparison.OrdinalIgnoreCase) ||
                         (href != "/" && path.StartsWith(href, StringComparison.OrdinalIgnoreCase));

            return $"<a href=\"{href}\" class=\"side-nav-link{(active ? " active" : "")}\">" +
                   $"<i class=\"bi bi-{icon}\"></i><span>{label}</span></a>";
        }

        var initials = "U";

        if (!string.IsNullOrWhiteSpace(userName))
        {
            var parts = userName.Split(' ', StringSplitOptions.RemoveEmptyEntries);

            if (parts.Length >= 2)
            {
                initials = $"{parts[0][0]}{parts[1][0]}".ToUpper();
            }
            else
            {
                initials = userName[0].ToString().ToUpper();
            }
        }
    }

    @if (isAuth)
    {
        <div class="app-shell d-flex">

            <aside class="offcanvas-lg offcanvas-start app-sidebar d-flex flex-column flex-shrink-0"
                   tabindex="-1"
                   id="appSidebar">

                <div class="offcanvas-header d-lg-none app-sidebar-mobile-header">
                    <div class="d-flex align-items-center gap-2">
                        <div class="brand-icon">
                            <img src="/image/FYPilot_logo.png" alt="FYPilot Logo" />
                        </div>

                        <div>
                            <div class="brand-name">FYPilot</div>
                            <div class="brand-subtitle">Academic Intelligence</div>
                        </div>
                    </div>

                    <button type="button"
                            class="btn-close btn-close-white"
                            data-bs-dismiss="offcanvas"
                            data-bs-target="#appSidebar"
                            aria-label="Close">
                    </button>
                </div>

                <div class="sidebar-brand d-none d-lg-flex">
                    <div class="brand-icon">
                        <img src="/image/FYPilot_logo.png" alt="FYPilot Logo" />
                    </div>

                    <div>
                        <div class="brand-name">FYPilot</div>
                        <div class="brand-subtitle">Academic Intelligence</div>
                    </div>
                </div>

                <div class="sidebar-scroll flex-grow-1">
                    <ul class="list-unstyled side-nav">

                        @if (role == "student")
                        {
                            <li><span class="side-nav-label">My Workspace</span></li>
                            <li>@Html.Raw(NavLink("/Student/Dashboard", "grid", "Dashboard"))</li>
                            <li>  @Html.Raw( NavLink( "/Student/MyProjects",  "folder2-open", "My Projects")) </li>
                            <li>@Html.Raw(NavLink("/Student/SkillAssessment", "bar-chart-line", "Skill Assessment"))</li>

                            <li><span class="side-nav-label">AI Planning</span></li>
                            <li>@Html.Raw(NavLink("/Student/IdeaGenerator", "lightbulb", "Idea Generator"))</li>
                            <li>@Html.Raw(NavLink("/Student/MarketDemand", "graph-up-arrow", "Market Demand"))</li>
                            <li>@Html.Raw(NavLink("/Student/IdeaComparison", "columns-gap", "Idea Comparison"))</li>
                            <li>@Html.Raw(NavLink("/Student/ProjectDNA", "diagram-3", "Project DNA"))</li>
                            <li>@Html.Raw(NavLink("/Student/Roadmap", "map", "Roadmap"))</li>
                            <li>@Html.Raw(NavLink("/Student/DocumentationGenerator", "journal-code", "SE Documentation"))</li>

                            <li><span class="side-nav-label">Project Support</span></li>
                            <li>@Html.Raw(NavLink("/Student/MentorChat", "chat-dots", "Mentor Chat"))</li>
                            <li>@Html.Raw(NavLink("/Student/DefenseSimulator", "shield-check", "Defense Simulator"))</li>
                            <li>@Html.Raw(NavLink("/Student/Feedback", "chat-square-text", "Supervisor Feedback"))</li>
                        }

                        @if (role == "supervisor")
                        {
                            <li><span class="side-nav-label">Supervisor</span></li>
                            <li>@Html.Raw(NavLink("/Supervisor/Dashboard", "speedometer2", "Dashboard"))</li>
                            <li>@Html.Raw(NavLink("/Supervisor/IdeaReview", "card-checklist", "Feedback Workspace"))</li>
                            <li>@Html.Raw(NavLink("/Supervisor/Meetings", "calendar-event", "Meetings"))</li>
                            <li>@Html.Raw(NavLink("/Supervisor/Evaluations", "star-half", "Evaluations"))</li>
                            <li>@Html.Raw(NavLink("/Supervisor/ProgressTracking", "graph-up-arrow", "Progress Tracking"))</li>

                        }
                        @if (role == "admin")
                        {
                            <li><span class="side-nav-label">Administration</span></li>

                            <li>
                                @Html.Raw(
                                    NavLink(
                                        "/Admin/Dashboard",
                                        "speedometer2",
                                        "Dashboard"))
                            </li>

                            <li>
                                @Html.Raw(
                                    NavLink(
                                        "/Admin/Users",
                                        "people",
                                        "Users"))
                            </li>

                            <li>
                                @Html.Raw(
                                    NavLink(
                                        "/Admin/Analytics",
                                        "bar-chart",
                                        "Analytics"))
                            </li>

                            <li>
                                @Html.Raw(
                                    NavLink(
                                        "/Admin/SupervisorAssignments",
                                        "person-check",
                                        "Supervisor Assignments"))
                            </li>

                            @if (isMainAdmin)
                            {
                                <li>
                                    @Html.Raw(
                                        NavLink(
                                            "/Admin/AdminAccounts",
                                            "person-gear",
                                            "Manage Administrators"))
                                </li>
                            }

                            <li><span class="side-nav-label">System</span></li>

                            <li>
                                @Html.Raw(
                                    NavLink(
                                        "/SystemTest",
                                        "pc-display",
                                        "System Status"))
                            </li>
                        }
                    </ul>
                </div>
            </aside>

            <div class="app-main flex-grow-1 d-flex flex-column min-w-0">

                <header class="app-topbar">
                    <div class="d-flex align-items-center gap-3 min-w-0">

                        <button class="btn mobile-menu-btn d-lg-none"
                                type="button"
                                data-bs-toggle="offcanvas"
                                data-bs-target="#appSidebar"
                                aria-controls="appSidebar"
                                aria-label="Open menu">
                            <i class="bi bi-list"></i>
                        </button>

                        @if (role == "student" && path.Equals("/Student/Dashboard", StringComparison.OrdinalIgnoreCase))
                        {
                            <div class="page-heading dashboard-top-heading">
                                <h6 class="mb-0">
                                    Welcome, @userName!
                                </h6>
                            </div>
                        }
                        else
                        {
                            <div class="page-heading">
                                <h6 class="mb-0">@ViewData["Title"]</h6>

                                @if (ViewData["Subtitle"] is string sub)
                                {
                                    <div class="page-subtitle">@sub</div>
                                }
                            </div>
                        }
                    </div>

                    <div class="topbar-actions">
                        <form method="post" asp-page="/Account/Logout" class="d-none d-sm-block">
                            <button type="submit" class="topbar-logout">
                                <i class="bi bi-box-arrow-right me-1"></i>
                                Logout
                            </button>
                        </form>

                        @if (!string.IsNullOrWhiteSpace(topbarProfileHref))
                        {
                            <a href="@topbarProfileHref" class="topbar-user topbar-user-link" title="Open Profile">
                                @if (!string.IsNullOrWhiteSpace(navProfileImagePath))
                                {
                                    <img src="@navProfileImagePath"
                                         alt="@userName"
                                         class="topbar-avatar-img" />
                                }
                                else
                                {
                                    <div class="topbar-avatar">@initials</div>
                                }

                                <div class="d-none d-xl-block">
                                    <div class="topbar-user-name">@userName</div>
                                    <div class="topbar-user-meta text-capitalize">@role</div>
                                </div>

                                <i class="bi bi-chevron-down topbar-user-arrow d-none d-xl-inline"></i>
                            </a>
                        }
                        else
                        {
                            <div class="topbar-user">
                                <div class="topbar-avatar">@initials</div>

                                <div class="d-none d-xl-block">
                                    <div class="topbar-user-name">@userName</div>
                                    <div class="topbar-user-meta text-capitalize">@role</div>
                                </div>
                            </div>
                        }
                    </div>
                </header>

                <main class="app-content flex-grow-1 overflow-auto">
                    @if (TempData["Success"] is string sMsg)
                    {
                        <div class="alert alert-success alert-dismissible fade show app-alert auto-dismiss-alert" data-auto-dismiss="2000">
                            <i class="bi bi-check-circle me-2"></i>
                            @sMsg
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    }

                    @if (TempData["Error"] is string eMsg)
                    {
                        <div class="alert alert-danger alert-dismissible fade show app-alert" data-auto-dismiss="5000">
                            <i class="bi bi-exclamation-triangle me-2"></i>
                            @eMsg
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    }

                    @RenderBody()
                </main>
            </div>
        </div>
    }
    else
    {
        @RenderBody()
    }

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <script>
        document.addEventListener("DOMContentLoaded", function () {
        document.querySelectorAll(".auto-dismiss-alert").forEach(function (alertBox) {
        const delay = parseInt(alertBox.getAttribute("data-auto-dismiss") || "2000", 10);

        setTimeout(function () {
        alertBox.style.transition = "opacity 0.35s ease, transform 0.35s ease";
        alertBox.style.opacity = "0";
        alertBox.style.transform = "translateY(-6px)";

        setTimeout(function () {
        alertBox.remove();
        }, 350);
        }, delay);
        });
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>