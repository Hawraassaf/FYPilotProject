@page
@model FYPilot.Web.Pages.Student.ProjectDetailsModel
@{
    ViewData["Title"] = "Project Details";
    ViewData["Subtitle"] = "Full details of your generated or selected project idea";
}

@if (!string.IsNullOrWhiteSpace(Model.SuccessMessage))
{
    <div class="alert alert-success">
        <i class="bi bi-check-circle me-2"></i>@Model.SuccessMessage
    </div>
}

@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
{
    <div class="alert alert-danger">
        <i class="bi bi-exclamation-triangle me-2"></i>@Model.ErrorMessage
    </div>
}

@if (Model.Idea == null)
{
    <div class="page-card p-5 text-center">
        <i class="bi bi-folder2-open display-3 text-muted"></i>
        <h5 class="mt-3">No Project Selected</h5>
        <p class="text-muted">
            You have not selected a final project idea yet. Generate ideas and select one to view it here.
        </p>
        <a href="/Student/IdeaGenerator" class="btn btn-primary">
            <i class="bi bi-stars me-2"></i>Generate Ideas
        </a>
    </div>
}
else
{
    var idea = Model.Idea;
    var requiresDataset =
        !string.IsNullOrWhiteSpace(idea.DatasetNeeded) &&
        !idea.DatasetNeeded.Equals("None", StringComparison.OrdinalIgnoreCase);

    <div class="row g-4">
        <div class="col-lg-8">
            <div class="page-card p-4 mb-3">
                <div class="d-flex align-items-start justify-content-between mb-3">
                    <div>
                        <h5 class="fw-bold mb-1">@idea.Title</h5>

                        <div class="d-flex flex-wrap gap-1">
                            <span class="badge bg-primary-subtle text-primary">@idea.Domain</span>
                            <span class="badge bg-warning-subtle text-warning text-capitalize">@idea.DifficultyLevel</span>
                            <span class="badge bg-secondary-subtle text-secondary">@idea.ExpectedDurationWeeks weeks</span>

                            @if (idea.IsSelected)
                            {
                                <span class="badge bg-success-subtle text-success">
                                    <i class="bi bi-check-circle me-1"></i>Selected Project
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-light text-muted border">
                                    Not Selected
                                </span>
                            }
                        </div>
                    </div>

                    <div class="text-end">
                        <div class="score-ring @(idea.FeasibilityScore >= 70 ? "text-success" : idea.FeasibilityScore >= 50 ? "text-warning" : "text-danger")"
                             style="width:64px;height:64px;font-size:1rem">
                            @idea.FeasibilityScore%
                        </div>
                        <div class="small text-muted mt-1">Feasibility</div>
                    </div>
                </div>

                <h6 class="small fw-bold text-muted mb-1">Problem Statement</h6>
                <p class="text-muted small">@idea.ProblemStatement</p>

                <h6 class="small fw-bold text-muted mb-1">Target Users</h6>
                <p class="text-muted small">@idea.TargetUsers</p>

                <h6 class="small fw-bold text-muted mb-1">Why It Is Useful</h6>
                <p class="text-muted small">@idea.WhyUseful</p>

                <h6 class="small fw-bold text-muted mb-1">Lebanese Market Relevance</h6>
                <p class="text-muted small">
                    @(string.IsNullOrWhiteSpace(idea.LebaneseMarketRelevance)
                        ? "No Lebanese market relevance description was provided."
                        : idea.LebaneseMarketRelevance)
                </p>
            </div>

            <div class="page-card p-4">
                <h6 class="fw-bold mb-3">Technical and Delivery Details</h6>

                <div class="row g-3">
                    <div class="col-md-6">
                        <div class="small fw-semibold text-muted mb-1">Required Technologies</div>
                        <div class="small">@idea.RequiredTechnologies</div>
                    </div>

                    <div class="col-md-6">
                        <div class="small fw-semibold text-muted mb-1">Required Skills</div>
                        <div class="small">@idea.RequiredSkills</div>
                    </div>

                    <div class="col-md-6">
                        <div class="small fw-semibold text-muted mb-1">Missing Skills</div>
                        <div class="small">
                            @(string.IsNullOrWhiteSpace(idea.MissingSkills) ? "None" : idea.MissingSkills)
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="small fw-semibold text-muted mb-1">Dataset Requirement</div>
                        <div class="small">
                            @(requiresDataset ? idea.DatasetNeeded : "No dataset is required for this idea.")
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="small fw-semibold text-muted mb-1">Expected Duration</div>
                        <div class="small">@idea.ExpectedDurationWeeks weeks</div>
                    </div>

                    <div class="col-md-6">
                        <div class="small fw-semibold text-muted mb-1">Lebanese Sector</div>
                        <div class="small">
                            @(string.IsNullOrWhiteSpace(idea.LebanesesSector) ? "Not specified" : idea.LebanesesSector)
                        </div>
                    </div>

                    <div class="col-12">
                        <div class="small fw-semibold text-muted mb-1">Final Deliverables</div>
                        <div class="small">@idea.FinalDeliverables</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="page-card p-4 mb-3">
                <h6 class="fw-bold mb-3">Idea Scores</h6>

                @foreach (var score in new[] {
                    new { Label = "Innovation", Value = idea.InnovationScore, Color = "#3b82f6" },
                    new { Label = "Feasibility", Value = idea.FeasibilityScore, Color = "#10b981" },
                    new { Label = "Market Demand", Value = idea.MarketDemandScore, Color = "#f59e0b" },
                })
                {
                    <div class="mb-3">
                        <div class="d-flex justify-content-between small mb-1">
                            <span>@score.Label</span>
                            <span class="fw-semibold" style="color:@score.Color">@score.Value%</span>
                        </div>

                        <div class="progress" style="height:6px">
                            <div class="progress-bar" style="width:@score.Value%;background:@score.Color"></div>
                        </div>
                    </div>
                }
            </div>

            <div class="page-card p-4">
                <h6 class="fw-bold mb-3">Actions</h6>

                @if (!idea.IsSelected)
                {
                    <form method="post" asp-page-handler="Select" class="mb-2">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="ideaId" value="@idea.Id" />
                        <button type="submit" class="btn btn-primary btn-sm w-100">
                            <i class="bi bi-check2-circle me-1"></i>Select This Idea
                        </button>
                    </form>
                }

                <div class="d-grid gap-2">
                    <a href="/Student/IdeaGenerator" class="btn btn-outline-secondary btn-sm">
                        <i class="bi bi-arrow-left me-1"></i>Back to Ideas
                    </a>

                    <a href="/Student/ProjectDNA?ideaId=@idea.Id" class="btn btn-outline-primary btn-sm">
                        <i class="bi bi-diagram-3 me-1"></i>DNA Analysis
                    </a>

                    <a href="/Student/ScopeOptimizer?ideaId=@idea.Id" class="btn btn-outline-warning btn-sm">
                        <i class="bi bi-funnel me-1"></i>Scope Optimizer
                    </a>

                    @if (idea.IsSelected)
                    {
                        <a href="/Student/Roadmap?ideaId=@idea.Id" class="btn btn-outline-success btn-sm">
                            <i class="bi bi-map me-1"></i>View Roadmap
                        </a>

                        <a href="/Student/DefenseSimulator?ideaId=@idea.Id" class="btn btn-outline-danger btn-sm">
                            <i class="bi bi-shield-check me-1"></i>Defense Prep
                        </a>

                        <a href="/Student/MentorChat?ideaId=@idea.Id" class="btn btn-outline-secondary btn-sm">
                            <i class="bi bi-chat-dots me-1"></i>Mentor Chat
                        </a>
                    }
                    else
                    {
                        <div class="alert alert-info small mb-0">
                            Select this idea before creating a roadmap, using mentor chat, or preparing defense questions.
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
}