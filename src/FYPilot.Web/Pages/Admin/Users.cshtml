@page
@model FYPilot.Web.Pages.Admin.UsersModel
@{
    ViewData["Title"]    = "User Management";
    ViewData["Subtitle"] = "All registered platform users";
}

<div class="page-card p-4">
    <div class="d-flex align-items-center justify-content-between mb-3">
        <div class="d-flex gap-2">
            <span class="badge bg-primary-subtle text-primary">@Model.Users.Count(u => u.Role == "student") Students</span>
            <span class="badge bg-success-subtle text-success">@Model.Users.Count(u => u.Role == "supervisor") Supervisors</span>
            <span class="badge bg-danger-subtle text-danger">@Model.Users.Count(u => u.Role == "admin") Admins</span>
        </div>
        <div class="d-flex gap-2">
            <input type="text" id="searchInput" class="form-control form-control-sm" placeholder="Search users…" style="width:200px" />
        </div>
    </div>

    <div class="table-responsive">
        <table class="table table-hover align-middle" id="usersTable">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Role</th>
                    <th>Ideas</th>
                    <th>Joined</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Model.Users.OrderByDescending(u => u.CreatedAt))
                {
                    <tr>
                        <td class="text-muted small">@user.Id</td>
                        <td>
                            <div class="d-flex align-items-center gap-2">
                                <div class="avatar" style="width:30px;height:30px;font-size:0.75rem;background:@(user.Role == "student" ? "#dbeafe" : user.Role == "supervisor" ? "#dcfce7" : "#fef2f2");color:@(user.Role == "student" ? "#1d4ed8" : user.Role == "supervisor" ? "#15803d" : "#dc2626")">
                                    @(user.FullName.Length > 0 ? user.FullName[0].ToString() : "?")
                                </div>
                                <span class="fw-semibold small">@user.FullName</span>
                            </div>
                        </td>
                        <td class="small text-muted">@user.Email</td>
                        <td>
                            <span class="badge text-capitalize @(user.Role == "student" ? "bg-primary-subtle text-primary" : user.Role == "supervisor" ? "bg-success-subtle text-success" : "bg-danger-subtle text-danger")">
                                @user.Role
                            </span>
                        </td>
                        <td class="small">@user.IdeaCount</td>
                        <td class="small text-muted">@user.CreatedAt.ToString("dd MMM yyyy")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    <div class="text-muted small mt-2">Total: @Model.Users.Count users</div>
</div>

@section Scripts {
<script>
document.getElementById('searchInput').addEventListener('input', function() {
    var q = this.value.toLowerCase();
    document.querySelectorAll('#usersTable tbody tr').forEach(function(row) {
        row.style.display = row.textContent.toLowerCase().includes(q) ? '' : 'none';
    });
});
</script>
}
