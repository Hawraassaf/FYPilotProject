@page
@model FYPilot.Web.Pages.Account.ForceChangePasswordModel
@{
    ViewData["Title"] = "Secure Administrator Account";
    ViewData["Subtitle"] = "A password change is required before continuing.";
}

<div class="forced-password-overlay">
    <section class="forced-password-modal"
             role="dialog"
             aria-modal="true"
             aria-labelledby="passwordChangeTitle">

        <div class="security-icon">
            <i class="bi bi-shield-lock-fill"></i>
        </div>

        <div class="security-heading">
            <span class="security-eyebrow">
                Administrator security required
            </span>

            <h1 id="passwordChangeTitle">
                Create Your Private Password
            </h1>

            <p>
                Welcome to the FYPilot administration area.
                Your account was created using a temporary password.
                Before accessing administrator features, replace it with
                a secure password known only to you.
            </p>
        </div>

        <div class="temporary-password-notice">
            <div class="notice-icon">
                <i class="bi bi-key-fill"></i>
            </div>

            <div>
                <strong>Temporary password detected</strong>

                <span>
                    Enter the temporary password provided by the main
                    administrator, then choose your permanent password.
                </span>
            </div>
        </div>

        <form method="post"
              id="forcePasswordForm"
              class="password-change-form">

            <div asp-validation-summary="ModelOnly"
                 class="validation-summary"></div>

            <div class="form-field">
                <label asp-for="Input.CurrentPassword"></label>

                <div class="password-input-wrap">
                    <i class="bi bi-key input-icon"></i>

                    <input asp-for="Input.CurrentPassword"
                           class="form-control"
                           autocomplete="current-password"
                           placeholder="Enter your temporary password"
                           autofocus />

                    <button type="button"
                            class="password-toggle"
                            data-target="Input_CurrentPassword"
                            aria-label="Show or hide temporary password">
                        <i class="bi bi-eye"></i>
                    </button>
                </div>

                <span asp-validation-for="Input.CurrentPassword"
                      class="field-validation"></span>
            </div>

            <div class="form-field">
                <label asp-for="Input.NewPassword"></label>

                <div class="password-input-wrap">
                    <i class="bi bi-lock-fill input-icon"></i>

                    <input asp-for="Input.NewPassword"
                           class="form-control"
                           autocomplete="new-password"
                           placeholder="Enter your new secure password" />

                    <button type="button"
                            class="password-toggle"
                            data-target="Input_NewPassword"
                            aria-label="Show or hide new password">
                        <i class="bi bi-eye"></i>
                    </button>
                </div>

                <span asp-validation-for="Input.NewPassword"
                      class="field-validation"></span>
            </div>

            <div class="password-rules">
                <span>
                    <i class="bi bi-check-circle"></i>
                    At least 8 characters
                </span>

                <span>
                    <i class="bi bi-check-circle"></i>
                    One uppercase letter
                </span>

                <span>
                    <i class="bi bi-check-circle"></i>
                    One lowercase letter
                </span>

                <span>
                    <i class="bi bi-check-circle"></i>
                    At least one number
                </span>
            </div>

            <div class="form-field">
                <label asp-for="Input.ConfirmPassword"></label>

                <div class="password-input-wrap">
                    <i class="bi bi-shield-check input-icon"></i>

                    <input asp-for="Input.ConfirmPassword"
                           class="form-control"
                           autocomplete="new-password"
                           placeholder="Confirm your new password" />

                    <button type="button"
                            class="password-toggle"
                            data-target="Input_ConfirmPassword"
                            aria-label="Show or hide password confirmation">
                        <i class="bi bi-eye"></i>
                    </button>
                </div>

                <span asp-validation-for="Input.ConfirmPassword"
                      class="field-validation"></span>
            </div>

            <button type="submit"
                    class="secure-account-button"
                    id="secureAccountButton">

                <i class="bi bi-shield-check"></i>
                <span>Secure My Account and Continue</span>
            </button>
        </form>

        <div class="mandatory-message">
            <i class="bi bi-info-circle-fill"></i>

            <span>
                This security step cannot be skipped. Administrator pages
                will become available after your password is changed.
            </span>
        </div>
    </section>
</div>

@section Head {
    <style>
        :root {
            --security-deep: #071D49;
            --security-navy: #28385E;
            --security-steel: #516C8D;
            --security-border: #E1E7F0;
            --security-muted: #64748B;
            --security-soft: #F5F7FA;
            --security-success: #047857;
            --security-warning: #B45309;
        }

        body {
            overflow: hidden !important;
        }

        .forced-password-overlay {
            position: fixed;
            inset: 0;
            z-index: 99999;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 1.5rem;
            overflow-y: auto;
            background: rgba(7, 29, 73, .72);
            backdrop-filter: blur(13px);
            -webkit-backdrop-filter: blur(13px);
        }

            .forced-password-overlay::before {
                content: "";
                position: fixed;
                inset: 0;
                pointer-events: none;
                background: radial-gradient( circle at 15% 10%, rgba(81, 108, 141, .34), transparent 34%), radial-gradient( circle at 85% 90%, rgba(40, 56, 94, .35), transparent 35%);
            }

        .forced-password-modal {
            position: relative;
            width: min(100%, 560px);
            padding: 2rem;
            border: 1px solid rgba(255, 255, 255, .7);
            border-radius: 28px;
            background: rgba(255, 255, 255, .98);
            box-shadow: 0 35px 90px rgba(2, 12, 32, .42), 0 10px 32px rgba(7, 29, 73, .18);
            animation: securityModalEnter .35s ease-out;
        }

        @@keyframes securityModalEnter {
            from {
                opacity: 0;
                transform: translateY(18px) scale(.98);
            }

            to {
                opacity: 1;
                transform: translateY(0) scale(1);
            }
        }

        .security-icon {
            width: 72px;
            height: 72px;
            margin: -3.9rem auto 1rem;
            display: grid;
            place-items: center;
            border: 6px solid rgba(255, 255, 255, .96);
            border-radius: 23px;
            color: #fff;
            background: linear-gradient( 145deg, var(--security-deep), var(--security-navy) 55%, var(--security-steel));
            box-shadow: 0 15px 30px rgba(7, 29, 73, .28);
            font-size: 1.8rem;
        }

        .security-heading {
            text-align: center;
        }

        .security-eyebrow {
            display: block;
            margin-bottom: .35rem;
            color: var(--security-steel);
            font-size: .69rem;
            font-weight: 800;
            letter-spacing: .12em;
            text-transform: uppercase;
        }

        .security-heading h1 {
            margin: 0;
            color: #111827;
            font-size: clamp(1.55rem, 4vw, 2rem);
            font-weight: 800;
            letter-spacing: -.035em;
        }

        .security-heading p {
            max-width: 480px;
            margin: .7rem auto 1.25rem;
            color: var(--security-muted);
            font-size: .84rem;
            line-height: 1.65;
        }

        .temporary-password-notice {
            display: grid;
            grid-template-columns: auto minmax(0, 1fr);
            gap: .75rem;
            align-items: center;
            margin-bottom: 1.2rem;
            padding: .85rem;
            border: 1px solid #F6D79D;
            border-radius: 15px;
            background: #FFF9ED;
        }

        .notice-icon {
            width: 38px;
            height: 38px;
            display: grid;
            place-items: center;
            border-radius: 12px;
            color: var(--security-warning);
            background: #FFEDC7;
        }

        .temporary-password-notice strong {
            display: block;
            margin-bottom: .12rem;
            color: #7C3F08;
            font-size: .78rem;
        }

        .temporary-password-notice span {
            display: block;
            color: #92510B;
            font-size: .7rem;
            line-height: 1.5;
        }

        .password-change-form {
            display: grid;
            gap: .9rem;
        }

        .validation-summary {
            color: #B42318;
            font-size: .73rem;
        }

            .validation-summary:empty {
                display: none;
            }

            .validation-summary ul {
                margin: 0;
                padding: .75rem .75rem .75rem 2rem;
                border: 1px solid #F3C7C3;
                border-radius: 12px;
                background: #FFF4F3;
            }

        .form-field label {
            display: block;
            margin-bottom: .35rem;
            color: #334155;
            font-size: .75rem;
            font-weight: 750;
        }

        .password-input-wrap {
            position: relative;
        }

            .password-input-wrap .form-control {
                min-height: 47px;
                padding-left: 2.55rem;
                padding-right: 3rem;
                border: 1px solid #D9E1EC;
                border-radius: 13px;
                color: #111827;
                background: #FAFBFD;
                font-size: .82rem;
                transition: .16s ease;
            }

                .password-input-wrap .form-control:focus {
                    border-color: var(--security-steel);
                    background: #fff;
                    box-shadow: 0 0 0 .22rem rgba(81, 108, 141, .13);
                }

        .input-icon {
            position: absolute;
            left: .9rem;
            top: 50%;
            z-index: 2;
            transform: translateY(-50%);
            color: var(--security-steel);
            font-size: .9rem;
            pointer-events: none;
        }

        .password-toggle {
            position: absolute;
            right: .45rem;
            top: 50%;
            width: 36px;
            height: 36px;
            transform: translateY(-50%);
            display: grid;
            place-items: center;
            border: 0;
            border-radius: 9px;
            color: var(--security-steel);
            background: transparent;
            cursor: pointer;
        }

            .password-toggle:hover {
                background: #EDF1F6;
            }

        .field-validation {
            display: block;
            margin-top: .3rem;
            color: #B42318;
            font-size: .68rem;
        }

        .password-rules {
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: .35rem;
            margin-top: -.25rem;
            padding: .7rem;
            border-radius: 12px;
            background: var(--security-soft);
        }

            .password-rules span {
                display: flex;
                align-items: center;
                gap: .35rem;
                color: var(--security-muted);
                font-size: .64rem;
            }

            .password-rules i {
                color: var(--security-success);
            }

        .secure-account-button {
            min-height: 49px;
            margin-top: .25rem;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: .55rem;
            border: 0;
            border-radius: 14px;
            color: #fff;
            background: linear-gradient( 135deg, var(--security-deep), var(--security-navy) 60%, var(--security-steel));
            box-shadow: 0 13px 26px rgba(40, 56, 94, .23);
            font-size: .8rem;
            font-weight: 800;
            cursor: pointer;
            transition: .16s ease;
        }

            .secure-account-button:hover:not(:disabled) {
                transform: translateY(-1px);
                box-shadow: 0 17px 31px rgba(40, 56, 94, .3);
            }

            .secure-account-button:disabled {
                opacity: .72;
                cursor: wait;
            }

        .mandatory-message {
            display: flex;
            align-items: flex-start;
            justify-content: center;
            gap: .4rem;
            margin-top: 1rem;
            color: #7B8799;
            text-align: center;
            font-size: .65rem;
            line-height: 1.5;
        }

            .mandatory-message i {
                margin-top: .08rem;
                color: var(--security-steel);
            }

        @@media (max-width: 600px) {
            .forced-password-overlay {
                align-items: flex-start;
                padding: 3.7rem .85rem 1rem;
            }

            .forced-password-modal {
                padding: 1.4rem 1rem;
                border-radius: 21px;
            }

            .security-icon {
                width: 62px;
                height: 62px;
                margin-top: -3.2rem;
                border-radius: 20px;
                font-size: 1.45rem;
            }

            .password-rules {
                grid-template-columns: 1fr;
            }
        }
    </style>
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        document
            .querySelectorAll(".password-toggle")
            .forEach(function (button) {
                button.addEventListener("click", function () {
                    const input =
                        document.getElementById(button.dataset.target);

                    const icon =
                        button.querySelector("i");

                    if (!input) {
                        return;
                    }

                    const shouldShow =
                        input.type === "password";

                    input.type =
                        shouldShow ? "text" : "password";

                    if (icon) {
                        icon.className =
                            shouldShow
                                ? "bi bi-eye-slash"
                                : "bi bi-eye";
                    }
                });
            });

        const form =
            document.getElementById("forcePasswordForm");

        const submitButton =
            document.getElementById("secureAccountButton");

        form?.addEventListener("submit", function () {
            if (!form.checkValidity() || !submitButton) {
                return;
            }

            submitButton.disabled = true;

            submitButton.innerHTML =
                '<span class="spinner-border spinner-border-sm"></span>' +
                '<span>Securing account...</span>';
        });

        history.pushState(null, "", window.location.href);

        window.addEventListener("popstate", function () {
            history.pushState(null, "", window.location.href);
        });
    </script>
}