@page
@model FYPilot.Web.Pages.Account.LoginModel
@{
    Layout = null;
    ViewData["Title"] = "Sign In";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>Sign In — FYPilot</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <style>
        :root {
            --navy: #0f172a;
            --navy-medium: #17345f;
            --navy-light: #245a9b;
            --cream-light: #fffaf3;
            --page-background: linear-gradient(135deg, #0f172a 0%, #17345f 55%, #245a9b 100%);
        }

        body {
            margin: 0;
            min-height: 100vh;
            font-family: Inter, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Arial, sans-serif;
        }

        .auth-wrapper {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 2rem 1rem;
            background: var(--page-background);
        }

        .auth-card {
            width: min(100%, 650px);
            padding: 2.5rem;
            border-radius: 26px;
            background: #F8FAFC;
            border: 1px solid rgba(255,255,255,0.22);
            box-shadow: 0 30px 85px rgba(2,6,23,0.36);
        }

        .auth-brand {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 0.75rem;
        }

        .auth-brand-logo {
            width: 54px;
            height: 54px;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
            flex-shrink: 0;
            border-radius: 17px;
            background: var(--page-background);
            box-shadow: 0 10px 24px rgba(15,23,42,0.18);
        }

        .auth-brand-logo img {
            width: 44px;
            height: 44px;
            object-fit: contain;
        }

        .auth-logo {
            color: var(--navy);
            font-size: 1.8rem;
            font-weight: 850;
            line-height: 1;
        }

        .form-label {
            color: var(--navy);
        }

        .form-control {
            min-height: 48px;
            border-radius: 13px;
            border-color: #d8dee8;
        }

        .form-control:focus {
            border-color: var(--navy-medium);
            box-shadow: 0 0 0 0.2rem rgba(23,52,95,0.14);
        }

        .auth-link {
            color: var(--navy-medium);
            text-decoration: none;
            font-weight: 700;
            transition: color 0.18s ease;
        }

        .auth-link:hover {
            color: var(--navy);
            text-decoration: underline;
        }

        .btn-sign-in {
            min-height: 50px;
            color: #ffffff;
            border: 0;
            border-radius: 14px;
            background: var(--page-background);
            box-shadow: 0 14px 30px rgba(23,52,95,0.22);
            transition: transform 0.18s ease, box-shadow 0.18s ease;
        }

        .btn-sign-in:hover {
            color: #ffffff;
            transform: translateY(-1px);
            box-shadow: 0 18px 36px rgba(23,52,95,0.28);
        }

        .demo-panel {
            padding: 1rem;
            border-radius: 16px;
            background: #f8fafc;
            border: 1px solid #e2e8f0;
        }

        .demo-button {
            border-radius: 10px;
        }

        @@media (max-width: 575px) {
            .auth-card {
                padding: 1.5rem;
                border-radius: 20px;
            }

            .auth-brand-logo {
                width: 48px;
                height: 48px;
            }

            .auth-brand-logo img {
                width: 39px;
                height: 39px;
            }

            .auth-logo {
                font-size: 1.55rem;
            }
        }
            .auth-card {
                width: 100% !important;
                max-width: 500px !important;
                padding: 2.75rem 3rem;
            }
    </style>
</head>

<body>
    <div class="auth-wrapper">
        <div class="auth-card">
            <div class="text-center mb-4">
                <div class="auth-brand mb-2">
                    <div class="auth-brand-logo">
                        <img src="/image/FYPilot_logo.png" alt="FYPilot Logo" />
                    </div>

                    <div class="auth-logo">FYPilot</div>
                </div>

                <p class="text-muted small mb-0">Academic Intelligence System</p>
            </div>

            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="alert alert-danger small">
                    <i class="bi bi-exclamation-triangle me-1"></i>
                    @Model.ErrorMessage
                </div>
            }

            <form method="post">
                @if (TempData["PasswordResetMessage"] is string passwordResetMessage)
                {
                    <div id="passwordResetAlert" class="alert alert-success small mb-3">
                        <i class="bi bi-check-circle me-1"></i>
                        @passwordResetMessage
                    </div>
                }

                <div class="mb-3">
                    <label class="form-label fw-semibold small">Email address</label>

                    <input asp-for="Input.Email"
                           class="form-control"
                           type="email"
                           placeholder="you@example.com"
                           autofocus />
                </div>

                <div class="mb-3">
                    <label class="form-label fw-semibold small">Password</label>

                    <input asp-for="Input.Password"
                           class="form-control"
                           type="password"
                           placeholder="••••••••" />

                    <div class="text-end mt-2">
                        <a asp-page="/Account/ForgotPassword" class="auth-link small">
                            Forgot your password?
                        </a>
                    </div>
                </div>

                <div class="d-grid mt-4">
                    <button type="submit" class="btn btn-sign-in btn-lg fw-semibold">
                        <i class="bi bi-box-arrow-in-right me-2"></i>
                        Sign In
                    </button>
                </div>
            </form>

            <hr class="my-4" />

            <div class="text-center small text-muted">
                Don't have an account?

                <a asp-page="/Account/Register" class="auth-link">
                    Create one
                </a>
            </div>

            <div class="demo-panel mt-4">
                <div class="small fw-semibold text-muted mb-2">
                    Demo Accounts (password: password123)
                </div>

                <div class="d-flex flex-column gap-1">
                    <button type="button"
                            class="btn btn-sm btn-outline-secondary text-start demo-button"
                            onclick="fillDemo('student@fyp.com')">
                        <i class="bi bi-person-badge me-1"></i>
                        student@fyp.com
                    </button>

                    <button type="button"
                            class="btn btn-sm btn-outline-secondary text-start demo-button"
                            onclick="fillDemo('supervisor@fyp.com')">
                        <i class="bi bi-person-check me-1"></i>
                        supervisor@fyp.com
                    </button>

                    <button type="button"
                            class="btn btn-sm btn-outline-secondary text-start demo-button"
                            onclick="fillDemo('admin@fyp.com')">
                        <i class="bi bi-shield-check me-1"></i>
                        admin@fyp.com
                    </button>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        function fillDemo(email) {
            document.querySelector('[name="Input.Email"]').value = email;
            document.querySelector('[name="Input.Password"]').value = 'password123';
        }

        setTimeout(function () {
            const alertBox = document.getElementById("passwordResetAlert");

            if (alertBox) {
                alertBox.style.transition = "opacity 0.5s ease";
                alertBox.style.opacity = "0";

                setTimeout(function () {
                    alertBox.remove();
                }, 500);
            }
        }, 3000);
    </script>
</body>
</html>
