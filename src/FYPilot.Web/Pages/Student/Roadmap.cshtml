@page
@model FYPilot.Web.Pages.Student.RoadmapModel
@{
    ViewData["Title"] = "Project Roadmap";
    ViewData["Subtitle"] = "Plan, schedule, and execute your FYP with confidence";

    var orderedPhases = Model.Phases.OrderBy(p => p.PhaseNumber).ToList();
    var done = orderedPhases.Count(p => p.IsCompleted);
    var total = orderedPhases.Count;
    var pct = total > 0 ? (int)Math.Round(done * 100.0 / total) : 0;
    var currentPhase = orderedPhases.FirstOrDefault(p => !p.IsCompleted);
    var selectedPhase = currentPhase ?? orderedPhases.FirstOrDefault();

    var fallbackWeeks = Model.Idea?.ExpectedDurationWeeks
        ?? Math.Max(orderedPhases.Sum(p => Math.Max(1, p.EstimatedWeeks)), 1);

    var totalWeeks = Model.WorkloadSummary?.TotalWeeks > 0
        ? Model.WorkloadSummary.TotalWeeks
        : Math.Max(fallbackWeeks, 1);

    var phaseRanges =
        new System.Collections.Generic.Dictionary<string, (int StartWeek, int EndWeek, int Duration)>();

    var weekCursor = 1;

    foreach (var phase in orderedPhases)
    {
        var key = Convert.ToString(phase.Id) ?? phase.PhaseNumber.ToString();
        var duration = Math.Max(1, phase.EstimatedWeeks);
        var startWeek = Math.Min(weekCursor, totalWeeks);
        var endWeek = Math.Min(totalWeeks, startWeek + duration - 1);

        phaseRanges[key] = (startWeek, endWeek, Math.Max(1, endWeek - startWeek + 1));
        weekCursor = endWeek + 1;
    }

    string FeasibilityLabel(string? value) => value switch
    {
        "feasible" => "Feasible",
        "feasible_after_scope_reduction" => "Feasible after scope reduction",
        "over_capacity" => "Over capacity",
        _ => string.IsNullOrWhiteSpace(value) ? "Not evaluated" : value.Replace("_", " ")
    };

    string FeasibilityClass(string? value) => value switch
    {
        "feasible" => "is-feasible",
        "feasible_after_scope_reduction" => "is-adjusted",
        "over_capacity" => "is-over",
        _ => "is-neutral"
    };
}

@if (Model.Idea == null)
{
    <main class="roadmap-empty-page">
        <section class="roadmap-empty-card" aria-labelledby="roadmap-empty-title">
            <div class="roadmap-empty-icon" aria-hidden="true">
                <i class="bi bi-signpost-split"></i>
            </div>

            <div class="roadmap-eyebrow">Project planning</div>
            <h1 id="roadmap-empty-title">Choose a project idea first</h1>

            <p>
                Your roadmap is created from the selected idea, project difficulty, available weeks,
                weekly capacity, and team size.
            </p>

            <div class="roadmap-empty-actions">
                <a class="btn roadmap-btn-primary" asp-page="/Student/IdeaComparison">
                    <i class="bi bi-check2-circle"></i>
                    Choose an Idea
                </a>

                <a class="btn roadmap-btn-secondary" asp-page="/Student/IdeaGenerator">
                    <i class="bi bi-stars"></i>
                    Generate Ideas
                </a>
            </div>
        </section>
    </main>
}
else
{
    <main class="roadmap-control">

        @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
        {
            <div class="roadmap-alert roadmap-alert-warning" role="alert">
                <i class="bi bi-exclamation-triangle-fill" aria-hidden="true"></i>
                <span>@Model.ErrorMessage</span>
            </div>
        }

        <header class="roadmap-command-header">
            <div class="roadmap-command-main">
                <div class="roadmap-command-icon" aria-hidden="true">
                    <i class="bi bi-kanban"></i>
                </div>

                <div class="roadmap-command-copy">
                    <div class="roadmap-eyebrow">Project Roadmap</div>

                    <div class="roadmap-title-line">
                        <h1>@Model.Idea.Title</h1>

                        @if (Model.LatestReview != null)
                        {
                            var (badgeClass, badgeLabel) = Model.DescribeReview(Model.LatestReview);

                            <span class="badge @badgeClass roadmap-review-badge"
                                  title="@Model.LatestReview.DecisionReason">
                                <i class="bi bi-shield-check" aria-hidden="true"></i>
                                @badgeLabel
                            </span>
                        }
                    </div>

                    <div class="roadmap-project-meta">
                        <span>@Model.Idea.Domain</span>
                        <span class="text-capitalize">@Model.Idea.DifficultyLevel</span>
                        <span>@totalWeeks weeks</span>
                    </div>
                </div>
            </div>

            <div class="roadmap-command-actions">
                <form method="post" asp-page-handler="Generate" id="rmGenerateForm">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="ideaId" value="@Model.Idea.Id" />

                    <button type="submit"
                            class="btn @(Model.Phases.Any() ? "roadmap-btn-secondary" : "roadmap-btn-primary")">
                        <i class="bi @(Model.Phases.Any() ? "bi-arrow-clockwise" : "bi-magic")"
                           aria-hidden="true"></i>
                        @(Model.Phases.Any() ? "Regenerate" : "Generate Roadmap")
                    </button>
                </form>

                <a href="/Student/ProjectDNA?ideaId=@Model.Idea.Id"
                   class="btn roadmap-btn-secondary">
                    <i class="bi bi-fingerprint" aria-hidden="true"></i>
                    Project DNA
                </a>
            </div>

            <div class="roadmap-header-progress" aria-label="@pct percent complete">
                <div class="roadmap-header-progress-copy">
                    <span>@done of @total phases completed</span>
                    <strong>@pct%</strong>
                </div>

                <div class="roadmap-progress-track">
                    <div class="roadmap-progress-fill" style="width:@pct%"></div>
                </div>
            </div>
        </header>

        @if (!Model.Phases.Any())
        {
            <section class="roadmap-start-panel" aria-labelledby="roadmap-start-title">
                <div class="roadmap-start-copy">
                    <div class="roadmap-start-icon" aria-hidden="true">
                        <i class="bi bi-diagram-3"></i>
                    </div>

                    <div>
                        <div class="roadmap-eyebrow">Ready to plan</div>
                        <h2 id="roadmap-start-title">Generate a project-specific execution plan</h2>

                        <p>
                            FYPilot will create dynamic phases, estimate task effort, distribute team workload,
                            check capacity, and review the final roadmap before showing it.
                        </p>
                    </div>
                </div>

                <div class="roadmap-start-features">
                    <div>
                        <i class="bi bi-calendar-range"></i>
                        <span>Dynamic phase scheduling</span>
                    </div>
                    <div>
                        <i class="bi bi-hourglass-split"></i>
                        <span>Realistic effort estimates</span>
                    </div>
                    <div>
                        <i class="bi bi-people"></i>
                        <span>Team workload allocation</span>
                    </div>
                    <div>
                        <i class="bi bi-speedometer2"></i>
                        <span>Capacity validation</span>
                    </div>
                </div>

                <form method="post" asp-page-handler="Generate" id="rmGenerateFormEmpty">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="ideaId" value="@Model.Idea.Id" />

                    <button type="submit" class="btn roadmap-btn-primary roadmap-btn-large">
                        <i class="bi bi-magic"></i>
                        Generate AI Roadmap
                    </button>
                </form>
            </section>
        }
        else
        {
            var summary = Model.WorkloadSummary;

            <section class="roadmap-summary-strip" aria-label="Roadmap summary">
                <div class="roadmap-summary-item">
                    <span>Current phase</span>
                    <strong>@(currentPhase?.Name ?? "All completed")</strong>
                </div>

                <div class="roadmap-summary-item">
                    <span>Total duration</span>
                    <strong>@totalWeeks weeks</strong>
                </div>

                <div class="roadmap-summary-item">
                    <span>Progress</span>
                    <strong>@done / @total phases</strong>
                </div>

                <div class="roadmap-summary-item">
                    <span>Team</span>
                    <strong>@(summary?.TeamSize ?? 1) member(s)</strong>
                </div>

                <div class="roadmap-summary-item">
                    <span>Planned effort</span>
                    <strong>@(summary?.AdjustedPlannedHours ?? 0)h</strong>
                </div>

                <div class="roadmap-summary-item">
                    <span>Capacity</span>
                    <strong>@(summary?.TotalCapacityHours ?? 0)h</strong>
                </div>

                <div class="roadmap-summary-item">
                    <span>Utilization</span>
                    <strong>@(summary?.UtilizationPercentage ?? 0)%</strong>
                </div>

                <div class="roadmap-summary-item roadmap-summary-feasibility">
                    <span>Schedule</span>
                    <strong class="roadmap-feasibility-pill @FeasibilityClass(summary?.ScheduleFeasibility)">
                        @FeasibilityLabel(summary?.ScheduleFeasibility)
                    </strong>
                </div>
            </section>

            <section class="roadmap-workspace">
                <aside class="roadmap-phase-nav" aria-label="Roadmap phases">
                    <div class="roadmap-panel-heading">
                        <div>
                            <span>Navigation</span>
                            <h2>Project phases</h2>
                        </div>

                        <span class="roadmap-count-badge">@total</span>
                    </div>

                    <div class="roadmap-phase-list" role="tablist" aria-orientation="vertical">
                        @foreach (var phase in orderedPhases)
                        {
                            var phaseKey = Convert.ToString(phase.Id) ?? phase.PhaseNumber.ToString();
                            var range = phaseRanges[phaseKey];
                            var isSelected = selectedPhase != null &&
                                Convert.ToString(selectedPhase.Id) == phaseKey;
                            var stateClass = phase.IsCompleted
                                ? "is-completed"
                                : (currentPhase != null && Convert.ToString(currentPhase.Id) == phaseKey
                                    ? "is-current"
                                    : "is-upcoming");

                            <button type="button"
                                    class="roadmap-phase-tab @stateClass @(isSelected ? "is-selected" : "")"
                                    data-phase-select="@phaseKey"
                                    role="tab"
                                    aria-selected="@(isSelected ? "true" : "false")"
                                    aria-controls="phase-panel-@phaseKey">
                                <span class="roadmap-phase-tab-number">
                                    @if (phase.IsCompleted)
                                    {
                                        <i class="bi bi-check-lg" aria-hidden="true"></i>
                                    }
                                    else
                                    {
                                        @phase.PhaseNumber
                                    }
                                </span>

                                <span class="roadmap-phase-tab-copy">
                                    <strong>@phase.Name</strong>
                                    <small>
                                        Week @range.StartWeek@(range.EndWeek > range.StartWeek ? $"–{range.EndWeek}" : "")
                                        · @range.Duration week(s)
                                    </small>
                                </span>

                                <i class="bi bi-chevron-right roadmap-phase-tab-arrow" aria-hidden="true"></i>
                            </button>
                        }
                    </div>
                </aside>

                <div class="roadmap-main-column">
                    <section class="roadmap-gantt-card" aria-labelledby="gantt-title">
                        <div class="roadmap-panel-heading roadmap-gantt-heading">
                            <div>
                                <span>Schedule</span>
                                <h2 id="gantt-title">Weekly timeline</h2>
                            </div>

                            <div class="roadmap-gantt-legend" aria-label="Timeline legend">
                                <span><i class="legend-dot completed"></i>Completed</span>
                                <span><i class="legend-dot current"></i>Current</span>
                                <span><i class="legend-dot upcoming"></i>Upcoming</span>
                            </div>
                        </div>

                        <div class="roadmap-gantt-scroll">
                            <div class="roadmap-gantt" style="--week-count:@totalWeeks;">
                                <div class="roadmap-gantt-corner">Phase</div>

                                <div class="roadmap-gantt-weeks" style="--week-count:@totalWeeks;">
                                    @for (var week = 1; week <= totalWeeks; week++)
                                    {
                                        <div class="roadmap-gantt-week">W@week</div>
                                    }
                                </div>

                                @foreach (var phase in orderedPhases)
                                {
                                    var phaseKey = Convert.ToString(phase.Id) ?? phase.PhaseNumber.ToString();
                                    var range = phaseRanges[phaseKey];
                                    var tasks = FYPilot.Web.Pages.Student.RoadmapModel.ParseTasks(phase.TasksJson);
                                    var stateClass = phase.IsCompleted
                                        ? "is-completed"
                                        : (currentPhase != null && Convert.ToString(currentPhase.Id) == phaseKey
                                            ? "is-current"
                                            : "is-upcoming");

                                    <button type="button"
                                            class="roadmap-gantt-label"
                                            data-phase-select="@phaseKey"
                                            aria-label="Open @phase.Name">
                                        <span>@phase.PhaseNumber</span>
                                        <strong>@phase.Name</strong>
                                    </button>

                                    <div class="roadmap-gantt-track" style="--week-count:@totalWeeks;">
                                        <button type="button"
                                                class="roadmap-gantt-bar @stateClass"
                                                style="grid-column:@range.StartWeek / span @range.Duration;"
                                                data-phase-select="@phaseKey"
                                                title="@phase.Name: week @range.StartWeek to @range.EndWeek">
                                            <strong>@range.Duration wk</strong>
                                            <span>@tasks.Count task(s)</span>
                                        </button>
                                    </div>
                                }
                            </div>
                        </div>
                    </section>

                    <section class="roadmap-details-card" aria-labelledby="phase-details-title">
                        <div class="roadmap-panel-heading">
                            <div>
                                <span>Execution</span>
                                <h2 id="phase-details-title">Selected phase details</h2>
                            </div>
                        </div>

                        @foreach (var phase in orderedPhases)
                        {
                            var phaseKey = Convert.ToString(phase.Id) ?? phase.PhaseNumber.ToString();
                            var range = phaseRanges[phaseKey];
                            var isSelected = selectedPhase != null &&
                                Convert.ToString(selectedPhase.Id) == phaseKey;
                            var tasks = FYPilot.Web.Pages.Student.RoadmapModel.ParseTasks(phase.TasksJson);

                            <article id="phase-panel-@phaseKey"
                                     class="roadmap-detail-panel @(isSelected ? "is-active" : "")"
                                     data-phase-panel="@phaseKey"
                                     role="tabpanel"
                                     aria-hidden="@(isSelected ? "false" : "true")">

                                <div class="roadmap-detail-header">
                                    <div>
                                        <div class="roadmap-detail-kicker">
                                            Phase @phase.PhaseNumber
                                            <span>
                                                Week @range.StartWeek@(range.EndWeek > range.StartWeek ? $"–{range.EndWeek}" : "")
                                            </span>
                                        </div>

                                        <h3>@phase.Name</h3>
                                        <p>@phase.Objective</p>
                                    </div>

                                    <div class="roadmap-detail-actions">
                                        @if (phase.IsCompleted)
                                        {
                                            <span class="roadmap-complete-badge">
                                                <i class="bi bi-check-circle-fill"></i>
                                                Completed
                                            </span>
                                        }
                                        else
                                        {
                                            <form method="post" asp-page-handler="Complete">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="phaseId" value="@phase.Id" />
                                                <input type="hidden" name="ideaId" value="@Model.Idea.Id" />

                                                <button type="submit" class="btn roadmap-btn-success">
                                                    <i class="bi bi-check2"></i>
                                                    Mark phase done
                                                </button>
                                            </form>
                                        }
                                    </div>
                                </div>

                                <div class="roadmap-phase-facts">
                                    <div>
                                        <span>Duration</span>
                                        <strong>@range.Duration week(s)</strong>
                                    </div>

                                    <div>
                                        <span>Tasks</span>
                                        <strong>@tasks.Count</strong>
                                    </div>

                                    <div>
                                        <span>Dependencies</span>
                                        <strong>
                                            @(string.IsNullOrWhiteSpace(phase.Dependencies)
                                                ? "None"
                                                : phase.Dependencies)
                                        </strong>
                                    </div>
                                </div>

                                @if (tasks.Any())
                                {
                                    <div class="roadmap-task-table-wrap">
                                        <table class="roadmap-task-table">
                                            <thead>
                                                <tr>
                                                    <th scope="col">Task</th>
                                                    <th scope="col">Effort</th>
                                                    <th scope="col">Ownership</th>
                                                    <th scope="col">Allocation</th>
                                                    <th scope="col">Sequence</th>
                                                </tr>
                                            </thead>

                                            <tbody>
                                                @{
                                                    var taskNumber = 0;
                                                }

                                                @foreach (var task in tasks)
                                                {
                                                    taskNumber++;

                                                    <tr>
                                                        <td data-label="Task">
                                                            <div class="roadmap-task-title">
                                                                <span>@taskNumber</span>
                                                                <strong>@task.Title</strong>
                                                            </div>
                                                        </td>

                                                        <td data-label="Effort">
                                                            @(task.EstimatedHours.HasValue
                                                                ? $"{task.EstimatedHours}h"
                                                                : "Not specified")
                                                        </td>

                                                        <td data-label="Ownership">
                                                            @if (task.AssignedMembers.Count > 0)
                                                            {
                                                                <div class="roadmap-owner-list">
                                                                    @foreach (var member in task.AssignedMembers)
                                                                    {
                                                                        <span>@member</span>
                                                                    }
                                                                </div>
                                                            }
                                                            else
                                                            {
                                                                <span class="roadmap-muted">Unassigned</span>
                                                            }
                                                        </td>

                                                        <td data-label="Allocation">
                                                            @if (task.MemberAllocations.Count > 0)
                                                            {
                                                                <div class="roadmap-allocation-list">
                                                                    @foreach (var allocation in task.MemberAllocations)
                                                                    {
                                                                        <span>
                                                                            <strong>@allocation.MemberId</strong>
                                                                            @allocation.AllocationPercentage%
                                                                            · @allocation.AllocatedHours h
                                                                        </span>
                                                                    }
                                                                </div>
                                                            }
                                                            else
                                                            {
                                                                <span class="roadmap-muted">Single-owner task</span>
                                                            }
                                                        </td>

                                                        <td data-label="Sequence">
                                                            <span class="roadmap-sequence-chip">Task @taskNumber</span>
                                                        </td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                }
                                else
                                {
                                    <div class="roadmap-inline-empty">
                                        <i class="bi bi-list-check"></i>
                                        No task details are available for this phase.
                                    </div>
                                }

                                <div class="roadmap-detail-grid">
                                    @if (!string.IsNullOrWhiteSpace(phase.ExpectedOutput))
                                    {
                                        <section class="roadmap-info-box">
                                            <div class="roadmap-info-icon">
                                                <i class="bi bi-box-arrow-in-down"></i>
                                            </div>
                                            <div>
                                                <span>Expected output</span>
                                                <p>@phase.ExpectedOutput</p>
                                            </div>
                                        </section>
                                    }

                                    @if (!string.IsNullOrWhiteSpace(phase.SuccessCriteria))
                                    {
                                        <section class="roadmap-info-box">
                                            <div class="roadmap-info-icon">
                                                <i class="bi bi-bullseye"></i>
                                            </div>
                                            <div>
                                                <span>Success criteria</span>
                                                <p>@phase.SuccessCriteria</p>
                                            </div>
                                        </section>
                                    }

                                    @if (!string.IsNullOrWhiteSpace(phase.Risks))
                                    {
                                        <section class="roadmap-info-box roadmap-info-risk">
                                            <div class="roadmap-info-icon">
                                                <i class="bi bi-exclamation-triangle"></i>
                                            </div>
                                            <div>
                                                <span>Risk warning</span>
                                                <p>@phase.Risks</p>
                                            </div>
                                        </section>
                                    }
                                </div>
                            </article>
                        }
                    </section>
                </div>

                <aside class="roadmap-capacity-panel">
                    <section class="roadmap-side-section">
                        <div class="roadmap-side-heading">
                            <span>Current focus</span>
                            <i class="bi bi-crosshair"></i>
                        </div>

                        <h3>@(currentPhase?.Name ?? "Roadmap completed")</h3>
                        <p>
                            @(currentPhase?.Objective
                                ?? "All roadmap phases are marked as complete.")
                        </p>

                        <div class="roadmap-side-metric">
                            <span>Remaining phases</span>
                            <strong>@orderedPhases.Count(p => !p.IsCompleted)</strong>
                        </div>
                    </section>

                    @if (summary != null)
                    {
                        <section class="roadmap-side-section">
                            <div class="roadmap-side-heading">
                                <span>Capacity</span>
                                <i class="bi bi-speedometer2"></i>
                            </div>

                            <div class="roadmap-capacity-number">
                                <strong>@summary.UtilizationPercentage%</strong>
                                <span>utilization</span>
                            </div>

                            <div class="roadmap-meter">
                                @{
                                    var utilizationWidth = Math.Min(Math.Max(summary.UtilizationPercentage, 0), 100);
                                }
                                <div class="@FeasibilityClass(summary.ScheduleFeasibility)"
                                     style="width:@utilizationWidth%"></div>
                            </div>

                            <dl class="roadmap-side-stats">
                                <div>
                                    <dt>Adjusted plan</dt>
                                    <dd>@summary.AdjustedPlannedHours h</dd>
                                </div>
                                <div>
                                    <dt>Available capacity</dt>
                                    <dd>@summary.TotalCapacityHours h</dd>
                                </div>
                                <div>
                                    <dt>Team size</dt>
                                    <dd>@summary.TeamSize</dd>
                                </div>
                                <div>
                                    <dt>Weekly/member</dt>
                                    <dd>@summary.HoursPerWeekPerMember h</dd>
                                </div>
                            </dl>

                            @if (summary.OriginalPlannedHours != summary.AdjustedPlannedHours)
                            {
                                <div class="roadmap-scope-adjustment">
                                    <i class="bi bi-scissors"></i>
                                    <span>
                                        Scope adjusted from <strong>@summary.OriginalPlannedHours h</strong>
                                        to <strong>@summary.AdjustedPlannedHours h</strong>.
                                    </span>
                                </div>
                            }
                        </section>

                        @if (summary.WorkloadByMember.Any())
                        {
                            <section class="roadmap-side-section">
                                <div class="roadmap-side-heading">
                                    <span>Team workload</span>
                                    <i class="bi bi-people"></i>
                                </div>

                                <div class="roadmap-member-load-list">
                                    @foreach (var member in summary.WorkloadByMember)
                                    {
                                        var memberWidth = Math.Min(Math.Max(member.UtilizationPercentage, 0), 100);

                                        <div class="roadmap-member-load">
                                            <div class="roadmap-member-load-copy">
                                                <strong>@member.Member</strong>
                                                <span>@member.AssignedHours h · @member.UtilizationPercentage%</span>
                                            </div>

                                            <div class="roadmap-member-load-track">
                                                <div style="width:@memberWidth%"></div>
                                            </div>
                                        </div>
                                    }
                                </div>
                            </section>
                        }

                        @if (summary.Warnings.Any() ||
                             (summary.ScheduleFeasibility == "over_capacity" &&
                              summary.RecommendedAdditionalWeeks > 0))
                        {
                            <section class="roadmap-side-section roadmap-warning-section">
                                <div class="roadmap-side-heading">
                                    <span>Schedule alerts</span>
                                    <i class="bi bi-exclamation-triangle"></i>
                                </div>

                                @if (summary.ScheduleFeasibility == "over_capacity" &&
                                     summary.RecommendedAdditionalWeeks > 0)
                                {
                                    <div class="roadmap-warning-item is-critical">
                                        <i class="bi bi-calendar-plus"></i>
                                        <span>
                                            Add approximately
                                            <strong>@summary.RecommendedAdditionalWeeks week(s)</strong>
                                            or reduce mandatory scope.
                                        </span>
                                    </div>
                                }

                                @foreach (var warning in summary.Warnings)
                                {
                                    <div class="roadmap-warning-item">
                                        <i class="bi bi-info-circle"></i>
                                        <span>@warning</span>
                                    </div>
                                }
                            </section>
                        }
                    }
                </aside>
            </section>

            @if (Model.DeferredTasks.Any())
            {
                <section class="roadmap-deferred-card" aria-labelledby="deferred-title">
                    <details>
                        <summary>
                            <span>
                                <i class="bi bi-archive"></i>
                                <strong id="deferred-title">Future Enhancements</strong>
                                <small>Excluded from the current delivery plan</small>
                            </span>

                            <span class="roadmap-deferred-count">@Model.DeferredTasks.Count task(s)</span>
                        </summary>

                        <div class="roadmap-deferred-table-wrap">
                            <table class="roadmap-deferred-table">
                                <thead>
                                    <tr>
                                        <th scope="col">Task</th>
                                        <th scope="col">Original phase</th>
                                        <th scope="col">Effort</th>
                                        <th scope="col">Priority</th>
                                        <th scope="col">Reason deferred</th>
                                    </tr>
                                </thead>

                                <tbody>
                                    @foreach (var task in Model.DeferredTasks)
                                    {
                                        <tr>
                                            <td data-label="Task"><strong>@task.Title</strong></td>
                                            <td data-label="Original phase">@task.OriginalPhase</td>
                                            <td data-label="Effort">@task.EstimatedHours h</td>
                                            <td data-label="Priority">
                                                <span class="roadmap-priority-chip">@task.Priority</span>
                                            </td>
                                            <td data-label="Reason">@task.ReasonDeferred</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </details>
                </section>
            }
        }

        <div class="roadmap-loading-overlay d-none"
             id="rmLoadingOverlay"
             role="status"
             aria-live="polite"
             aria-label="Generating project roadmap">
            <div class="roadmap-loading-panel">
                <div class="roadmap-loading-top">
                    <div class="roadmap-loading-spinner" aria-hidden="true"></div>

                    <div>
                        <div class="roadmap-eyebrow">AI processing</div>
                        <h2>Building your project roadmap</h2>
                        <p>
                            Keep this page open while FYPilot generates, schedules, validates, and reviews the plan.
                        </p>
                    </div>
                </div>

                <div class="roadmap-loading-progress">
                    <div></div>
                </div>

                <ol class="roadmap-loading-steps">
                    <li class="is-active">
                        <i class="bi bi-folder2-open"></i>
                        Reading project context
                    </li>
                    <li>
                        <i class="bi bi-diagram-3"></i>
                        Generating project-specific phases
                    </li>
                    <li>
                        <i class="bi bi-hourglass-split"></i>
                        Estimating tasks and effort
                    </li>
                    <li>
                        <i class="bi bi-people"></i>
                        Allocating team workload
                    </li>
                    <li>
                        <i class="bi bi-shield-check"></i>
                        Reviewing roadmap quality
                    </li>
                </ol>
            </div>
        </div>
    </main>
}

@section Head {
