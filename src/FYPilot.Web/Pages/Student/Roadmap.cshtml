@page
@model FYPilot.Web.Pages.Student.RoadmapModel
@{
    ViewData["Title"] = "Project Roadmap";
    ViewData["Subtitle"] = "Evidence-based execution plan for your FYP";
}

@if (Model.Idea == null)
{
    <div class="page-card p-5 text-center">
        <i class="bi bi-map display-3 text-muted"></i>
        <h5 class="mt-3">No Project Selected</h5>
        <p class="text-muted">Generate and select a project idea first.</p>
        <a href="/Student/IdeaGenerator" class="btn btn-primary">
            <i class="bi bi-stars me-2"></i>Go to Idea Generator
        </a>
    </div>
}
else
{
    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="alert alert-warning small">
            <i class="bi bi-exclamation-triangle me-1"></i>
            @Model.ErrorMessage
        </div>
    }

    <div class="row g-4 mb-4">
        <div class="col-md-8">
            <div class="page-card p-4">
                <div class="d-flex align-items-start justify-content-between mb-1">
                    <div>
                        <h6 class="fw-bold mb-1">@Model.Idea.Title</h6>
                        <span class="badge bg-primary-subtle text-primary">@Model.Idea.Domain</span>
                        <span class="badge bg-secondary-subtle text-secondary">@Model.Idea.ExpectedDurationWeeks weeks total</span>
                    </div>

                    @if (!Model.Phases.Any())
                    {
                        <form method="post" asp-page-handler="Generate">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="ideaId" value="@Model.Idea.Id" />
                            <button type="submit" class="btn btn-primary btn-sm">
                                <i class="bi bi-magic me-1"></i>Generate AI Roadmap
                            </button>
                        </form>
                    }
                </div>
            </div>
        </div>

        <div class="col-md-4">
            @{
                var done = Model.Phases.Count(p => p.IsCompleted);
                var pct = Model.Phases.Any() ? (int)(done * 100.0 / Model.Phases.Count) : 0;
            }

            <div class="stat-card d-flex align-items-center gap-3">
                <div class="stat-icon" style="background:#f0fdf4">
                    <i class="bi bi-check2-all text-success"></i>
                </div>
                <div>
                    <div class="stat-value">@pct%</div>
                    <div class="stat-label">@done / @Model.Phases.Count phases complete</div>
                </div>
            </div>
        </div>
    </div>

    @if (Model.Phases.Any())
    {
        <div class="position-relative">
            @foreach (var phase in Model.Phases.OrderBy(p => p.PhaseNumber))
            {
                <div class="d-flex gap-3 mb-4">
                    <!-- Timeline dot -->
                    <div class="d-flex flex-column align-items-center" style="width:40px">
                        <div class="rounded-circle d-flex align-items-center justify-content-center fw-bold text-white"
                             style="width:36px;height:36px;background:@(phase.IsCompleted ? "#10b981" : "#3b82f6");flex-shrink:0">
                            @(phase.IsCompleted ? "✓" : phase.PhaseNumber.ToString())
                        </div>

                        @if (phase != Model.Phases.OrderBy(p => p.PhaseNumber).Last())
                        {
                            <div style="width:2px;flex-grow:1;background:#e2e8f0;margin-top:4px"></div>
                        }
                    </div>

                    <!-- Phase card -->
                    <div class="page-card p-4 flex-grow-1 mb-0">
                        <div class="d-flex align-items-start justify-content-between mb-2">
                            <div>
                                <h6 class="fw-bold mb-0">Phase @phase.PhaseNumber: @phase.Name</h6>
                                <span class="small text-muted">@phase.EstimatedWeeks week(s)</span>
                            </div>

                            <div class="d-flex gap-2 align-items-center">
                                @if (phase.IsCompleted)
                                {
                                    <span class="badge bg-success">Completed</span>
                                }
                                else
                                {
                                    <form method="post" asp-page-handler="Complete" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="phaseId" value="@phase.Id" />
                                        <button type="submit" class="btn btn-sm btn-outline-success">Mark Done</button>
                                    </form>
                                }
                            </div>
                        </div>

                        <p class="text-muted small mb-2">@phase.Objective</p>

                        @if (!string.IsNullOrEmpty(phase.TasksJson) && phase.TasksJson != "[]")
                        {
                            <div class="mb-2">
                                <div class="small fw-semibold mb-1">Tasks</div>
                                <ul class="small text-muted mb-0 ps-3">
                                    @foreach (var t in System.Text.Json.JsonSerializer.Deserialize<List<string>>(phase.TasksJson) ?? [])
                                    {
                                        <li>@t</li>
                                    }
                                </ul>
                            </div>
                        }

                        <div class="row g-2 small mt-2">
                            @if (!string.IsNullOrEmpty(phase.ExpectedOutput))
                            {
                                <div class="col-sm-6">
                                    <span class="fw-semibold text-muted">Output:</span> @phase.ExpectedOutput
                                </div>
                            }

                            @if (!string.IsNullOrEmpty(phase.SuccessCriteria))
                            {
                                <div class="col-sm-6">
                                    <span class="fw-semibold text-muted">Success:</span> @phase.SuccessCriteria
                                </div>
                            }

                            @if (!string.IsNullOrEmpty(phase.Risks))
                            {
                                <div class="col-12">
                                    <span class="badge bg-warning-subtle text-warning">
                                        <i class="bi bi-exclamation-triangle me-1"></i>Risk:
                                    </span>
                                    <span class="small text-muted">@phase.Risks</span>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="page-card p-5 text-center text-muted">
            <i class="bi bi-map display-4"></i>
            <p class="mt-3">
                Click <strong>Generate AI Roadmap</strong> above to create your evidence-based execution plan.
            </p>
        </div>
    }
}